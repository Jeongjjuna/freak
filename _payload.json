06,698,699],{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[117,701,703],{"id":702},"실무에서-만나는-곳","실무에서 만나는 곳",[611,705,706,709,712,715],{},[614,707,708],{},"JWT 서명 (HS256, RS256)",[614,710,711],{},"웹훅 검증 (Stripe, GitHub 등)",[614,713,714],{},"서버 간 API 인증",[614,716,717],{},"AWS SigV4 요청 서명",[117,719,721,722,725,726,729],{"id":720},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[109,723,724],{},"누가 보냈는지","와 ",[109,727,728],{},"내용이 안 바뀌었는지","를 증명한다",[106,731,732,733,736],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[109,734,735],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[106,738,739,740,742,743,745],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[109,741,81],{},"), 중간에 변조되지 않았다(",[109,744,735],{},")\"를 증명한다.",[106,747,748],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[117,750,752],{"id":751},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[106,754,755],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[106,757,758],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[106,760,761],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[763,764],"br",{},[106,766,767],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[411,769,770],{},[106,771,772],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":54,"searchDepth":169,"depth":169,"links":774},[775],{"id":693,"depth":28,"text":694,"children":776},[777,778,780],{"id":702,"depth":169,"text":703},{"id":720,"depth":169,"text":779},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":751,"depth":169,"text":752},"2026-06-03T15:40:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-signature",{"description":54},"feeds\u002F2026-06-03-signature",[82,787,788,789,790,791,81],"암호기초","백엔드","서명","HMAC","JWT","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":794,"title":795,"body":796,"date":873,"description":54,"extension":433,"meta":874,"navigation":172,"path":875,"seo":876,"stem":877,"tags":878,"__hash__":880},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":98,"value":797,"toc":866},[798,802,807,809,823,827,830,833,836,840,843,846,849,852,854,861],[101,799,801],{"id":800},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[411,803,804],{},[106,805,806],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[117,808,703],{"id":702},[611,810,811,814,817,820],{},[614,812,813],{},"비밀번호 저장",[614,815,816],{},"파일 무결성 검증",[614,818,819],{},"캐시 키 생성",[614,821,822],{},"Git 커밋 식별자",[117,824,826],{"id":825},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[106,828,829],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[106,831,832],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[106,834,835],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[117,837,839],{"id":838},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[106,841,842],{},"SHA-256은 매우 빠른 알고리즘이다.",[106,844,845],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[106,847,848],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[106,850,851],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[763,853],{},[106,855,856,857,860],{},"대표 알고리즘: SHA-256·SHA-512(",[109,858,859],{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[411,862,863],{},[106,864,865],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":54,"searchDepth":169,"depth":169,"links":867},[868],{"id":800,"depth":28,"text":801,"children":869},[870,871,872],{"id":702,"depth":169,"text":703},{"id":825,"depth":169,"text":826},{"id":838,"depth":169,"text":839},"2026-06-03T15:30:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-hash",{"description":54},"feeds\u002F2026-06-03-hash",[82,787,879],"해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":882,"title":883,"body":884,"date":955,"description":54,"extension":433,"meta":956,"navigation":172,"path":957,"seo":958,"stem":959,"tags":960,"__hash__":962},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":98,"value":885,"toc":948},[886,890,895,897,908,912,915,925,931,935,938,940,943],[101,887,889],{"id":888},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[411,891,892],{},[106,893,894],{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[117,896,703],{"id":702},[611,898,899,902,905],{},[614,900,901],{},"전송 구간 암호화: HTTPS\u002FTLS",[614,903,904],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[614,906,907],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[117,909,911],{"id":910},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[106,913,914],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[611,916,917,920],{},[614,918,919],{},"필요하다 → 암호화",[614,921,922,923],{},"필요하지 않다 → ",[109,924,879],{},[106,926,927,928,930],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[109,929,879],{},"를 사용한다.(다음편)",[117,932,934],{"id":933},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[106,936,937],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[763,939],{},[106,941,942],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[411,944,945],{},[106,946,947],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":54,"searchDepth":169,"depth":169,"links":949},[950],{"id":888,"depth":28,"text":889,"children":951},[952,953,954],{"id":702,"depth":169,"text":703},{"id":910,"depth":169,"text":911},{"id":933,"depth":169,"text":934},"2026-06-03T15:20:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encryption",{"description":54},"feeds\u002F2026-06-03-encryption",[82,787,961],"암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":964,"title":965,"body":966,"date":1050,"description":54,"extension":433,"meta":1051,"navigation":172,"path":1052,"seo":1053,"stem":1054,"tags":1055,"__hash__":1057},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":98,"value":967,"toc":1042},[968,972,977,979,1000,1004,1007,1010,1014,1025,1029,1032,1034,1037],[101,969,971],{"id":970},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[411,973,974],{},[106,975,976],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[117,978,703],{"id":702},[611,980,981,991,994,997],{},[614,982,983,984,156,987,990],{},"JWT의 ",[109,985,986],{},"header",[109,988,989],{},"payload"," (Base64URL)",[614,992,993],{},"URL의 한글·특수문자 (Percent-Encoding)",[614,995,996],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[614,998,999],{},"바이너리를 로그·DB에 저장할 때",[117,1001,1003],{"id":1002},"왜-사용할까","왜 사용할까?",[106,1005,1006],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[106,1008,1009],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[117,1011,1013],{"id":1012},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[106,1015,983,1016,725,1018,1020,1021,1024],{},[109,1017,986],{},[109,1019,989],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[109,1022,1023],{},"서명(Signature)"," 에서 나온다.",[117,1026,1028],{"id":1027},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[106,1030,1031],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[763,1033],{},[106,1035,1036],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[411,1038,1039],{},[106,1040,1041],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":54,"searchDepth":169,"depth":169,"links":1043},[1044],{"id":970,"depth":28,"text":971,"children":1045},[1046,1047,1048,1049],{"id":702,"depth":169,"text":703},{"id":1002,"depth":169,"text":1003},{"id":1012,"depth":169,"text":1013},{"id":1027,"depth":169,"text":1028},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":54},"feeds\u002F2026-06-03-encoding",[82,787,788,1056,791],"인코딩","8I5ExkCcCxIM2o5tuh_mX4i-P-F6f_Sv4n747ziuqKA",{"id":1059,"title":1060,"body":1061,"date":1297,"description":54,"extension":433,"meta":1298,"navigation":172,"path":1299,"seo":1300,"stem":1301,"tags":1302,"__hash__":1303},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":98,"value":1062,"toc":1288},[1063,1067,1070,1175,1179,1184,1195,1199,1210,1213,1224,1227,1232,1235,1239,1254,1257,1265,1268,1272],[117,1064,1066],{"id":1065},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[106,1068,1069],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[1071,1072,1073,1095],"table",{},[1074,1075,1076],"thead",{},[1077,1078,1079,1083,1086,1089,1092],"tr",{},[1080,1081,1082],"th",{},"구분",[1080,1084,1085],{},"목적",[1080,1087,1088],{},"방향성",[1080,1090,1091],{},"키",[1080,1093,1094],{},"대표 알고리즘",[1096,1097,1098,1120,1139,1157],"tbody",{},[1077,1099,1100,1106,1112,1115,1117],{},[1101,1102,1103],"td",{},[109,1104,1105],{},"인코딩 (Encoding)",[1101,1107,1108,1109],{},"형식 변환 ",[634,1110,1111],{},"(보안 아님)",[1101,1113,1114],{},"양방향 (키 불필요)",[1101,1116,462],{},[1101,1118,1119],{},"Base64, Base64URL, Hex",[1077,1121,1122,1127,1130,1133,1136],{},[1101,1123,1124],{},[109,1125,1126],{},"양방향 암호화 (Encryption)",[1101,1128,1129],{},"기밀성 — 내용 숨기기",[1101,1131,1132],{},"양방향 (복호화 가능)",[1101,1134,1135],{},"o",[1101,1137,1138],{},"AES(대칭키), RSA(비대칭키)",[1077,1140,1141,1146,1149,1152,1154],{},[1101,1142,1143],{},[109,1144,1145],{},"해시 (Hash)",[1101,1147,1148],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[1101,1150,1151],{},"단방향 (복원 불가)",[1101,1153,462],{},[1101,1155,1156],{},"SHA-256, SHA-512, SHA-3",[1077,1158,1159,1164,1167,1170,1172],{},[1101,1160,1161],{},[109,1162,1163],{},"서명 (Signature)",[1101,1165,1166],{},"무결성 + 인증 — 위변조 + 출처",[1101,1168,1169],{},"단방향 (해시 기반)",[1101,1171,1135],{},[1101,1173,1174],{},"HMAC-SHA256(HS256), RS256, ES256",[117,1176,1178],{"id":1177},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[1180,1181,1183],"h4",{"id":1182},"인코딩-암호화","인코딩 ≠ 암호화",[611,1185,1186,1189,1192],{},[614,1187,1188],{},"Base64는 키가 없다.",[614,1190,1191],{},"누구나 디코딩할 수 있다.",[614,1193,1194],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[1180,1196,1198],{"id":1197},"해시-서명","해시 ≠ 서명",[611,1200,1201,1204,1207],{},[614,1202,1203],{},"해시는 데이터의 지문을 생성한다.",[614,1205,1206],{},"같은 입력은 항상 같은 해시값을 만든다.",[614,1208,1209],{},"데이터가 변경되면 해시값도 달라진다.",[106,1211,1212],{},"반면 서명은",[611,1214,1215,1218,1221],{},[614,1216,1217],{},"해시에 키를 결합하여 생성한다.",[614,1219,1220],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[614,1222,1223],{},"누가 생성했는지까지 검증할 수 있다.",[106,1225,1226],{},"즉,",[411,1228,1229],{},[106,1230,1231],{},"서명(Signature) = 해시(Hash) + 키(Key)",[106,1233,1234],{},"라고 생각하면 이해하기 쉽다.",[1180,1236,1238],{"id":1237},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[106,1240,983,1241,1244,1245,1248,1249,1253],{},[109,1242,1243],{},"HS256","은 ",[109,1246,1247],{},"HMAC-SHA256","을 사용하는 ",[1250,1251,1252],"strong",{},"서명 알고리즘","이다.",[106,1255,1256],{},"토큰 내용을 숨기는 것이 아니라,",[611,1258,1259,1262],{},[614,1260,1261],{},"토큰이 위조되지 않았는지",[614,1263,1264],{},"신뢰할 수 있는 발급자가 만들었는지",[106,1266,1267],{},"를 검증하기 위해 사용된다.",[117,1269,1271],{"id":1270},"한-줄-요약","한 줄 요약",[411,1273,1274],{},[106,1275,1276,1277,1279,1280,1282,1283,1285,1286,653],{},"형식만 바꾸면 ",[1250,1278,1056],{},", 숨기면 ",[1250,1281,961],{},", 지문(위\u002F변조검사) 찍으면 ",[1250,1284,879],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[1250,1287,789],{},{"title":54,"searchDepth":169,"depth":169,"links":1289},[1290,1291,1296],{"id":1065,"depth":169,"text":1066},{"id":1177,"depth":169,"text":1178,"children":1292},[1293,1294,1295],{"id":1182,"depth":176,"text":1183},{"id":1197,"depth":176,"text":1198},{"id":1237,"depth":176,"text":1238},{"id":1270,"depth":169,"text":1271},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":54},"feeds\u002F2026-06-03-crypto-basics",[82,787,1056,961,879,789],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",{"id":1305,"title":1306,"body":1307,"date":1357,"description":1311,"extension":433,"meta":1358,"navigation":172,"path":1359,"seo":1360,"stem":1361,"tags":1362,"__hash__":1364},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":98,"value":1308,"toc":1354},[1309,1312,1315,1321,1324,1331,1336,1339,1345,1348,1351],[106,1310,1311],{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[106,1313,1314],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[1316,1317,1318],"ol",{},[614,1319,1320],{},"JWT 방식",[106,1322,1323],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[106,1325,1326],{},[1327,1328],"img",{"alt":1329,"src":1330},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[1316,1332,1333],{"start":28},[614,1334,1335],{},"HMAC (Hash-based Message Authentication Code)",[106,1337,1338],{},"서버 간에 시크릿 키를 공유한다.\n요청 하는 서버는 요청 정보(Request Body 등)를 시크릿 키를 이용해 해시 기반 서명값(MAC)으로 변환하고, 그 값을 \"헤더에 담아 전송\"한다.\n요청을 받은 서버는 요청 정보(Request Body 등) 을 동일한 시크릿 키로 해시 기반 서명값(MAC)으로 변환하고, \"그 결과가 헤더의 값과 같은지 확인하여 검증\"한다.",[106,1340,1341],{},[1327,1342],{"alt":1343,"src":1344},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[106,1346,1347],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[101,1349,1350],{"id":1350},"정리",[106,1352,1353],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":54,"searchDepth":169,"depth":169,"links":1355},[1356],{"id":1350,"depth":28,"text":1350},"2026-06-01T20:36:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-hmac",{"description":1311},"feeds\u002F2026-06-01-hmac",[82,1363,790,791,81],"네트워크","mJQJW2YkEiLfOXtm6jWO4bEV6DvCkJ55q9yOyoAMhZY",{"id":1366,"title":1367,"body":1368,"date":1501,"description":54,"extension":433,"meta":1502,"navigation":172,"path":1503,"seo":1504,"stem":1505,"tags":1506,"__hash__":1509},"feeds\u002Ffeeds\u002F2026-06-01-referential-transparency.md","2026 06 01 Referential Transparency",{"type":98,"value":1369,"toc":1499},[1370,1375,1380,1416,1421,1440,1445,1462,1464,1467,1488,1490,1493,1496],[411,1371,1372],{},[106,1373,1374],{},"참조 투명성(Referential Transparency) : 함수형 프로그래밍의 핵심 원칙",[1316,1376,1377],{},[614,1378,1379],{},"순수성",[611,1381,1382,1403],{},[614,1383,1384,1385],{},"규칙1. 값을 반환해야 한다.",[611,1386,1387,1395],{},[614,1388,1389,1390],{},"값 반환외에는 부수효과 없도록\n",[611,1391,1392],{},[614,1393,1394],{},"부수효과 : 파일 입출력, 데이터 전송,  화면 쓰기",[614,1396,1397,1398],{},"부수효과 없는 순수 애플리케이션이 가능한건가? 당연 불가능\n",[611,1399,1400],{},[614,1401,1402],{},"단, 타입 시스템을 사용해서 부수 효과가 발생하는 시점을 명시적으로 표시하고, 명확하게 드러내는 방향으로 가야한다.",[614,1404,1405,1406],{},"규칙 2. 결과가 입력에만 의존해아함.",[611,1407,1408],{},[614,1409,1410,1411],{},"결과값 계산을 위해 입력(파라미터)외에 다른것을 사용하지 않아야함.\n",[611,1412,1413],{},[614,1414,1415],{},"ex) 계산을 위해 전역, 싱글톤, 파일, 네트워크 소켓등 사용 x",[1316,1417,1418],{"start":28},[614,1419,1420],{},"불변성",[611,1422,1423,1426],{},[614,1424,1425],{},"불변 데이터 구조를 사용하자.",[614,1427,1428,1429,1432],{},"순수함수 + 불변데이터 ⇒ ",[109,1430,1431],{},"디버깅하고 오류 피하기가 쉬워짐.",[611,1433,1434,1437],{},[614,1435,1436],{},"함수형 코드를 읽을 때 상태를 신경쓰지 않아도됨.",[614,1438,1439],{},"결국 상태 변경을 신경쓰며 프로그래밍을 하게될때, 사람은 실수를 하게 된다.(예측 하기 어려운 버그 발생)",[1316,1441,1442],{"start":169},[614,1443,1444],{},"전체성",[611,1446,1447],{},[614,1448,1449,1450],{},"모든 입력값에 대해 유한 시간내에 결과 반환하는 함수\n",[611,1451,1452,1455],{},[614,1453,1454],{},"무한루프를 가지지 말것",[614,1456,1457,1458,1461],{},"모든 입력에대한 결과를 반환해라(",[109,1459,1460],{},"예외 보다는 결과값을 반환할 것",")",[763,1463],{},[106,1465,1466],{},"객체 인스턴스 생성의 메모리 CPU 사용량?",[611,1468,1469,1472,1475],{},[614,1470,1471],{},"JVM 객체 생성 비용이 그렇게 높지 않음",[614,1473,1474],{},"불변 객체를 사용하면 JIT 컴파일러와 가비지 컬렉터가 효율적으로 동작할 확률이 높음.",[614,1476,1477,1478,156,1481,156,1484,1487],{},"즉, 약간의 객체 생성 비용보다, ",[109,1479,1480],{},"예측 가능성",[109,1482,1483],{},"테스트 용이성",[109,1485,1486],{},"동시성 안정성"," 등을 우선으로 봄",[763,1489],{},[106,1491,1492],{},"결국 함수형 프로그래밍은\n\"코드를 더 똑똑하게 작성하는 방법\"이라기보다,",[106,1494,1495],{},"\"예측 가능한 시스템을 만드는 방법\", \"디버깅을 쉽게하고, 상태에 따른 예측하기 어려운 버그 가능성을 줄이는 방법.\"",[106,1497,1498],{},"에 가까운 것 같다.",{"title":54,"searchDepth":169,"depth":169,"links":1500},[],"2026-06-01T04:07:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-referential-transparency",{"description":54},"feeds\u002F2026-06-01-referential-transparency",[1507,1508],"FP","참조 투명성","_nS-0fooYQq5yg3NLwUQLQQa1TyGJ6c6nAshLDTwBfY",{"id":1511,"title":1512,"body":1513,"date":1561,"description":1517,"extension":433,"meta":1562,"navigation":172,"path":1563,"seo":1564,"stem":1565,"tags":1566,"__hash__":1568},"feeds\u002Ffeeds\u002F2026-05-31-oop-fp.md","2026 05 31 Oop Fp",{"type":98,"value":1514,"toc":1559},[1515,1518,1521,1529,1532,1553,1556],[106,1516,1517],{},"기존에 나는 읽기 쉽고, 확장성이 좋고, 협업하기 좋은 코드를 작성하기 위해 OOP와 FP를 활용했다.",[106,1519,1520],{},"하지만 이제는 AI가 코드를 작성하는 시대다.\nAI가 코드를 작성하게 되면서 부터는 문득 이런 생각이 들었다.",[411,1522,1523],{},[106,1524,1525,1526,1528],{},"\"객체지향(OOP), 함수형 프로그래밍(FP)을 계속 공부하는 것이 여전히 의미가 있을까?\"",[763,1527],{},"\n\"개발자의 역할이 구현보다 테스트와 검증에 가까워지고 있다면, OOP와 FP는 어떤 가치를 가질까?\"",[106,1530,1531],{},"내가 생각하는 핵심은 다음과 같다.",[611,1533,1534,1542],{},[614,1535,1536,1537],{},"객체지향 프로그래밍(OOP)\n",[611,1538,1539],{},[614,1540,1541],{},"책임과 경계를 정의한다.",[614,1543,1544,1545],{},"함수형 프로그래밍(FP)\n",[611,1546,1547,1550],{},[614,1548,1549],{},"예측 가능성을 높인다.",[614,1551,1552],{},"부수효과(Side Effect)를 최소화한다.",[106,1554,1555],{},"누군가는 AI 개발을 지휘해야하고, 능숙하게 시스템을 파악하여 AI 에게 또다시 프롬프트를 전달해야한다.\n그렇기 때문에 어떤 책임을 어디에 둘지,\n어떤 상태 변경을 허용할지,\n무엇을 검증해야 하는지는 여전히 사람이 결정하는게 좋다고 생각한다.",[106,1557,1558],{},"앞으로는 협업과 확장성뿐 아니라,\nAI Agent 개발 관점에서 설계 → 테스트 → 검증까지의 흐름 속에서\n객체지향과 함수형이 어떤 이점을 주는지 직접 실험해보고 기록해보려 한다.",{"title":54,"searchDepth":169,"depth":169,"links":1560},[],"2026-05-31T23:50:00+09:00",{},"\u002Ffeeds\u002F2026-05-31-oop-fp",{"description":1517},"feeds\u002F2026-05-31-oop-fp",[1567,1507,73],"OOP","N9SjZzLRCfBFEcIvGVaOj6-Girq0VI3AybXYfO-Zn2M",{"id":1570,"title":1571,"body":1572,"date":1561,"description":1576,"extension":433,"meta":1597,"navigation":172,"path":1598,"seo":1599,"stem":1600,"tags":1601,"__hash__":1604},"feeds\u002Ffeeds\u002F2026-05-31-readable-code.md","2026 05 31 Readable Code",{"type":98,"value":1573,"toc":1595},[1574,1577,1580,1583,1586,1589,1592],[106,1575,1576],{},"AI 덕분에 코드 생산량은 훨씬 빨라졌다.",[106,1578,1579],{},"평소 확장성을 고려해 설계하는 것을 좋아했는데,\n반복 구현이나 노가다에 가까운 테스트 코드 작성이 많이 줄어든 것 같아 좋다.",[106,1581,1582],{},"그래도 결국 버그가 발생하면 사람이 코드를 읽고 이해해야 하는 순간이 온다.\n그렇다면 이왕이면 사람도 읽기 쉽게 설계하고 구현하는 것이 좋지 않을까?",[106,1584,1585],{},"AI에게 좋은 프롬프트를 주기 위해서도,\n읽기 쉽고 확장 가능한 코드를 유지하기 위해서도,\n개발자는 여전히 설계와 코드 품질을 고민해야 한다.",[106,1587,1588],{},"내가 이해하지 못하는 시스템을 AI에게 제대로 설명할 수는 없다.",[106,1590,1591],{},"어셈블리어가 아닌 고수준 언어를 사용하는 이상,\nAI 시대에도 좋은 코드의 기준은 크게 달라지지 않은 것 같다.",[106,1593,1594],{},"오히려 더 중요해졌을지도.",{"title":54,"searchDepth":169,"depth":169,"links":1596},[],{},"\u002Ffeeds\u002F2026-05-31-readable-code",{"description":1576},"feeds\u002F2026-05-31-readable-code",[1602,1603],"가독성","유지보수","DSKfabvGfJ_uiuX6TR-UXYZnBshpE5BiXWt6Fq8gQnM",1780811788101]