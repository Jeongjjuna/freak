[{"data":1,"prerenderedAt":410},["ShallowReactive",2],{"layout-data":3,"all-feeds":94},{"groups":4,"recentPosts":46},[5,11,41],{"name":6,"categories":7},"Engineering",[8],{"name":9,"count":10},"Architecture",1,{"name":12,"categories":13},"Learning",[14,16,18,20,22,24,26,29,31,33,35,37,39],{"name":15,"count":10},"API",{"name":17,"count":10},"Docker",{"name":19,"count":10},"Git",{"name":21,"count":10},"JPA",{"name":23,"count":10},"Kafka",{"name":25,"count":10},"Kubernetes",{"name":27,"count":28},"MySQL",2,{"name":30,"count":10},"RabbitMQ",{"name":32,"count":10},"Redis",{"name":34,"count":10},"Security",{"name":36,"count":28},"SpringBoot",{"name":38,"count":10},"SpringSecurity",{"name":40,"count":10},"Testing",{"name":42,"categories":43},"Archive",[44],{"name":45,"count":10},"Books",[47,55,65,75,85],{"slug":48,"title":49,"date":50,"category":27,"tags":51,"excerpt":53,"thumbnail":54},"revisiting-db-locks","초심 찾기! 동시성 처리를 위한 DB Lock 다시 한번 복습해보자","2026-04-30",[27,52,21],"동시성","","\u002Fimages\u002Fthumbnails\u002Fdatabase.png",{"slug":56,"title":57,"date":58,"category":45,"tags":59,"excerpt":53,"thumbnail":64},"minimum-practical-knowledge-for-developers","개발자를 위한 최소한의 실무 지식 독서 회고","2026-04-18",[60,61,62,63],"독서","실무지식","성장","커리어","\u002Fimages\u002Fthumbnails\u002Fbooks.png",{"slug":66,"title":67,"date":68,"category":9,"tags":69,"excerpt":53,"thumbnail":74},"spring-architecture","아키텍처 규칙 강제하기(feat MultiModule, ArchUnit, AI Agent)","2026-04-08",[70,36,71,72,73],"Kotlin","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",{"slug":76,"title":77,"date":78,"category":38,"tags":79,"excerpt":53,"thumbnail":84},"spring-security-architecture","[Example] Spring Security 동작 원리, 프로세스 이해하기","2026-03-15",[80,81,82,83],"Spring Security","Authentication","Filter","Java","\u002Fimages\u002Fthumbnails\u002Fsecurity.png",{"slug":86,"title":87,"date":88,"category":36,"tags":89,"excerpt":53,"thumbnail":93},"spring-aop-private-method","[Example] Spring AOP를 private 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[90,91,83,92],"Spring","AOP","Transactional","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[95,165,315,374],{"id":96,"title":97,"body":98,"date":153,"description":104,"extension":154,"meta":155,"navigation":156,"path":157,"seo":158,"stem":159,"tags":160,"__hash__":164},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":99,"value":100,"toc":149},"minimark",[101,105,108,115,118,125,130,133,139,142,146],[102,103,104],"p",{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[102,106,107],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[109,110,111],"ol",{},[112,113,114],"li",{},"JWT 방식",[102,116,117],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[102,119,120],{},[121,122],"img",{"alt":123,"src":124},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[109,126,127],{"start":28},[112,128,129],{},"HMAC (Hash-based Message Authentication Code)",[102,131,132],{},"서버 간에 시크릿 키를 공유한다.\n보내는 서버는 요청 정보(Request Body 등)로 시크릿 키를 이용해 해시 기반 서명값(MAC)을 계산하고, 그 값을 헤더에 담아 전송한다. 본문 자체는 암호화되지 않고 그대로 간다.\n받은 서버는 동일한 시크릿 키로 요청 정보를 똑같이 계산하고, 그 결과가 헤더의 값과 같은지 확인하여 검증한다.",[102,134,135],{},[121,136],{"alt":137,"src":138},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[102,140,141],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[143,144,145],"h2",{"id":145},"정리",[102,147,148],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":53,"searchDepth":150,"depth":150,"links":151},3,[152],{"id":145,"depth":28,"text":145},"2026-06-01T20:36:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-01-hmac",{"description":104},"feeds\u002F2026-06-01-hmac",[161,162,163],"보안","네트워크","HMAC","G4AmG5dtKsOs_ngpnRI6pR6dZfX7HE-nCEhpUKuTu8g",{"id":166,"title":167,"body":168,"date":306,"description":53,"extension":154,"meta":307,"navigation":156,"path":308,"seo":309,"stem":310,"tags":311,"__hash__":314},"feeds\u002Ffeeds\u002F2026-06-01-referential-transparency.md","2026 06 01 Referential Transparency",{"type":99,"value":169,"toc":304},[170,176,181,218,223,243,248,265,268,271,293,295,298,301],[171,172,173],"blockquote",{},[102,174,175],{},"참조 투명성(Referential Transparency) : 함수형 프로그래밍의 핵심 원칙",[109,177,178],{},[112,179,180],{},"순수성",[182,183,184,205],"ul",{},[112,185,186,187],{},"규칙1. 값을 반환해야 한다.",[182,188,189,197],{},[112,190,191,192],{},"값 반환외에는 부수효과 없도록\n",[182,193,194],{},[112,195,196],{},"부수효과 : 파일 입출력, 데이터 전송,  화면 쓰기",[112,198,199,200],{},"부수효과 없는 순수 애플리케이션이 가능한건가? 당연 불가능\n",[182,201,202],{},[112,203,204],{},"단, 타입 시스템을 사용해서 부수 효과가 발생하는 시점을 명시적으로 표시하고, 명확하게 드러내는 방향으로 가야한다.",[112,206,207,208],{},"규칙 2. 결과가 입력에만 의존해아함.",[182,209,210],{},[112,211,212,213],{},"결과값 계산을 위해 입력(파라미터)외에 다른것을 사용하지 않아야함.\n",[182,214,215],{},[112,216,217],{},"ex) 계산을 위해 전역, 싱글톤, 파일, 네트워크 소켓등 사용 x",[109,219,220],{"start":28},[112,221,222],{},"불변성",[182,224,225,228],{},[112,226,227],{},"불변 데이터 구조를 사용하자.",[112,229,230,231,235],{},"순수함수 + 불변데이터 ⇒ ",[232,233,234],"code",{},"디버깅하고 오류 피하기가 쉬워짐.",[182,236,237,240],{},[112,238,239],{},"함수형 코드를 읽을 때 상태를 신경쓰지 않아도됨.",[112,241,242],{},"결국 상태 변경을 신경쓰며 프로그래밍을 하게될때, 사람은 실수를 하게 된다.(예측 하기 어려운 버그 발생)",[109,244,245],{"start":150},[112,246,247],{},"전체성",[182,249,250],{},[112,251,252,253],{},"모든 입력값에 대해 유한 시간내에 결과 반환하는 함수\n",[182,254,255,258],{},[112,256,257],{},"무한루프를 가지지 말것",[112,259,260,261,264],{},"모든 입력에대한 결과를 반환해라(",[232,262,263],{},"예외 보다는 결과값을 반환할 것",")",[266,267],"br",{},[102,269,270],{},"객체 인스턴스 생성의 메모리 CPU 사용량?",[182,272,273,276,279],{},[112,274,275],{},"JVM 객체 생성 비용이 그렇게 높지 않음",[112,277,278],{},"불변 객체를 사용하면 JIT 컴파일러와 가비지 컬렉터가 효율적으로 동작할 확률이 높음.",[112,280,281,282,285,286,285,289,292],{},"즉, 약간의 객체 생성 비용보다, ",[232,283,284],{},"예측 가능성",", ",[232,287,288],{},"테스트 용이성",[232,290,291],{},"동시성 안정성"," 등을 우선으로 봄",[266,294],{},[102,296,297],{},"결국 함수형 프로그래밍은\n\"코드를 더 똑똑하게 작성하는 방법\"이라기보다,",[102,299,300],{},"\"예측 가능한 시스템을 만드는 방법\", \"디버깅을 쉽게하고, 상태에 따른 예측하기 어려운 버그 가능성을 줄이는 방법.\"",[102,302,303],{},"에 가까운 것 같다.",{"title":53,"searchDepth":150,"depth":150,"links":305},[],"2026-06-01T04:07:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-referential-transparency",{"description":53},"feeds\u002F2026-06-01-referential-transparency",[312,313],"FP","참조 투명성","_nS-0fooYQq5yg3NLwUQLQQa1TyGJ6c6nAshLDTwBfY",{"id":316,"title":317,"body":318,"date":366,"description":322,"extension":154,"meta":367,"navigation":156,"path":368,"seo":369,"stem":370,"tags":371,"__hash__":373},"feeds\u002Ffeeds\u002F2026-05-31-oop-fp.md","2026 05 31 Oop Fp",{"type":99,"value":319,"toc":364},[320,323,326,334,337,358,361],[102,321,322],{},"기존에 나는 읽기 쉽고, 확장성이 좋고, 협업하기 좋은 코드를 작성하기 위해 OOP와 FP를 활용했다.",[102,324,325],{},"하지만 이제는 AI가 코드를 작성하는 시대다.\nAI가 코드를 작성하게 되면서 부터는 문득 이런 생각이 들었다.",[171,327,328],{},[102,329,330,331,333],{},"\"객체지향(OOP), 함수형 프로그래밍(FP)을 계속 공부하는 것이 여전히 의미가 있을까?\"",[266,332],{},"\n\"개발자의 역할이 구현보다 테스트와 검증에 가까워지고 있다면, OOP와 FP는 어떤 가치를 가질까?\"",[102,335,336],{},"내가 생각하는 핵심은 다음과 같다.",[182,338,339,347],{},[112,340,341,342],{},"객체지향 프로그래밍(OOP)\n",[182,343,344],{},[112,345,346],{},"책임과 경계를 정의한다.",[112,348,349,350],{},"함수형 프로그래밍(FP)\n",[182,351,352,355],{},[112,353,354],{},"예측 가능성을 높인다.",[112,356,357],{},"부수효과(Side Effect)를 최소화한다.",[102,359,360],{},"누군가는 AI 개발을 지휘해야하고, 능숙하게 시스템을 파악하여 AI 에게 또다시 프롬프트를 전달해야한다.\n그렇기 때문에 어떤 책임을 어디에 둘지,\n어떤 상태 변경을 허용할지,\n무엇을 검증해야 하는지는 여전히 사람이 결정하는게 좋다고 생각한다.",[102,362,363],{},"앞으로는 협업과 확장성뿐 아니라,\nAI Agent 개발 관점에서 설계 → 테스트 → 검증까지의 흐름 속에서\n객체지향과 함수형이 어떤 이점을 주는지 직접 실험해보고 기록해보려 한다.",{"title":53,"searchDepth":150,"depth":150,"links":365},[],"2026-05-31T23:50:00+09:00",{},"\u002Ffeeds\u002F2026-05-31-oop-fp",{"description":322},"feeds\u002F2026-05-31-oop-fp",[372,312,73],"OOP","N9SjZzLRCfBFEcIvGVaOj6-Girq0VI3AybXYfO-Zn2M",{"id":375,"title":376,"body":377,"date":366,"description":381,"extension":154,"meta":402,"navigation":156,"path":403,"seo":404,"stem":405,"tags":406,"__hash__":409},"feeds\u002Ffeeds\u002F2026-05-31-readable-code.md","2026 05 31 Readable Code",{"type":99,"value":378,"toc":400},[379,382,385,388,391,394,397],[102,380,381],{},"AI 덕분에 코드 생산량은 훨씬 빨라졌다.",[102,383,384],{},"평소 확장성을 고려해 설계하는 것을 좋아했는데,\n반복 구현이나 노가다에 가까운 테스트 코드 작성이 많이 줄어든 것 같아 좋다.",[102,386,387],{},"그래도 결국 버그가 발생하면 사람이 코드를 읽고 이해해야 하는 순간이 온다.\n그렇다면 이왕이면 사람도 읽기 쉽게 설계하고 구현하는 것이 좋지 않을까?",[102,389,390],{},"AI에게 좋은 프롬프트를 주기 위해서도,\n읽기 쉽고 확장 가능한 코드를 유지하기 위해서도,\n개발자는 여전히 설계와 코드 품질을 고민해야 한다.",[102,392,393],{},"내가 이해하지 못하는 시스템을 AI에게 제대로 설명할 수는 없다.",[102,395,396],{},"어셈블리어가 아닌 고수준 언어를 사용하는 이상,\nAI 시대에도 좋은 코드의 기준은 크게 달라지지 않은 것 같다.",[102,398,399],{},"오히려 더 중요해졌을지도.",{"title":53,"searchDepth":150,"depth":150,"links":401},[],{},"\u002Ffeeds\u002F2026-05-31-readable-code",{"description":381},"feeds\u002F2026-05-31-readable-code",[407,408],"readable-code","유지보수","ITbkErFtzBmXv3ZiNmq5v23IRF4f_nW9ab0ikxuW9Bc",1780317006109]