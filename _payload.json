[{"data":1,"prerenderedAt":411},["ShallowReactive",2],{"layout-data":3,"all-feeds":94},{"groups":4,"recentPosts":46},[5,11,41],{"name":6,"categories":7},"Engineering",[8],{"name":9,"count":10},"Architecture",1,{"name":12,"categories":13},"Learning",[14,16,18,20,22,24,26,29,31,33,35,37,39],{"name":15,"count":10},"API",{"name":17,"count":10},"Docker",{"name":19,"count":10},"Git",{"name":21,"count":10},"JPA",{"name":23,"count":10},"Kafka",{"name":25,"count":10},"Kubernetes",{"name":27,"count":28},"MySQL",2,{"name":30,"count":10},"RabbitMQ",{"name":32,"count":10},"Redis",{"name":34,"count":10},"Security",{"name":36,"count":28},"SpringBoot",{"name":38,"count":10},"SpringSecurity",{"name":40,"count":10},"Testing",{"name":42,"categories":43},"Archive",[44],{"name":45,"count":10},"Books",[47,55,65,75,85],{"slug":48,"title":49,"date":50,"category":27,"tags":51,"excerpt":53,"thumbnail":54},"revisiting-db-locks","초심 찾기! 동시성 처리를 위한 DB Lock 다시 한번 복습해보자","2026-04-30",[27,52,21],"동시성","","\u002Fimages\u002Fthumbnails\u002Fdatabase.png",{"slug":56,"title":57,"date":58,"category":45,"tags":59,"excerpt":53,"thumbnail":64},"minimum-practical-knowledge-for-developers","개발자를 위한 최소한의 실무 지식 독서 회고","2026-04-18",[60,61,62,63],"독서","실무지식","성장","커리어","\u002Fimages\u002Fthumbnails\u002Fbooks.png",{"slug":66,"title":67,"date":68,"category":9,"tags":69,"excerpt":53,"thumbnail":74},"spring-architecture","아키텍처 규칙 강제하기(feat MultiModule, ArchUnit, AI Agent)","2026-04-08",[70,36,71,72,73],"Kotlin","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",{"slug":76,"title":77,"date":78,"category":38,"tags":79,"excerpt":53,"thumbnail":84},"spring-security-architecture","[Example] Spring Security 동작 원리, 프로세스 이해하기","2026-03-15",[80,81,82,83],"Spring Security","Authentication","Filter","Java","\u002Fimages\u002Fthumbnails\u002Fsecurity.png",{"slug":86,"title":87,"date":88,"category":36,"tags":89,"excerpt":53,"thumbnail":93},"spring-aop-private-method","[Example] Spring AOP를 private 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[90,91,83,92],"Spring","AOP","Transactional","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[95,166,316,375],{"id":96,"title":97,"body":98,"date":153,"description":104,"extension":154,"meta":155,"navigation":156,"path":157,"seo":158,"stem":159,"tags":160,"__hash__":165},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":99,"value":100,"toc":149},"minimark",[101,105,108,115,118,125,130,133,139,142,146],[102,103,104],"p",{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[102,106,107],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[109,110,111],"ol",{},[112,113,114],"li",{},"JWT 방식",[102,116,117],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[102,119,120],{},[121,122],"img",{"alt":123,"src":124},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[109,126,127],{"start":28},[112,128,129],{},"HMAC (Hash-based Message Authentication Code)",[102,131,132],{},"서버 간에 시크릿 키를 공유한다.\n요청 하는 서버는 요청 정보(Request Body 등)를 시크릿 키를 이용해 해시 기반 서명값(MAC)으로 변환하고, 그 값을 \"헤더에 담아 전송\"한다.\n요청을 받은 서버는 요청 정보(Request Body 등) 을 동일한 시크릿 키로 해시 기반 서명값(MAC)으로 변환하고, \"그 결과가 헤더의 값과 같은지 확인하여 검증\"한다.",[102,134,135],{},[121,136],{"alt":137,"src":138},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[102,140,141],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[143,144,145],"h2",{"id":145},"정리",[102,147,148],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":53,"searchDepth":150,"depth":150,"links":151},3,[152],{"id":145,"depth":28,"text":145},"2026-06-01T20:36:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-01-hmac",{"description":104},"feeds\u002F2026-06-01-hmac",[161,162,163,164],"보안","네트워크","HMAC","JWT","f229CVTvv20IYHmale0GxOtq9gGfj6GwVHokCgATK-g",{"id":167,"title":168,"body":169,"date":307,"description":53,"extension":154,"meta":308,"navigation":156,"path":309,"seo":310,"stem":311,"tags":312,"__hash__":315},"feeds\u002Ffeeds\u002F2026-06-01-referential-transparency.md","2026 06 01 Referential Transparency",{"type":99,"value":170,"toc":305},[171,177,182,219,224,244,249,266,269,272,294,296,299,302],[172,173,174],"blockquote",{},[102,175,176],{},"참조 투명성(Referential Transparency) : 함수형 프로그래밍의 핵심 원칙",[109,178,179],{},[112,180,181],{},"순수성",[183,184,185,206],"ul",{},[112,186,187,188],{},"규칙1. 값을 반환해야 한다.",[183,189,190,198],{},[112,191,192,193],{},"값 반환외에는 부수효과 없도록\n",[183,194,195],{},[112,196,197],{},"부수효과 : 파일 입출력, 데이터 전송,  화면 쓰기",[112,199,200,201],{},"부수효과 없는 순수 애플리케이션이 가능한건가? 당연 불가능\n",[183,202,203],{},[112,204,205],{},"단, 타입 시스템을 사용해서 부수 효과가 발생하는 시점을 명시적으로 표시하고, 명확하게 드러내는 방향으로 가야한다.",[112,207,208,209],{},"규칙 2. 결과가 입력에만 의존해아함.",[183,210,211],{},[112,212,213,214],{},"결과값 계산을 위해 입력(파라미터)외에 다른것을 사용하지 않아야함.\n",[183,215,216],{},[112,217,218],{},"ex) 계산을 위해 전역, 싱글톤, 파일, 네트워크 소켓등 사용 x",[109,220,221],{"start":28},[112,222,223],{},"불변성",[183,225,226,229],{},[112,227,228],{},"불변 데이터 구조를 사용하자.",[112,230,231,232,236],{},"순수함수 + 불변데이터 ⇒ ",[233,234,235],"code",{},"디버깅하고 오류 피하기가 쉬워짐.",[183,237,238,241],{},[112,239,240],{},"함수형 코드를 읽을 때 상태를 신경쓰지 않아도됨.",[112,242,243],{},"결국 상태 변경을 신경쓰며 프로그래밍을 하게될때, 사람은 실수를 하게 된다.(예측 하기 어려운 버그 발생)",[109,245,246],{"start":150},[112,247,248],{},"전체성",[183,250,251],{},[112,252,253,254],{},"모든 입력값에 대해 유한 시간내에 결과 반환하는 함수\n",[183,255,256,259],{},[112,257,258],{},"무한루프를 가지지 말것",[112,260,261,262,265],{},"모든 입력에대한 결과를 반환해라(",[233,263,264],{},"예외 보다는 결과값을 반환할 것",")",[267,268],"br",{},[102,270,271],{},"객체 인스턴스 생성의 메모리 CPU 사용량?",[183,273,274,277,280],{},[112,275,276],{},"JVM 객체 생성 비용이 그렇게 높지 않음",[112,278,279],{},"불변 객체를 사용하면 JIT 컴파일러와 가비지 컬렉터가 효율적으로 동작할 확률이 높음.",[112,281,282,283,286,287,286,290,293],{},"즉, 약간의 객체 생성 비용보다, ",[233,284,285],{},"예측 가능성",", ",[233,288,289],{},"테스트 용이성",[233,291,292],{},"동시성 안정성"," 등을 우선으로 봄",[267,295],{},[102,297,298],{},"결국 함수형 프로그래밍은\n\"코드를 더 똑똑하게 작성하는 방법\"이라기보다,",[102,300,301],{},"\"예측 가능한 시스템을 만드는 방법\", \"디버깅을 쉽게하고, 상태에 따른 예측하기 어려운 버그 가능성을 줄이는 방법.\"",[102,303,304],{},"에 가까운 것 같다.",{"title":53,"searchDepth":150,"depth":150,"links":306},[],"2026-06-01T04:07:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-referential-transparency",{"description":53},"feeds\u002F2026-06-01-referential-transparency",[313,314],"FP","참조 투명성","_nS-0fooYQq5yg3NLwUQLQQa1TyGJ6c6nAshLDTwBfY",{"id":317,"title":318,"body":319,"date":367,"description":323,"extension":154,"meta":368,"navigation":156,"path":369,"seo":370,"stem":371,"tags":372,"__hash__":374},"feeds\u002Ffeeds\u002F2026-05-31-oop-fp.md","2026 05 31 Oop Fp",{"type":99,"value":320,"toc":365},[321,324,327,335,338,359,362],[102,322,323],{},"기존에 나는 읽기 쉽고, 확장성이 좋고, 협업하기 좋은 코드를 작성하기 위해 OOP와 FP를 활용했다.",[102,325,326],{},"하지만 이제는 AI가 코드를 작성하는 시대다.\nAI가 코드를 작성하게 되면서 부터는 문득 이런 생각이 들었다.",[172,328,329],{},[102,330,331,332,334],{},"\"객체지향(OOP), 함수형 프로그래밍(FP)을 계속 공부하는 것이 여전히 의미가 있을까?\"",[267,333],{},"\n\"개발자의 역할이 구현보다 테스트와 검증에 가까워지고 있다면, OOP와 FP는 어떤 가치를 가질까?\"",[102,336,337],{},"내가 생각하는 핵심은 다음과 같다.",[183,339,340,348],{},[112,341,342,343],{},"객체지향 프로그래밍(OOP)\n",[183,344,345],{},[112,346,347],{},"책임과 경계를 정의한다.",[112,349,350,351],{},"함수형 프로그래밍(FP)\n",[183,352,353,356],{},[112,354,355],{},"예측 가능성을 높인다.",[112,357,358],{},"부수효과(Side Effect)를 최소화한다.",[102,360,361],{},"누군가는 AI 개발을 지휘해야하고, 능숙하게 시스템을 파악하여 AI 에게 또다시 프롬프트를 전달해야한다.\n그렇기 때문에 어떤 책임을 어디에 둘지,\n어떤 상태 변경을 허용할지,\n무엇을 검증해야 하는지는 여전히 사람이 결정하는게 좋다고 생각한다.",[102,363,364],{},"앞으로는 협업과 확장성뿐 아니라,\nAI Agent 개발 관점에서 설계 → 테스트 → 검증까지의 흐름 속에서\n객체지향과 함수형이 어떤 이점을 주는지 직접 실험해보고 기록해보려 한다.",{"title":53,"searchDepth":150,"depth":150,"links":366},[],"2026-05-31T23:50:00+09:00",{},"\u002Ffeeds\u002F2026-05-31-oop-fp",{"description":323},"feeds\u002F2026-05-31-oop-fp",[373,313,73],"OOP","N9SjZzLRCfBFEcIvGVaOj6-Girq0VI3AybXYfO-Zn2M",{"id":376,"title":377,"body":378,"date":367,"description":382,"extension":154,"meta":403,"navigation":156,"path":404,"seo":405,"stem":406,"tags":407,"__hash__":410},"feeds\u002Ffeeds\u002F2026-05-31-readable-code.md","2026 05 31 Readable Code",{"type":99,"value":379,"toc":401},[380,383,386,389,392,395,398],[102,381,382],{},"AI 덕분에 코드 생산량은 훨씬 빨라졌다.",[102,384,385],{},"평소 확장성을 고려해 설계하는 것을 좋아했는데,\n반복 구현이나 노가다에 가까운 테스트 코드 작성이 많이 줄어든 것 같아 좋다.",[102,387,388],{},"그래도 결국 버그가 발생하면 사람이 코드를 읽고 이해해야 하는 순간이 온다.\n그렇다면 이왕이면 사람도 읽기 쉽게 설계하고 구현하는 것이 좋지 않을까?",[102,390,391],{},"AI에게 좋은 프롬프트를 주기 위해서도,\n읽기 쉽고 확장 가능한 코드를 유지하기 위해서도,\n개발자는 여전히 설계와 코드 품질을 고민해야 한다.",[102,393,394],{},"내가 이해하지 못하는 시스템을 AI에게 제대로 설명할 수는 없다.",[102,396,397],{},"어셈블리어가 아닌 고수준 언어를 사용하는 이상,\nAI 시대에도 좋은 코드의 기준은 크게 달라지지 않은 것 같다.",[102,399,400],{},"오히려 더 중요해졌을지도.",{"title":53,"searchDepth":150,"depth":150,"links":402},[],{},"\u002Ffeeds\u002F2026-05-31-readable-code",{"description":382},"feeds\u002F2026-05-31-readable-code",[408,409],"readable-code","유지보수","ITbkErFtzBmXv3ZiNmq5v23IRF4f_nW9ab0ikxuW9Bc",1780323598791]