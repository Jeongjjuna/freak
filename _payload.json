 수 없는 이유 (feat. @Transactional)","2026-02-07",[90,91,83,92],"Spring","AOP","Transactional","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[95,214,303,385,482,732,793,938,997],{"id":96,"title":97,"body":98,"date":200,"description":53,"extension":201,"meta":202,"navigation":203,"path":204,"seo":205,"stem":206,"tags":207,"__hash__":213},"feeds\u002Ffeeds\u002F2026-06-03-signature.md","2026 06 03 Signature",{"type":99,"value":100,"toc":191},"minimark",[101,106,113,118,134,147,154,164,167,171,174,177,180,183,186],[102,103,105],"h2",{"id":104},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[107,108,109],"blockquote",{},[110,111,112],"p",{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[114,115,117],"h3",{"id":116},"실무에서-만나는-곳","실무에서 만나는 곳",[119,120,121,125,128,131],"ul",{},[122,123,124],"li",{},"JWT 서명 (HS256, RS256)",[122,126,127],{},"웹훅 검증 (Stripe, GitHub 등)",[122,129,130],{},"서버 간 API 인증",[122,132,133],{},"AWS SigV4 요청 서명",[114,135,137,138,142,143,146],{"id":136},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[139,140,141],"code",{},"누가 보냈는지","와 ",[139,144,145],{},"내용이 안 바뀌었는지","를 증명한다",[110,148,149,150,153],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[139,151,152],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[110,155,156,157,160,161,163],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[139,158,159],{},"인증","), 중간에 변조되지 않았다(",[139,162,152],{},")\"를 증명한다.",[110,165,166],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[114,168,170],{"id":169},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[110,172,173],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[110,175,176],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[110,178,179],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[181,182],"br",{},[110,184,185],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[107,187,188],{},[110,189,190],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":53,"searchDepth":192,"depth":192,"links":193},3,[194],{"id":104,"depth":28,"text":105,"children":195},[196,197,199],{"id":116,"depth":192,"text":117},{"id":136,"depth":192,"text":198},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":169,"depth":192,"text":170},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":53},"feeds\u002F2026-06-03-signature",[208,209,210,211,212],"보안","백엔드","서명","HMAC","JWT","daCzdI8pZQRjnS280-A0_pWA--NQ7kXLUxftQzuK1jU",{"id":215,"title":216,"body":217,"date":294,"description":53,"extension":201,"meta":295,"navigation":203,"path":296,"seo":297,"stem":298,"tags":299,"__hash__":302},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":99,"value":218,"toc":287},[219,223,228,230,244,248,251,254,257,261,264,267,270,273,275,282],[102,220,222],{"id":221},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[107,224,225],{},[110,226,227],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[114,229,117],{"id":116},[119,231,232,235,238,241],{},[122,233,234],{},"비밀번호 저장",[122,236,237],{},"파일 무결성 검증",[122,239,240],{},"캐시 키 생성",[122,242,243],{},"Git 커밋 식별자",[114,245,247],{"id":246},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[110,249,250],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[110,252,253],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[110,255,256],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[114,258,260],{"id":259},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[110,262,263],{},"SHA-256은 매우 빠른 알고리즘이다.",[110,265,266],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[110,268,269],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[110,271,272],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[181,274],{},[110,276,277,278,281],{},"대표 알고리즘: SHA-256·SHA-512(",[139,279,280],{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[107,283,284],{},[110,285,286],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":53,"searchDepth":192,"depth":192,"links":288},[289],{"id":221,"depth":28,"text":222,"children":290},[291,292,293],{"id":116,"depth":192,"text":117},{"id":246,"depth":192,"text":247},{"id":259,"depth":192,"text":260},"2026-06-03T15:30:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-hash",{"description":53},"feeds\u002F2026-06-03-hash",[208,300,301],"암호기초","해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":304,"title":305,"body":306,"date":377,"description":53,"extension":201,"meta":378,"navigation":203,"path":379,"seo":380,"stem":381,"tags":382,"__hash__":384},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":99,"value":307,"toc":370},[308,312,317,319,330,334,337,347,353,357,360,362,365],[102,309,311],{"id":310},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[107,313,314],{},[110,315,316],{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[114,318,117],{"id":116},[119,320,321,324,327],{},[122,322,323],{},"전송 구간 암호화: HTTPS\u002FTLS",[122,325,326],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[122,328,329],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[114,331,333],{"id":332},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[110,335,336],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[119,338,339,342],{},[122,340,341],{},"필요하다 → 암호화",[122,343,344,345],{},"필요하지 않다 → ",[139,346,301],{},[110,348,349,350,352],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[139,351,301],{},"를 사용한다.(다음편)",[114,354,356],{"id":355},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[110,358,359],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[181,361],{},[110,363,364],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[107,366,367],{},[110,368,369],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":53,"searchDepth":192,"depth":192,"links":371},[372],{"id":310,"depth":28,"text":311,"children":373},[374,375,376],{"id":116,"depth":192,"text":117},{"id":332,"depth":192,"text":333},{"id":355,"depth":192,"text":356},"2026-06-03T15:20:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encryption",{"description":53},"feeds\u002F2026-06-03-encryption",[208,300,383],"암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":386,"title":387,"body":388,"date":473,"description":53,"extension":201,"meta":474,"navigation":203,"path":475,"seo":476,"stem":477,"tags":478,"__hash__":481},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":99,"value":389,"toc":465},[390,394,399,401,423,427,430,433,437,448,452,455,457,460],[102,391,393],{"id":392},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[107,395,396],{},[110,397,398],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[114,400,117],{"id":116},[119,402,403,414,417,420],{},[122,404,405,406,409,410,413],{},"JWT의 ",[139,407,408],{},"header",", ",[139,411,412],{},"payload"," (Base64URL)",[122,415,416],{},"URL의 한글·특수문자 (Percent-Encoding)",[122,418,419],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[122,421,422],{},"바이너리를 로그·DB에 저장할 때",[114,424,426],{"id":425},"왜-사용할까","왜 사용할까?",[110,428,429],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[110,431,432],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[114,434,436],{"id":435},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[110,438,405,439,142,441,443,444,447],{},[139,440,408],{},[139,442,412],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[139,445,446],{},"서명(Signature)"," 에서 나온다.",[114,449,451],{"id":450},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[110,453,454],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[181,456],{},[110,458,459],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[107,461,462],{},[110,463,464],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":53,"searchDepth":192,"depth":192,"links":466},[467],{"id":392,"depth":28,"text":393,"children":468},[469,470,471,472],{"id":116,"depth":192,"text":117},{"id":425,"depth":192,"text":426},{"id":435,"depth":192,"text":436},{"id":450,"depth":192,"text":451},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":53},"feeds\u002F2026-06-03-encoding",[208,209,479,480,212],"인코딩","Base64","Sq2598RzaFZXqN7EZqu85x2WRdigojLrlU9euESHMOQ",{"id":483,"title":484,"body":485,"date":725,"description":53,"extension":201,"meta":726,"navigation":203,"path":727,"seo":728,"stem":729,"tags":730,"__hash__":731},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":99,"value":486,"toc":715},[487,491,494,601,605,610,621,625,636,639,650,653,658,661,665,680,683,691,694,698],[114,488,490],{"id":489},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[110,492,493],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[495,496,497,519],"table",{},[498,499,500],"thead",{},[501,502,503,507,510,513,516],"tr",{},[504,505,506],"th",{},"구분",[504,508,509],{},"목적",[504,511,512],{},"방향성",[504,514,515],{},"키",[504,517,518],{},"대표 알고리즘",[520,521,522,546,565,583],"tbody",{},[501,523,524,530,537,540,543],{},[525,526,527],"td",{},[139,528,529],{},"인코딩 (Encoding)",[525,531,532,533],{},"형식 변환 ",[534,535,536],"em",{},"(보안 아님)",[525,538,539],{},"양방향 (키 불필요)",[525,541,542],{},"x",[525,544,545],{},"Base64, Base64URL, Hex",[501,547,548,553,556,559,562],{},[525,549,550],{},[139,551,552],{},"양방향 암호화 (Encryption)",[525,554,555],{},"기밀성 — 내용 숨기기",[525,557,558],{},"양방향 (복호화 가능)",[525,560,561],{},"o",[525,563,564],{},"AES(대칭키), RSA(비대칭키)",[501,566,567,572,575,578,580],{},[525,568,569],{},[139,570,571],{},"해시 (Hash)",[525,573,574],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[525,576,577],{},"단방향 (복원 불가)",[525,579,542],{},[525,581,582],{},"SHA-256, SHA-512, SHA-3",[501,584,585,590,593,596,598],{},[525,586,587],{},[139,588,589],{},"서명 (Signature)",[525,591,592],{},"무결성 + 인증 — 위변조 + 출처",[525,594,595],{},"단방향 (해시 기반)",[525,597,561],{},[525,599,600],{},"HMAC-SHA256(HS256), RS256, ES256",[114,602,604],{"id":603},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[606,607,609],"h4",{"id":608},"인코딩-암호화","인코딩 ≠ 암호화",[119,611,612,615,618],{},[122,613,614],{},"Base64는 키가 없다.",[122,616,617],{},"누구나 디코딩할 수 있다.",[122,619,620],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[606,622,624],{"id":623},"해시-서명","해시 ≠ 서명",[119,626,627,630,633],{},[122,628,629],{},"해시는 데이터의 지문을 생성한다.",[122,631,632],{},"같은 입력은 항상 같은 해시값을 만든다.",[122,634,635],{},"데이터가 변경되면 해시값도 달라진다.",[110,637,638],{},"반면 서명은",[119,640,641,644,647],{},[122,642,643],{},"해시에 키를 결합하여 생성한다.",[122,645,646],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[122,648,649],{},"누가 생성했는지까지 검증할 수 있다.",[110,651,652],{},"즉,",[107,654,655],{},[110,656,657],{},"서명(Signature) = 해시(Hash) + 키(Key)",[110,659,660],{},"라고 생각하면 이해하기 쉽다.",[606,662,664],{"id":663},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[110,666,405,667,670,671,674,675,679],{},[139,668,669],{},"HS256","은 ",[139,672,673],{},"HMAC-SHA256","을 사용하는 ",[676,677,678],"strong",{},"서명 알고리즘","이다.",[110,681,682],{},"토큰 내용을 숨기는 것이 아니라,",[119,684,685,688],{},[122,686,687],{},"토큰이 위조되지 않았는지",[122,689,690],{},"신뢰할 수 있는 발급자가 만들었는지",[110,692,693],{},"를 검증하기 위해 사용된다.",[114,695,697],{"id":696},"한-줄-요약","한 줄 요약",[107,699,700],{},[110,701,702,703,705,706,708,709,711,712,714],{},"형식만 바꾸면 ",[676,704,479],{},", 숨기면 ",[676,707,383],{},", 지문(위\u002F변조검사) 찍으면 ",[676,710,301],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[676,713,210],{},".",{"title":53,"searchDepth":192,"depth":192,"links":716},[717,718,724],{"id":489,"depth":192,"text":490},{"id":603,"depth":192,"text":604,"children":719},[720,722,723],{"id":608,"depth":721,"text":609},4,{"id":623,"depth":721,"text":624},{"id":663,"depth":721,"text":664},{"id":696,"depth":192,"text":697},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":53},"feeds\u002F2026-06-03-crypto-basics",[208,479,383,301,210],"DiJZVjRCgtWgXEW1t3eXSnpdeyUQmyB_r7uG-8JAGfk",{"id":733,"title":734,"body":735,"date":785,"description":739,"extension":201,"meta":786,"navigation":203,"path":787,"seo":788,"stem":789,"tags":790,"__hash__":792},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":99,"value":736,"toc":782},[737,740,743,749,752,759,764,767,773,776,779],[110,738,739],{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[110,741,742],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[744,745,746],"ol",{},[122,747,748],{},"JWT 방식",[110,750,751],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[110,753,754],{},[755,756],"img",{"alt":757,"src":758},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[744,760,761],{"start":28},[122,762,763],{},"HMAC (Hash-based Message Authentication Code)",[110,765,766],{},"서버 간에 시크릿 키를 공유한다.\n요청 하는 서버는 요청 정보(Request Body 등)를 시크릿 키를 이용해 해시 기반 서명값(MAC)으로 변환하고, 그 값을 \"헤더에 담아 전송\"한다.\n요청을 받은 서버는 요청 정보(Request Body 등) 을 동일한 시크릿 키로 해시 기반 서명값(MAC)으로 변환하고, \"그 결과가 헤더의 값과 같은지 확인하여 검증\"한다.",[110,768,769],{},[755,770],{"alt":771,"src":772},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[110,774,775],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[102,777,778],{"id":778},"정리",[110,780,781],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":53,"searchDepth":192,"depth":192,"links":783},[784],{"id":778,"depth":28,"text":778},"2026-06-01T20:36:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-hmac",{"description":739},"feeds\u002F2026-06-01-hmac",[208,791,211,212],"네트워크","f229CVTvv20IYHmale0GxOtq9gGfj6GwVHokCgATK-g",{"id":794,"title":795,"body":796,"date":929,"description":53,"extension":201,"meta":930,"navigation":203,"path":931,"seo":932,"stem":933,"tags":934,"__hash__":937},"feeds\u002Ffeeds\u002F2026-06-01-referential-transparency.md","2026 06 01 Referential Transparency",{"type":99,"value":797,"toc":927},[798,803,808,844,849,868,873,890,892,895,916,918,921,924],[107,799,800],{},[110,801,802],{},"참조 투명성(Referential Transparency) : 함수형 프로그래밍의 핵심 원칙",[744,804,805],{},[122,806,807],{},"순수성",[119,809,810,831],{},[122,811,812,813],{},"규칙1. 값을 반환해야 한다.",[119,814,815,823],{},[122,816,817,818],{},"값 반환외에는 부수효과 없도록\n",[119,819,820],{},[122,821,822],{},"부수효과 : 파일 입출력, 데이터 전송,  화면 쓰기",[122,824,825,826],{},"부수효과 없는 순수 애플리케이션이 가능한건가? 당연 불가능\n",[119,827,828],{},[122,829,830],{},"단, 타입 시스템을 사용해서 부수 효과가 발생하는 시점을 명시적으로 표시하고, 명확하게 드러내는 방향으로 가야한다.",[122,832,833,834],{},"규칙 2. 결과가 입력에만 의존해아함.",[119,835,836],{},[122,837,838,839],{},"결과값 계산을 위해 입력(파라미터)외에 다른것을 사용하지 않아야함.\n",[119,840,841],{},[122,842,843],{},"ex) 계산을 위해 전역, 싱글톤, 파일, 네트워크 소켓등 사용 x",[744,845,846],{"start":28},[122,847,848],{},"불변성",[119,850,851,854],{},[122,852,853],{},"불변 데이터 구조를 사용하자.",[122,855,856,857,860],{},"순수함수 + 불변데이터 ⇒ ",[139,858,859],{},"디버깅하고 오류 피하기가 쉬워짐.",[119,861,862,865],{},[122,863,864],{},"함수형 코드를 읽을 때 상태를 신경쓰지 않아도됨.",[122,866,867],{},"결국 상태 변경을 신경쓰며 프로그래밍을 하게될때, 사람은 실수를 하게 된다.(예측 하기 어려운 버그 발생)",[744,869,870],{"start":192},[122,871,872],{},"전체성",[119,874,875],{},[122,876,877,878],{},"모든 입력값에 대해 유한 시간내에 결과 반환하는 함수\n",[119,879,880,883],{},[122,881,882],{},"무한루프를 가지지 말것",[122,884,885,886,889],{},"모든 입력에대한 결과를 반환해라(",[139,887,888],{},"예외 보다는 결과값을 반환할 것",")",[181,891],{},[110,893,894],{},"객체 인스턴스 생성의 메모리 CPU 사용량?",[119,896,897,900,903],{},[122,898,899],{},"JVM 객체 생성 비용이 그렇게 높지 않음",[122,901,902],{},"불변 객체를 사용하면 JIT 컴파일러와 가비지 컬렉터가 효율적으로 동작할 확률이 높음.",[122,904,905,906,409,909,409,912,915],{},"즉, 약간의 객체 생성 비용보다, ",[139,907,908],{},"예측 가능성",[139,910,911],{},"테스트 용이성",[139,913,914],{},"동시성 안정성"," 등을 우선으로 봄",[181,917],{},[110,919,920],{},"결국 함수형 프로그래밍은\n\"코드를 더 똑똑하게 작성하는 방법\"이라기보다,",[110,922,923],{},"\"예측 가능한 시스템을 만드는 방법\", \"디버깅을 쉽게하고, 상태에 따른 예측하기 어려운 버그 가능성을 줄이는 방법.\"",[110,925,926],{},"에 가까운 것 같다.",{"title":53,"searchDepth":192,"depth":192,"links":928},[],"2026-06-01T04:07:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-referential-transparency",{"description":53},"feeds\u002F2026-06-01-referential-transparency",[935,936],"FP","참조 투명성","_nS-0fooYQq5yg3NLwUQLQQa1TyGJ6c6nAshLDTwBfY",{"id":939,"title":940,"body":941,"date":989,"description":945,"extension":201,"meta":990,"navigation":203,"path":991,"seo":992,"stem":993,"tags":994,"__hash__":996},"feeds\u002Ffeeds\u002F2026-05-31-oop-fp.md","2026 05 31 Oop Fp",{"type":99,"value":942,"toc":987},[943,946,949,957,960,981,984],[110,944,945],{},"기존에 나는 읽기 쉽고, 확장성이 좋고, 협업하기 좋은 코드를 작성하기 위해 OOP와 FP를 활용했다.",[110,947,948],{},"하지만 이제는 AI가 코드를 작성하는 시대다.\nAI가 코드를 작성하게 되면서 부터는 문득 이런 생각이 들었다.",[107,950,951],{},[110,952,953,954,956],{},"\"객체지향(OOP), 함수형 프로그래밍(FP)을 계속 공부하는 것이 여전히 의미가 있을까?\"",[181,955],{},"\n\"개발자의 역할이 구현보다 테스트와 검증에 가까워지고 있다면, OOP와 FP는 어떤 가치를 가질까?\"",[110,958,959],{},"내가 생각하는 핵심은 다음과 같다.",[119,961,962,970],{},[122,963,964,965],{},"객체지향 프로그래밍(OOP)\n",[119,966,967],{},[122,968,969],{},"책임과 경계를 정의한다.",[122,971,972,973],{},"함수형 프로그래밍(FP)\n",[119,974,975,978],{},[122,976,977],{},"예측 가능성을 높인다.",[122,979,980],{},"부수효과(Side Effect)를 최소화한다.",[110,982,983],{},"누군가는 AI 개발을 지휘해야하고, 능숙하게 시스템을 파악하여 AI 에게 또다시 프롬프트를 전달해야한다.\n그렇기 때문에 어떤 책임을 어디에 둘지,\n어떤 상태 변경을 허용할지,\n무엇을 검증해야 하는지는 여전히 사람이 결정하는게 좋다고 생각한다.",[110,985,986],{},"앞으로는 협업과 확장성뿐 아니라,\nAI Agent 개발 관점에서 설계 → 테스트 → 검증까지의 흐름 속에서\n객체지향과 함수형이 어떤 이점을 주는지 직접 실험해보고 기록해보려 한다.",{"title":53,"searchDepth":192,"depth":192,"links":988},[],"2026-05-31T23:50:00+09:00",{},"\u002Ffeeds\u002F2026-05-31-oop-fp",{"description":945},"feeds\u002F2026-05-31-oop-fp",[995,935,73],"OOP","N9SjZzLRCfBFEcIvGVaOj6-Girq0VI3AybXYfO-Zn2M",{"id":998,"title":999,"body":1000,"date":989,"description":1004,"extension":201,"meta":1025,"navigation":203,"path":1026,"seo":1027,"stem":1028,"tags":1029,"__hash__":1032},"feeds\u002Ffeeds\u002F2026-05-31-readable-code.md","2026 05 31 Readable Code",{"type":99,"value":1001,"toc":1023},[1002,1005,1008,1011,1014,1017,1020],[110,1003,1004],{},"AI 덕분에 코드 생산량은 훨씬 빨라졌다.",[110,1006,1007],{},"평소 확장성을 고려해 설계하는 것을 좋아했는데,\n반복 구현이나 노가다에 가까운 테스트 코드 작성이 많이 줄어든 것 같아 좋다.",[110,1009,1010],{},"그래도 결국 버그가 발생하면 사람이 코드를 읽고 이해해야 하는 순간이 온다.\n그렇다면 이왕이면 사람도 읽기 쉽게 설계하고 구현하는 것이 좋지 않을까?",[110,1012,1013],{},"AI에게 좋은 프롬프트를 주기 위해서도,\n읽기 쉽고 확장 가능한 코드를 유지하기 위해서도,\n개발자는 여전히 설계와 코드 품질을 고민해야 한다.",[110,1015,1016],{},"내가 이해하지 못하는 시스템을 AI에게 제대로 설명할 수는 없다.",[110,1018,1019],{},"어셈블리어가 아닌 고수준 언어를 사용하는 이상,\nAI 시대에도 좋은 코드의 기준은 크게 달라지지 않은 것 같다.",[110,1021,1022],{},"오히려 더 중요해졌을지도.",{"title":53,"searchDepth":192,"depth":192,"links":1024},[],{},"\u002Ffeeds\u002F2026-05-31-readable-code",{"description":1004},"feeds\u002F2026-05-31-readable-code",[1030,1031],"readable-code","유지보수","ITbkErFtzBmXv3ZiNmq5v23IRF4f_nW9ab0ikxuW9Bc",1780519122719]