ss":181,"line":28},[179,188,189],{},"GET \u002Fapi\u002Fdata\n",[179,191,193],{"class":181,"line":192},3,[179,194,195],{},"Origin: https:\u002F\u002Fmy-site.com\n",[179,197,199],{"class":181,"line":198},4,[179,200,202],{"emptyLinePlaceholder":201},true,"\n",[179,204,206],{"class":181,"line":205},5,[179,207,208],{},"# 응답 (서버 → 브라우저)\n",[179,210,212],{"class":181,"line":211},6,[179,213,214],{},"Access-Control-Allow-Origin: https:\u002F\u002Fmy-site.com\n",[111,216,217,218,220,221,224,225,228,229,232,233,235],{},"서버는 ",[114,219,168],{},"을 읽고 → 허용 목록에 있으면 → 그 값을 그대로 ",[114,222,223],{},"Allow-Origin","에 담아 되돌림(",[114,226,227],{},"에코",").\n",[114,230,231],{},"*"," 대신 에코하는 이유: 자격증명 요청은 ",[114,234,231],{}," 불가 + 여러 출처 허용 시 목록 검사 후 반사해야 하므로.",[106,237,239],{"id":238},"주요-응답-헤더","주요 응답 헤더",[171,241,243],{"className":173,"code":242,"language":175,"meta":54,"style":54},"Access-Control-Allow-Origin: https:\u002F\u002Fmy-site.com\nAccess-Control-Allow-Methods: GET, POST\nAccess-Control-Allow-Headers: Content-Type\nAccess-Control-Allow-Credentials: true   # 쿠키 등 자격증명 허용\n",[114,244,245,249,254,259],{"__ignoreMap":54},[179,246,247],{"class":181,"line":10},[179,248,214],{},[179,250,251],{"class":181,"line":28},[179,252,253],{},"Access-Control-Allow-Methods: GET, POST\n",[179,255,256],{"class":181,"line":192},[179,257,258],{},"Access-Control-Allow-Headers: Content-Type\n",[179,260,261],{"class":181,"line":198},[179,262,263],{},"Access-Control-Allow-Credentials: true   # 쿠키 등 자격증명 허용\n",[106,265,267],{"id":266},"preflight-사전-요청","Preflight (사전 요청)",[111,269,270,271,274],{},"GET\u002FPOST(단순) 외(예: PUT\u002FDELETE, 커스텀 헤더)면 본 요청 전에 ",[114,272,273],{},"OPTIONS","로 미리 물어봄 → 서버가 허용 헤더로 응답해야 본 요청 진행.",[106,276,278],{"id":277},"흔한-오해","흔한 오해",[123,280,281,287,297],{},[126,282,283,286],{},[114,284,285],{},"차단하는 건 브라우저",", 서버 아님. 요청은 서버에 이미 도달했을 수도 있음.",[126,288,289,292,293,296],{},[114,290,291],{},"credentials: true","면 ",[114,294,295],{},"Allow-Origin: *"," 불가 → 정확한 출처 명시 필요.",[126,298,299,3