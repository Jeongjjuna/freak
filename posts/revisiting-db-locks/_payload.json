[{"data":1,"prerenderedAt":922},["ShallowReactive",2],{"layout-data":3,"post-revisiting-db-locks":93,"related-MySQL":913},{"groups":4,"recentPosts":46},[5,11,41],{"name":6,"categories":7},"Engineering",[8],{"name":9,"count":10},"Architecture",1,{"name":12,"categories":13},"Learning",[14,16,18,20,22,24,26,29,31,33,35,37,39],{"name":15,"count":10},"API",{"name":17,"count":10},"Docker",{"name":19,"count":10},"Git",{"name":21,"count":10},"JPA",{"name":23,"count":10},"Kafka",{"name":25,"count":10},"Kubernetes",{"name":27,"count":28},"MySQL",2,{"name":30,"count":10},"RabbitMQ",{"name":32,"count":10},"Redis",{"name":34,"count":10},"Security",{"name":36,"count":28},"SpringBoot",{"name":38,"count":10},"SpringSecurity",{"name":40,"count":10},"Testing",{"name":42,"categories":43},"Archive",[44],{"name":45,"count":10},"Books",[47,56,64,75,85],{"slug":48,"title":49,"date":50,"category":27,"tags":51,"excerpt":54,"thumbnail":55},"revisiting-db-locks","초심 찾기! 동시성 처리를 위한 DB Lock 다시 한번 복습해보자","2026-04-30",[27,52,21,53],"동시성","데이터베이스","","\u002Fimages\u002Fthumbnails\u002Fdatabase.png",{"slug":57,"title":58,"date":59,"category":45,"tags":60,"excerpt":54,"thumbnail":63},"minimum-practical-knowledge-for-developers","개발자를 위한 최소한의 실무 지식 독서 회고","2026-04-18",[61,62],"독서","커리어","\u002Fimages\u002Fthumbnails\u002Fbooks.png",{"slug":65,"title":66,"date":67,"category":9,"tags":68,"excerpt":54,"thumbnail":74},"spring-architecture","아키텍처 규칙 강제하기(feat MultiModule, ArchUnit, AI Agent)","2026-04-08",[69,70,71,72,73],"Kotlin","Spring","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",{"slug":76,"title":77,"date":78,"category":38,"tags":79,"excerpt":54,"thumbnail":84},"spring-security-architecture","[Example] Spring Security 동작 원리, 프로세스 이해하기","2026-03-15",[80,81,70,82,83],"Spring Security","인증","보안","Java","\u002Fimages\u002Fthumbnails\u002Fsecurity.png",{"slug":86,"title":87,"date":88,"category":36,"tags":89,"excerpt":54,"thumbnail":92},"spring-aop-private-method","[Example] Spring AOP를 private 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[70,90,83,91],"AOP","Transaction","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",{"id":94,"title":49,"body":95,"category":27,"date":50,"description":54,"excerpt":54,"extension":905,"meta":906,"navigation":331,"path":907,"seo":908,"stem":909,"tags":910,"thumbnail":911,"__hash__":912},"posts\u002Fposts\u002Frevisiting-db-locks.md",{"type":96,"value":97,"toc":885},"minimark",[98,102,106,109,128,131,134,137,152,155,159,162,165,168,171,175,178,189,192,195,206,209,223,231,235,242,258,261,264,275,282,285,290,297,317,351,354,357,391,394,418,421,424,427,430,433,437,487,495,499,502,547,550,554,561,564,573,579,585,589,592,601,607,610,613,619,623,630,636,639,643,660,671,674,678,703,706,717,720,728,732,738,744,748,759,788,796,799,802,822,825,835,845,848,868,874,881],[99,100,101],"h2",{"id":101},"들어가며",[103,104,105],"p",{},"프로젝트를 진행하다 보면 동시성 문제를 마주하게 됩니다.\n실제로 장애가 발생하지 않더라도, 기능을 구현하는 과정에서 정합성 문제가 발생할 가능성은 없는지 한 번쯤 점검하게 되는데요,",[103,107,108],{},"저는 동시성 이슈를 검토할 때 보통 아래와 같은 단계적인 순서로 해결 방법을 고민합니다.",[110,111,112,116,119,122,125],"ol",{},[113,114,115],"li",{},"동시성 자체를 줄이거나 제거하는 설계\n↓",[113,117,118],{},"DB 제약 조건 활용 (Unique Key 등)\n↓",[113,120,121],{},"DB Lock (비관적 락, 낙관적 락)\n↓",[113,123,124],{},"비동기 순차 처리 (Queue 기반)\n↓",[113,126,127],{},"분산 락 (Redis, Zookeeper 등)",[103,129,130],{},"하지만 실무에서는 구현의 편의성이나 빠른 개발에 집중한 나머지, 충분한 고민 없이 비교적 적용하기 쉬운 'Lock'을 먼저 선택하는 경우를 종종 보게 됩니다.",[103,132,133],{},"물론 Lock은 강력한 해결 수단이지만, 도입에 따른 데드락(Deadlock) 등 여러 장애 상황을 고려해야 하고,\n특히 Redis 같은 도구를 활용한 '분산 락'의 경우 Lock 해제 실패 대응이나 운영 및 구현 복잡도까지 함께 짊어져야 합니다.\n결국 시스템의 복잡도를 증가시키는 선택이 될 수 있죠.",[103,135,136],{},"따라서 기술을 선택할 때는 \"어떤 기술을 쓰느냐\"보다 \"왜 이 기술이어야만 하는가\"에 대한 답을 내릴 수 있어야 합니다.\n그래서 저는 Lock이 필요 없는 설계가 가능한지 먼저 깊게 고민한 뒤, 아래의 기준들을 바탕으로 적절한 트레이드오프(Trade-off)를 고려해 구현 방향을 결정합니다.",[138,139,140,143,146,149],"ul",{},[113,141,142],{},"성능 및 비용",[113,144,145],{},"비즈니스\u002F서비스 정책",[113,147,148],{},"구현 복잡도",[113,150,151],{},"유지보수성과 협업 난이도",[103,153,154],{},"사람마다 우선시하는 기준은 다르겠지만, 적적한 기준을 가지고 문제에 접근하는 것이 중요하다고 생각합니다.",[99,156,158],{"id":157},"ai-agent-시대-개발자에게-진짜-필요한-능력","AI Agent 시대, 개발자에게 진짜 필요한 능력",[103,160,161],{},"최근 AI Agent 기반의 개발 환경을 경험하면서, 앞서 언급한 기준과 판단력의 중요성을 더욱 크게 체감하고 있습니다.",[103,163,164],{},"이전에는 코드를 직접 작성하는 구현 능력이 핵심이었다면, 지금은 AI에게 의도와 설계를 정확히 전달하고,\n생성된 결과물이 올바르게 동작하는지 빠르게 판단·검증하는 능력이 더 중요해지고 있습니다.",[103,166,167],{},"AI는 순식간에 코드를 만들어 주지만, 그 코드가 올바른 동시성 모델을 따르고 있는지, 실제 운영 환경에서도 안전하게 동작할지는 결국 개발자의 책임입니다.\n많이 알고 있을수록 더 잘 검증할 수 있고, 개념에 대한 깊은 이해도가 곧 개발자의 판단력이 되는 시대가 온 것입니다.",[103,169,170],{},"돌아보면 한 번 완벽히 이해했다고 생각했던 개념도 시간이 흐르거나 개발 환경이 바뀌면 다시 정리가 필요하곤 합니다.\n그래서 이번 글에서는 초심으로 돌아가, 동시성 해결의 핵심 축인 DB Lock의 동작 방식과 선택 기준을 다시 복습해보려 합니다.\n간단하게 실습을 해보고, 실제 상황에서 어떤 기준으로 기술을 선택해야 하는지 복습해보는 시간을 가지고자합니다.",[99,172,174],{"id":173},"동시성-문제","동시성 문제",[103,176,177],{},"대부분의 서비스는 평소엔 문제 없이 동작하지만,\n트래픽이 몰리는 순간 이런 문제가 드러납니다.",[138,179,180,183,186],{},[113,181,182],{},"Lost Update",[113,184,185],{},"Race Condition",[113,187,188],{},"데이터 불일치",[103,190,191],{},"그래서 기능을 개발할 때는 항상\n\"이 로직에서 동시성 문제가 발생할 수 있는가?\"를 함께 고민하게 됩니다.",[103,193,194],{},"예를 들어 다음과 같은 질문들을 스스로 던지게 됩니다.",[138,196,197,200,203],{},[113,198,199],{},"정합성이 반드시 보장되어야 하는가?",[113,201,202],{},"동시 요청이 많이 발생할 가능성이 있는가?",[113,204,205],{},"실제 트래픽이 집중되는 기능인가?",[103,207,208],{},"실제로 동시성 이슈가 자주 발생하는 대표적인 요구사항은 다음과 같습니다.",[138,210,211,214,217,220],{},[113,212,213],{},"좋아요 증가",[113,215,216],{},"주문 생성",[113,218,219],{},"재고 감소",[113,221,222],{},"포인트 증가\u002F차감",[103,224,225,226,230],{},"이러한 문제를 해결하기 위해 데이터베이스는 ",[227,228,229],"strong",{},"Lock 메커니즘","을 제공합니다.",[99,232,234],{"id":233},"record-lock-row-lock","Record Lock (Row Lock)",[103,236,237,238,241],{},"Record Lock은 테이블 전체가 아니라 ",[227,239,240],{},"특정 행(Row)에 대해서만 락을 거는 방식","입니다.",[103,243,244,245,249,250,253,254,257],{},"InnoDB 스토리지 엔진에서는 ",[246,247,248],"code",{},"UPDATE",", ",[246,251,252],{},"DELETE","와 같은 쓰기 작업이 수행되는 시점에\n해당 레코드에 대해 ",[227,255,256],{},"Exclusive Row Lock(X Lock)"," 을 획득합니다.",[103,259,260],{},"즉, 하나의 트랜잭션이 특정 행을 수정하고 있는 동안에는\n다른 트랜잭션이 동일한 레코드를 동시에 수정하지 못하도록 막아줍니다.",[103,262,263],{},"이를 통해 다음과 같은 문제를 방지할 수 있습니다.",[138,265,266,269,272],{},[113,267,268],{},"동일 레코드의 동시 수정 방지",[113,270,271],{},"트랜잭션 간 충돌 제어",[113,273,274],{},"데이터 무결성 보장",[103,276,277,278,281],{},"일반적으로 우리가 기대하는 ",[227,279,280],{},"\"행 단위 동시성 제어\""," 가 바로 Record Lock이라고 볼 수 있습니다.",[103,283,284],{},"다만, 모든 스토리지 엔진이 Row Lock을 제공하는 것은 아니기 때문에\n실제 운영 환경에서는 사용 중인 스토리지 엔진(InnoDB 여부)을 반드시 확인해야 합니다.",[286,287,289],"h3",{"id":288},"락-상태-확인하기","락 상태 확인하기",[103,291,292,293,296],{},"실제로 Lock이 어떻게 동작하는지 직접 확인해보는 것이 가장 확실합니다.\nMySQL에서는 ",[246,294,295],{},"performance_schema","를 통해 현재 걸린 Lock 상태를 조회할 수 있습니다.",[298,299,303],"pre",{"className":300,"code":301,"language":302,"meta":54,"style":54},"language-mysql shiki shiki-themes github-light github-light dracula","select *\nfrom performance_schema.data_locks;\n","mysql",[246,304,305,312],{"__ignoreMap":54},[306,307,309],"span",{"class":308,"line":10},"line",[306,310,311],{},"select *\n",[306,313,314],{"class":308,"line":28},[306,315,316],{},"from performance_schema.data_locks;\n",[298,318,320],{"className":300,"code":319,"language":302,"meta":54,"style":54},"START TRANSACTION;\n\nUPDATE article\nSET like_count = like_count + 1\nWHERE id = 123;\n",[246,321,322,327,333,339,345],{"__ignoreMap":54},[306,323,324],{"class":308,"line":10},[306,325,326],{},"START TRANSACTION;\n",[306,328,329],{"class":308,"line":28},[306,330,332],{"emptyLinePlaceholder":331},true,"\n",[306,334,336],{"class":308,"line":335},3,[306,337,338],{},"UPDATE article\n",[306,340,342],{"class":308,"line":341},4,[306,343,344],{},"SET like_count = like_count + 1\n",[306,346,348],{"class":308,"line":347},5,[306,349,350],{},"WHERE id = 123;\n",[103,352,353],{},"해당 시점에 InnoDB는 id = 123 레코드에 대해 Exclusive Row Lock(X Lock) 을 획득합니다.",[103,355,356],{},"performance_schema 를 통해 조회해보면 아래와 같이 record lock 이 걸렸음을 확인할 수 있습니다.",[298,358,360],{"className":300,"code":359,"language":302,"meta":54,"style":54},"+--------+-------------------------------------------+-----------------------+-----------+----------+---------------+-------------+----------------+-------------------+------------+-----------------------+-----------+---------------+-------------+-----------+\n| ENGINE | ENGINE_LOCK_ID                            | ENGINE_TRANSACTION_ID | THREAD_ID | EVENT_ID | OBJECT_SCHEMA | OBJECT_NAME | PARTITION_NAME | SUBPARTITION_NAME | INDEX_NAME | OBJECT_INSTANCE_BEGIN | LOCK_TYPE | LOCK_MODE     | LOCK_STATUS | LOCK_DATA |\n+--------+-------------------------------------------+-----------------------+-----------+----------+---------------+-------------+----------------+-------------------+------------+-----------------------+-----------+---------------+-------------+-----------+\n| INNODB | 281473586793688:112:1068:281473500370112  |                  1844 |        46 |       68 | lock_test     | article     | NULL           | NULL              | NULL       |       281473500370112 | TABLE     | IX            | GRANTED     | NULL      |\n| INNODB | 281473586793688:112:2:4:2:281473500367120 |                  1844 |        46 |       68 | lock_test     | article     | NULL           | NULL              | PRIMARY    |       281473500367120 | RECORD    | X,REC_NOT_GAP | GRANTED     | 1         |\n+--------+-------------------------------------------+-----------------------+-----------+----------+---------------+-------------+----------------+-------------------+------------+-----------------------+-----------+---------------+-------------+-----------+\n",[246,361,362,367,372,376,381,386],{"__ignoreMap":54},[306,363,364],{"class":308,"line":10},[306,365,366],{},"+--------+-------------------------------------------+-----------------------+-----------+----------+---------------+-------------+----------------+-------------------+------------+-----------------------+-----------+---------------+-------------+-----------+\n",[306,368,369],{"class":308,"line":28},[306,370,371],{},"| ENGINE | ENGINE_LOCK_ID                            | ENGINE_TRANSACTION_ID | THREAD_ID | EVENT_ID | OBJECT_SCHEMA | OBJECT_NAME | PARTITION_NAME | SUBPARTITION_NAME | INDEX_NAME | OBJECT_INSTANCE_BEGIN | LOCK_TYPE | LOCK_MODE     | LOCK_STATUS | LOCK_DATA |\n",[306,373,374],{"class":308,"line":335},[306,375,366],{},[306,377,378],{"class":308,"line":341},[306,379,380],{},"| INNODB | 281473586793688:112:1068:281473500370112  |                  1844 |        46 |       68 | lock_test     | article     | NULL           | NULL              | NULL       |       281473500370112 | TABLE     | IX            | GRANTED     | NULL      |\n",[306,382,383],{"class":308,"line":347},[306,384,385],{},"| INNODB | 281473586793688:112:2:4:2:281473500367120 |                  1844 |        46 |       68 | lock_test     | article     | NULL           | NULL              | PRIMARY    |       281473500367120 | RECORD    | X,REC_NOT_GAP | GRANTED     | 1         |\n",[306,387,389],{"class":308,"line":388},6,[306,390,366],{},[103,392,393],{},"그래서 또다른 커넥션에서 아래와 같이 같은 record 에 대해 update 를 시도합니다.",[298,395,396],{"className":300,"code":319,"language":302,"meta":54,"style":54},[246,397,398,402,406,410,414],{"__ignoreMap":54},[306,399,400],{"class":308,"line":10},[306,401,326],{},[306,403,404],{"class":308,"line":28},[306,405,332],{"emptyLinePlaceholder":331},[306,407,408],{"class":308,"line":335},[306,409,338],{},[306,411,412],{"class":308,"line":341},[306,413,344],{},[306,415,416],{"class":308,"line":347},[306,417,350],{},[103,419,420],{},"이 쿼리는 즉시 실행되지 않고 대기 상태(waiting) 에 들어가게 됩니다.",[103,422,423],{},"이미 트랜잭션 1이 동일 레코드를 점유하고 있기 때문입니다.",[103,425,426],{},"트랜잭션 1이 종료되면서 해당 레코드에 걸린 Lock이 해제되고,\n대기 중이던 트랜잭션 2의 UPDATE가 그제서야 수행됩니다.",[103,428,429],{},"이 과정을 통해 InnoDB의 Record Lock이\n동일 레코드에 대한 동시 수정 요청을 원자적으로 수행한다는 것을 알 수 있습니다.",[103,431,432],{},"블로그에서 바로 쓰기 좋은 짧고 깔끔한 단일 콜아웃 버전으로 정리해줄게.",[286,434,436],{"id":435},"참고","🍀 참고",[298,438,440],{"className":300,"code":439,"language":302,"meta":54,"style":54},"UPDATE article SET like_count = like_count + 1 WHERE title = 'lock test article';\n\n+--------+-------------------------------------------+-----------------------+-----------+----------+---------------+-------------+----------------+-------------------+------------+-----------------------+-----------+-----------+-------------+------------------------+\n| ENGINE | ENGINE_LOCK_ID                            | ENGINE_TRANSACTION_ID | THREAD_ID | EVENT_ID | OBJECT_SCHEMA | OBJECT_NAME | PARTITION_NAME | SUBPARTITION_NAME | INDEX_NAME | OBJECT_INSTANCE_BEGIN | LOCK_TYPE | LOCK_MODE | LOCK_STATUS | LOCK_DATA              |\n+--------+-------------------------------------------+-----------------------+-----------+----------+---------------+-------------+----------------+-------------------+------------+-----------------------+-----------+-----------+-------------+------------------------+\n| INNODB | 281473586793688:114:1068:281473500370112  |                  1846 |        46 |       72 | lock_test     | article     | NULL           | NULL              | NULL       |       281473500370112 | TABLE     | IX        | GRANTED     | NULL                   |\n| INNODB | 281473586793688:114:2:4:1:281473500367120 |                  1846 |        46 |       72 | lock_test     | article     | NULL           | NULL              | PRIMARY    |       281473500367120 | RECORD    | X         | GRANTED     | supremum pseudo-record |\n| INNODB | 281473586793688:114:2:4:2:281473500367120 |                  1846 |        46 |       72 | lock_test     | article     | NULL           | NULL              | PRIMARY    |       281473500367120 | RECORD    | X         | GRANTED     | 1                      |\n+--------+-------------------------------------------+-----------------------+-----------+----------+---------------+-------------+----------------+-------------------+------------+-----------------------+-----------+-----------+-------------+------------------------+\n",[246,441,442,447,451,456,461,465,470,476,482],{"__ignoreMap":54},[306,443,444],{"class":308,"line":10},[306,445,446],{},"UPDATE article SET like_count = like_count + 1 WHERE title = 'lock test article';\n",[306,448,449],{"class":308,"line":28},[306,450,332],{"emptyLinePlaceholder":331},[306,452,453],{"class":308,"line":335},[306,454,455],{},"+--------+-------------------------------------------+-----------------------+-----------+----------+---------------+-------------+----------------+-------------------+------------+-----------------------+-----------+-----------+-------------+------------------------+\n",[306,457,458],{"class":308,"line":341},[306,459,460],{},"| ENGINE | ENGINE_LOCK_ID                            | ENGINE_TRANSACTION_ID | THREAD_ID | EVENT_ID | OBJECT_SCHEMA | OBJECT_NAME | PARTITION_NAME | SUBPARTITION_NAME | INDEX_NAME | OBJECT_INSTANCE_BEGIN | LOCK_TYPE | LOCK_MODE | LOCK_STATUS | LOCK_DATA              |\n",[306,462,463],{"class":308,"line":347},[306,464,455],{},[306,466,467],{"class":308,"line":388},[306,468,469],{},"| INNODB | 281473586793688:114:1068:281473500370112  |                  1846 |        46 |       72 | lock_test     | article     | NULL           | NULL              | NULL       |       281473500370112 | TABLE     | IX        | GRANTED     | NULL                   |\n",[306,471,473],{"class":308,"line":472},7,[306,474,475],{},"| INNODB | 281473586793688:114:2:4:1:281473500367120 |                  1846 |        46 |       72 | lock_test     | article     | NULL           | NULL              | PRIMARY    |       281473500367120 | RECORD    | X         | GRANTED     | supremum pseudo-record |\n",[306,477,479],{"class":308,"line":478},8,[306,480,481],{},"| INNODB | 281473586793688:114:2:4:2:281473500367120 |                  1846 |        46 |       72 | lock_test     | article     | NULL           | NULL              | PRIMARY    |       281473500367120 | RECORD    | X         | GRANTED     | 1                      |\n",[306,483,485],{"class":308,"line":484},9,[306,486,455],{},[298,488,493],{"className":489,"code":491,"language":492,"meta":54},[490],"language-text","UPDATE 시 InnoDB의 Lock 종류는 WHERE 조건에 따라 달라집니다.\n\nPK \u002F Unique 조건\n→ Record Lock 적용 (단일 레코드만 잠금, 동시성 영향 최소)\nNon-Unique 조건\n→ Gap Lock 또는 Next-Key Lock 적용 가능\n→ 조회된 레코드뿐 아니라 여러 레코드 행에 INSERT까지 차단될 수 있음\n\nDB Lock 동작은 DB 벤더, 스토리지 엔진(InnoDB 등), 트랜잭션 격리 수준에 따라 달라지므로\n동시성 처리가 중요한 경우 실제 Lock 동작을 확인하며 사용하는 것이 좋습니다.\n","text",[246,494,491],{"__ignoreMap":54},[99,496,498],{"id":497},"락을-오래-점유하면-생기는-문제","락을 오래 점유하면 생기는 문제",[103,500,501],{},"다만 이러한 Lock 을 오래 점유하게 되면 시스템 전체 성능에 악영향을 줄 수 있음이 예상됩니다.",[138,503,504,517,527,537],{},[113,505,506,509],{},[227,507,508],{},"트랜잭션 대기 증가",[138,510,511,514],{},[113,512,513],{},"동일 레코드를 수정하려는 요청들이 대기 상태로 쌓인다.",[113,515,516],{},"순간적인 트래픽 증가가 전체 요청 지연으로 이어질 수 있다.",[113,518,519,522],{},[227,520,521],{},"DB 부하 증가",[138,523,524],{},[113,525,526],{},"대기 중인 커넥션이 늘어나면서 커넥션 풀 고갈이나 CPU 사용량 증가가 발생할 수 있다.",[113,528,529,532],{},[227,530,531],{},"Deadlock 발생",[138,533,534],{},[113,535,536],{},"여러 트랜잭션이 서로의 Lock 해제를 기다리며 교착 상태에 빠질 수 있다.",[113,538,539,542],{},[227,540,541],{},"장애 상황 유발",[138,543,544],{},[113,545,546],{},"Lock 대기가 길어지면 Timeout이 발생하고,\n결국 서비스 장애로 이어질 가능성도 존재한다.",[103,548,549],{},"개발자는 Lock 을 얼마나 짧은 시간동안 점유할 수 있는가에 고민을 해야합니다.",[99,551,553],{"id":552},"조회수-좋아요-기능-예시","조회수, 좋아요 기능 예시",[103,555,556,557,560],{},"게시글 서비스에서는 반정규화를 통해",[558,559],"br",{},"\n게시글 Row에 조회수, 좋아요 수 같은 집계 데이터를 함께 저장하는 경우가 많습니다.",[103,562,563],{},"문제는 쓰기 트래픽이 몰리는 순간 발생합니다.",[103,565,566,567,569,570,572],{},"조회수 증가, 좋아요 증가, 게시글 수정은",[558,568],{},"\n기능적으로는 서로 독립적인 작업이지만",[558,571],{},"\n모두 동일한 게시글 Row를 UPDATE 하게 됩니다.",[103,574,575,576,578],{},"특정 게시글에 좋아요나 조회 요청이 집중되면",[558,577],{},"\n집계성 업데이트가 Row Lock을 지속적으로 점유하게 되고,",[103,580,581,582,584],{},"그 결과 게시글 수정과 같은 다른 작업까지",[558,583],{},"\n불필요하게 대기하는 상황이 발생할 수 있습니다.",[99,586,588],{"id":587},"데이터-구조-분리를-통한-lock-경합-완화","데이터 구조 분리를 통한 Lock 경합 완화",[103,590,591],{},"예를 들어 다음과 같이 데이터를 분리할 수 있습니다.",[103,593,594,595,597,598,600],{},"article",[558,596],{},"\narticle_like",[558,599],{},"\narticle_like_count",[103,602,603,604,606],{},"락 경합을 줄이기 위해",[558,605],{},"\n데이터 모델의 책임을 나누는 접근입니다.",[103,608,609],{},"또한 조회수와 같은 집계 데이터는\n요청마다 즉시 UPDATE 하지 않고,\n캐시에 누적한 뒤 일정 주기로 반영하는 전략도 사용할 수 있습니다.",[103,611,612],{},"이번 복습을 통해 다시 느낀 점은 다음과 같습니다.",[103,614,615,616,618],{},"동시성 문제는 단순히 Lock 기술로 해결하는 문제가 아니라,",[558,617],{},"\n데이터 구조 설계 단계에서 이미 결정되는 경우가 많다는 점입니다.",[99,620,622],{"id":621},"비관적-락-pessimistic-lock","비관적 락 (Pessimistic Lock)",[103,624,625,626,629],{},"비관적 락은 ",[227,627,628],{},"충돌이 발생할 가능성이 높다고 가정","하는 방식입니다.",[103,631,632,633,635],{},"데이터 수정 전에 먼저 Lock을 획득하여",[558,634],{},"\n다른 트랜잭션의 접근을 차단합니다.",[103,637,638],{},"InnoDB의 Record Lock 역시 비관적 락의 대표적인 예시입니다.",[286,640,642],{"id":641},"방법-1-update-한-번에-처리","방법 1 — UPDATE 한 번에 처리",[298,644,646],{"className":300,"code":645,"language":302,"meta":54,"style":54},"UPDATE article\nSET like_count = like_count + 1\nWHERE id = 123;\n",[246,647,648,652,656],{"__ignoreMap":54},[306,649,650],{"class":308,"line":10},[306,651,338],{},[306,653,654],{"class":308,"line":28},[306,655,344],{},[306,657,658],{"class":308,"line":335},[306,659,350],{},[138,661,662,665,668],{},[113,663,664],{},"UPDATE 실행 시점에 Row Lock 획득",[113,666,667],{},"Lock 점유 시간이 상대적으로 짧음",[113,669,670],{},"불필요한 조회 과정 없음",[103,672,673],{},"단순 증가\u002F감소 연산에서는 가장 좋은 방식",[286,675,677],{"id":676},"방법-2-select-for-update","방법 2 — SELECT FOR UPDATE",[298,679,681],{"className":300,"code":680,"language":302,"meta":54,"style":54},"SELECT *\nFROM article\nWHERE id = 123 FOR\nUPDATE;\n",[246,682,683,688,693,698],{"__ignoreMap":54},[306,684,685],{"class":308,"line":10},[306,686,687],{},"SELECT *\n",[306,689,690],{"class":308,"line":28},[306,691,692],{},"FROM article\n",[306,694,695],{"class":308,"line":335},[306,696,697],{},"WHERE id = 123 FOR\n",[306,699,700],{"class":308,"line":341},[306,701,702],{},"UPDATE;\n",[103,704,705],{},"이후 비즈니스 로직 수행 후 UPDATE를 실행합니다.",[138,707,708,711,714],{},[113,709,710],{},"조회 시점부터 Lock 획득",[113,712,713],{},"조회 → 검증 → 수정 흐름 구현 가능",[113,715,716],{},"JPA 같은 ORM 기술 사용 시 객체 중심으로 로직 작성이 용이",[103,718,719],{},"단점",[138,721,722,725],{},[113,723,724],{},"Lock 점유 시간이 길어질 수 있음",[113,726,727],{},"트랜잭션 설계에 더욱 주의 필요",[99,729,731],{"id":730},"낙관적-락-optimistic-lock","낙관적 락 (Optimistic Lock)",[103,733,734,735,629],{},"낙관적 락은 ",[227,736,737],{},"충돌이 거의 발생하지 않는다고 가정",[103,739,740,741,743],{},"데이터 조회 시 Lock을 획득하지 않고,",[558,742],{},"\nUPDATE 시점에 데이터 변경 여부를 검증하여 충돌을 감지합니다.",[286,745,747],{"id":746},"동작-방식","동작 방식",[138,749,750,753,756],{},[113,751,752],{},"현재 version 조회",[113,754,755],{},"UPDATE 시 version 조건 포함",[113,757,758],{},"수정 성공 시 version 증가",[298,760,762],{"className":300,"code":761,"language":302,"meta":54,"style":54},"UPDATE article\nSET like_count = ?,\n    version    = version + 1\nWHERE id = 123\n  AND version = 10;\n",[246,763,764,768,773,778,783],{"__ignoreMap":54},[306,765,766],{"class":308,"line":10},[306,767,338],{},[306,769,770],{"class":308,"line":28},[306,771,772],{},"SET like_count = ?,\n",[306,774,775],{"class":308,"line":335},[306,776,777],{},"    version    = version + 1\n",[306,779,780],{"class":308,"line":341},[306,781,782],{},"WHERE id = 123\n",[306,784,785],{"class":308,"line":347},[306,786,787],{},"  AND version = 10;\n",[138,789,790,793],{},[113,791,792],{},"UPDATE 성공 → 충돌 없음",[113,794,795],{},"UPDATE 실패 → 다른 트랜잭션이 먼저 수정",[103,797,798],{},"충돌이 발생한 경우에는\n재시도(Retry) 전략을 함께 설계해야 합니다.",[103,800,801],{},"특징",[138,803,804,807,810,813,816,819],{},[113,805,806],{},"DB Lock 대기 없음",[113,808,809],{},"동시 처리 성능에 유리",[113,811,812],{},"충돌 발생 시 애플리케이션 레벨에서 처리 필요\n적합한 상황",[113,814,815],{},"충돌 빈도가 낮은 서비스",[113,817,818],{},"읽기 비중이 높은 시스템",[113,820,821],{},"Lock 대기를 최소화하고 싶은 경우",[99,823,824],{"id":824},"마무리",[103,826,827,828,830,831,834],{},"동시성 문제를 해결하기 위해 DB Lock을 고려할 때,",[558,829],{},"\n무조건 Lock부터 적용하기보다는 ",[227,832,833],{},"설계를 통해 문제 자체를 줄일 수 있는지"," 먼저 고민하는 것이 중요합니다.",[103,836,837,838,840,841,844],{},"또한 충돌 발생 빈도가 낮거나 일부 실패를 허용할 수 있는 경우라면,",[558,839],{},"\n제약조건이나 원자적 연산을 활용해 ",[227,842,843],{},"가능한 한 Lock을 사용하지 않는 방향","을 먼저 검토해보는게 좋은 방향이라는 생각이 듭니다.",[103,846,847],{},"이번에 정리하며 스스로 정립한 사고 흐름은 다음과 같습니다.",[138,849,850,853,856,859,865],{},[113,851,852],{},"데이터 구조를 분리할 수 있는가?",[113,854,855],{},"원자적 UPDATE로 해결 가능한가?",[113,857,858],{},"Lock이 반드시 필요한 상황인가?",[113,860,861,862,864],{},"비동기 처리로 문제 자체를 단순화할 수 있는가?",[558,863],{},"\n(단, 운영 비용과 서비스 정책에 대한 협의가 필요)",[113,866,867],{},"복잡한 비즈니스 제어나 다중 인스턴스 환경이라면 분산 락을 고려할 수 있는가?",[103,869,870,871,873],{},"오랜만에 초심으로 돌아가",[558,872],{},"\nDB Lock 개념을 다시 복습하고 정리해볼 수 있는 시간이었습니다.",[103,875,876,877,880],{},"다음에는 ",[227,878,879],{},"분산 락과 비동기 처리 환경에서의 동시성 제어 방식","을 복습해볼 예정입니다.",[882,883,884],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text