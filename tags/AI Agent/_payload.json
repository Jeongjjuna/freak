[{"data":1,"prerenderedAt":166},["ShallowReactive",2],{"layout-data":3,"tag-posts-AI Agent":93,"tag-feeds-AI Agent":96},{"groups":4,"recentPosts":46},[5,11,41],{"name":6,"categories":7},"Engineering",[8],{"name":9,"count":10},"Architecture",1,{"name":12,"categories":13},"Learning",[14,16,18,20,22,24,26,29,31,33,35,37,39],{"name":15,"count":10},"API",{"name":17,"count":10},"Docker",{"name":19,"count":10},"Git",{"name":21,"count":10},"JPA",{"name":23,"count":10},"Kafka",{"name":25,"count":10},"Kubernetes",{"name":27,"count":28},"MySQL",2,{"name":30,"count":10},"RabbitMQ",{"name":32,"count":10},"Redis",{"name":34,"count":10},"Security",{"name":36,"count":28},"SpringBoot",{"name":38,"count":10},"SpringSecurity",{"name":40,"count":10},"Testing",{"name":42,"categories":43},"Archive",[44],{"name":45,"count":10},"Books",[47,56,64,75,85],{"slug":48,"title":49,"date":50,"category":27,"tags":51,"excerpt":54,"thumbnail":55},"revisiting-db-locks","초심 찾기! 동시성 처리를 위한 DB Lock 다시 한번 복습해보자","2026-04-30",[27,52,21,53],"동시성","데이터베이스","","\u002Fimages\u002Fthumbnails\u002Fdatabase.png",{"slug":57,"title":58,"date":59,"category":45,"tags":60,"excerpt":54,"thumbnail":63},"minimum-practical-knowledge-for-developers","개발자를 위한 최소한의 실무 지식 독서 회고","2026-04-18",[61,62],"독서","커리어","\u002Fimages\u002Fthumbnails\u002Fbooks.png",{"slug":65,"title":66,"date":67,"category":9,"tags":68,"excerpt":54,"thumbnail":74},"spring-architecture","아키텍처 규칙 강제하기(feat MultiModule, ArchUnit, AI Agent)","2026-04-08",[69,70,71,72,73],"Kotlin","Spring","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",{"slug":76,"title":77,"date":78,"category":38,"tags":79,"excerpt":54,"thumbnail":84},"spring-security-architecture","[Example] Spring Security 동작 원리, 프로세스 이해하기","2026-03-15",[80,81,70,82,83],"Spring Security","인증","보안","Java","\u002Fimages\u002Fthumbnails\u002Fsecurity.png",{"slug":86,"title":87,"date":88,"category":36,"tags":89,"excerpt":54,"thumbnail":92},"spring-aop-private-method","[Example] Spring AOP를 private 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[70,90,83,91],"AOP","Transaction","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[94],{"slug":65,"title":66,"date":67,"category":9,"tags":95,"excerpt":54,"thumbnail":74},[69,70,71,72,73],[97],{"id":98,"title":99,"body":100,"date":155,"description":106,"extension":156,"meta":157,"navigation":158,"path":159,"seo":160,"stem":161,"tags":162,"__hash__":165},"feeds\u002Ffeeds\u002F2026-05-31-oop-fp.md","2026 05 31 Oop Fp",{"type":101,"value":102,"toc":152},"minimark",[103,107,110,120,123,146,149],[104,105,106],"p",{},"기존에 나는 읽기 쉽고, 확장성이 좋고, 협업하기 좋은 코드를 작성하기 위해 OOP와 FP를 활용했다.",[104,108,109],{},"하지만 이제는 AI가 코드를 작성하는 시대다.\nAI가 코드를 작성하게 되면서 부터는 문득 이런 생각이 들었다.",[111,112,113],"blockquote",{},[104,114,115,116,119],{},"\"객체지향(OOP), 함수형 프로그래밍(FP)을 계속 공부하는 것이 여전히 의미가 있을까?\"",[117,118],"br",{},"\n\"개발자의 역할이 구현보다 테스트와 검증에 가까워지고 있다면, OOP와 FP는 어떤 가치를 가질까?\"",[104,121,122],{},"내가 생각하는 핵심은 다음과 같다.",[124,125,126,135],"ul",{},[127,128,129,130],"li",{},"객체지향 프로그래밍(OOP)\n",[124,131,132],{},[127,133,134],{},"책임과 경계를 정의한다.",[127,136,137,138],{},"함수형 프로그래밍(FP)\n",[124,139,140,143],{},[127,141,142],{},"예측 가능성을 높인다.",[127,144,145],{},"부수효과(Side Effect)를 최소화한다.",[104,147,148],{},"누군가는 AI 개발을 지휘해야하고, 능숙하게 시스템을 파악하여 AI 에게 또다시 프롬프트를 전달해야한다.\n그렇기 때문에 어떤 책임을 어디에 둘지,\n어떤 상태 변경을 허용할지,\n무엇을 검증해야 하는지는 여전히 사람이 결정하는게 좋다고 생각한다.",[104,150,151],{},"앞으로는 협업과 확장성뿐 아니라,\nAI Agent 개발 관점에서 설계 → 테스트 → 검증까지의 흐름 속에서\n객체지향과 함수형이 어떤 이점을 주는지 직접 실험해보고 기록해보려 한다.",{"title":54,"searchDepth":153,"depth":153,"links":154},3,[],"2026-05-31T23:50:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-05-31-oop-fp",{"description":106},"feeds\u002F2026-05-31-oop-fp",[163,164,73],"OOP","FP","N9SjZzLRCfBFEcIvGVaOj6-Girq0VI3AybXYfO-Zn2M",1780815040363]