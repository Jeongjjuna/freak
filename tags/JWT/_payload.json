vate 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[70,90,83,91],"AOP","Transaction","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[94],{"slug":95,"title":96,"date":97,"category":34,"tags":98,"excerpt":54,"thumbnail":84},"jwt-authentication","[Example] JWT 인증 구현과 refresh token 전략","2025-07-28",[99,82,70,81],"JWT",[101,218,314],{"id":102,"title":103,"body":104,"date":205,"description":54,"extension":206,"meta":207,"navigation":208,"path":209,"seo":210,"stem":211,"tags":212,"__hash__":217},"feeds\u002Ffeeds\u002F2026-06-03-signature.md","2026 06 03 Signature",{"type":105,"value":106,"toc":196},"minimark",[107,112,119,124,140,153,160,169,172,176,179,182,185,188,191],[108,109,111],"h2",{"id":110},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[113,114,115],"blockquote",{},[116,117,118],"p",{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[120,121,123],"h3",{"id":122},"실무에서-만나는-곳","실무에서 만나는 곳",[125,126,127,131,134,137],"ul",{},[128,129,130],"li",{},"JWT 서명 (HS256, RS256)",[128,132,133],{},"웹훅 검증 (Stripe, GitHub 등)",[128,135,136],{},"서버 간 API 인증",[128,138,139],{},"AWS SigV4 요청 서명",[120,141,143,144,148,149,152],{"id":142},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[145,146,147],"code",{},"누가 보냈는지","와 ",[145,150,151],{},"내용이 안 바뀌었는지","를 증명한다",[116,154,155,156,159],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[145,157,158],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[116,161,162,163,165,166,168],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[145,164,81],{},"), 중간에 변조되지 않았다(",[145,167,158],{},")\"를 증명한다.",[116,170,171],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[120,173,175],{"id":174},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[116,177,178],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[116,180,181],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[116,183,184],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[186,187],"br",{},[116,189,190],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[113,192,193],{},[116,194,195],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":54,"searchDepth":197,"depth":197,"links":198},3,[199],{"id":110,"depth":28,"text":111,"children":200},[201,202,204],{"id":122,"depth":197,"text":123},{"id":142,"depth":197,"text":203},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":174,"depth":197,"text":175},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":54},"feeds\u002F2026-06-03-signature",[82,213,214,215,216,99,81],"암호기초","백엔드","서명","HMAC","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":219,"title":220,"body":221,"date":306,"description":54,"extension":206,"meta":307,"navigation":208,"path":308,"seo":309,"stem":310,"tags":311,"__hash__":313},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":105,"value":222,"toc":298},[223,227,232,234,256,260,263,266,270,281,285,288,290,293],[108,224,226],{"id":225},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[113,228,229],{},[116,230,231],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[120,233,123],{"id":122},[125,235,236,247,250,253],{},[128,237,238,239,242,243,246],{},"JWT의 ",[145,240,241],{},"header",", ",[145,244,245],{},"payload"," (Base64URL)",[128,248,249],{},"URL의 한글·특수문자 (Percent-Encoding)",[128,251,252],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[128,254,255],{},"바이너리를 로그·DB에 저장할 때",[120,257,259],{"id":258},"왜-사용할까","왜 사용할까?",[116,261,262],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[116,264,265],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[120,267,269],{"id":268},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[116,271,238,272,148,274,276,277,280],{},[145,273,241],{},[145,275,245],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[145,278,279],{},"서명(Signature)"," 에서 나온다.",[120,282,284],{"id":283},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[116,286,287],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[186,289],{},[116,291,292],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[113,294,295],{},[116,296,297],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":54,"searchDepth":197,"depth":197,"links":299},[300],{"id":225,"depth":28,"text":226,"children":301},[302,303,304,305],{"id":122,"depth":197,"text":123},{"id":258,"depth":197,"text":259},{"id":268,"depth":197,"text":269},{"id":283,"depth":197,"text":284},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":54},"feeds\u002F2026-06-03-encoding",[82,213,214,312,99],"인코딩","8I5ExkCcCxIM2o5tuh_mX4i-P-F6f_Sv4n747ziuqKA",{"id":315,"title":316,"body":317,"date":367,"description":321,"extension":206,"meta":368,"navigation":208,"path":369,"seo":370,"stem":371,"tags":372,"__hash__":374},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":105,"value":318,"toc":364},[319,322,325,331,334,341,346,349,355,358,361],[116,320,321],{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[116,323,324],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[326,327,328],"ol",{},[128,329,330],{},"JWT 방식",[116,332,333],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[116,335,336],{},[337,338],"img",{"alt":339,"src":340},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[326,342,343],{"start":28},[128,344,345],{},"HMAC (Hash-based Message Authentication Code)",[116,347,348],{},"서버 간에 시크릿 키를 공유한다.\n요청 하는 서버는 요청 정보(Request Body 등)를 시크릿 키를 이용해 해시 기반 서명값(MAC)으로 변환하고, 그 값을 \"헤더에 담아 전송\"한다.\n요청을 받은 서버는 요청 정보(Request Body 등) 을 동일한 시크릿 키로 해시 기반 서명값(MAC)으로 변환하고, \"그 결과가 헤더의 값과 같은지 확인하여 검증\"한다.",[116,350,351],{},[337,352],{"alt":353,"src":354},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[116,356,357],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[108,359,360],{"id":360},"정리",[116,362,363],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":54,"searchDepth":197,"depth":197,"links":365},[366],{"id":360,"depth":28,"text":360},"2026-06-01T20:36:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-hmac",{"description":321},"feeds\u002F2026-06-01-hmac",[82,373,216,99,81],"네트워크","mJQJW2YkEiLfOXtm6jWO4bEV6DvCkJ55q9yOyoAMhZY",1780811788211]