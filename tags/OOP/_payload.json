[{"data":1,"prerenderedAt":145},["ShallowReactive",2],{"layout-data":3,"tag-posts-OOP":74,"tag-feeds-OOP":75},{"groups":4,"recentPosts":30},[5,11,20,25],{"name":6,"categories":7},"Engineering",[8],{"name":9,"count":10},"Architecture",1,{"name":12,"categories":13},"Learning",[14,16,18],{"name":15,"count":10},"MySQL",{"name":17,"count":10},"Redis",{"name":19,"count":10},"Security",{"name":21,"categories":22},"Archive",[23],{"name":24,"count":10},"Books",{"name":26,"categories":27},"Etc",[28],{"name":29,"count":10},"Kotlin",[31,40,47,56,64],{"slug":32,"title":33,"date":34,"category":19,"tags":35,"excerpt":38,"thumbnail":39},"2026-06-07-jvm-security-jwt","이론 & 실습 : 초간단 JWT 직접 구현해보기","2026-06-07",[19,36,37,29],"JWT","SHA256","","\u002Fimages\u002Fthumbnails\u002Fsecurity.png",{"slug":41,"title":42,"date":34,"category":29,"tags":43,"excerpt":38,"thumbnail":46},"2026-06-07-kotlin-stdlib-uuid-v7","UUID - v7 이 무엇일까?",[29,44,45],"UUID","UUIDv7","\u002Fimages\u002Fthumbnails\u002Fkotlin.png",{"slug":48,"title":49,"date":50,"category":15,"tags":51,"excerpt":38,"thumbnail":55},"revisiting-db-locks","초심 찾기! 동시성 처리를 위한 DB Lock 다시 한번 복습해보자","2026-04-30",[15,52,53,54],"동시성","JPA","데이터베이스","\u002Fimages\u002Fthumbnails\u002Fdatabase.png",{"slug":57,"title":58,"date":59,"category":24,"tags":60,"excerpt":38,"thumbnail":63},"minimum-practical-knowledge-for-developers","개발자를 위한 최소한의 실무 지식 독서 회고","2026-04-18",[61,62],"독서","개발자를 위한 최소한의 실무 지식","\u002Fimages\u002Fthumbnails\u002Fbooks.png",{"slug":65,"title":66,"date":67,"category":9,"tags":68,"excerpt":38,"thumbnail":73},"spring-architecture","아키텍처 규칙 강제하기(feat MultiModule, ArchUnit, AI Agent)","2026-04-08",[29,69,70,71,72],"Spring","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",[],[76],{"id":77,"title":78,"body":79,"date":134,"description":85,"extension":135,"meta":136,"navigation":137,"path":138,"seo":139,"stem":140,"tags":141,"__hash__":144},"feeds\u002Ffeeds\u002F2026-05-31-oop-fp.md","2026 05 31 Oop Fp",{"type":80,"value":81,"toc":131},"minimark",[82,86,89,99,102,125,128],[83,84,85],"p",{},"기존에 나는 읽기 쉽고, 확장성이 좋고, 협업하기 좋은 코드를 작성하기 위해 OOP와 FP를 활용했다.",[83,87,88],{},"하지만 이제는 AI가 코드를 작성하는 시대다.\nAI가 코드를 작성하게 되면서 부터는 문득 이런 생각이 들었다.",[90,91,92],"blockquote",{},[83,93,94,95,98],{},"\"객체지향(OOP), 함수형 프로그래밍(FP)을 계속 공부하는 것이 여전히 의미가 있을까?\"",[96,97],"br",{},"\n\"개발자의 역할이 구현보다 테스트와 검증에 가까워지고 있다면, OOP와 FP는 어떤 가치를 가질까?\"",[83,100,101],{},"내가 생각하는 핵심은 다음과 같다.",[103,104,105,114],"ul",{},[106,107,108,109],"li",{},"객체지향 프로그래밍(OOP)\n",[103,110,111],{},[106,112,113],{},"책임과 경계를 정의한다.",[106,115,116,117],{},"함수형 프로그래밍(FP)\n",[103,118,119,122],{},[106,120,121],{},"예측 가능성을 높인다.",[106,123,124],{},"부수효과(Side Effect)를 최소화한다.",[83,126,127],{},"누군가는 AI 개발을 지휘해야하고, 능숙하게 시스템을 파악하여 AI 에게 또다시 프롬프트를 전달해야한다.\n그렇기 때문에 어떤 책임을 어디에 둘지,\n어떤 상태 변경을 허용할지,\n무엇을 검증해야 하는지는 여전히 사람이 결정하는게 좋다고 생각한다.",[83,129,130],{},"앞으로는 협업과 확장성뿐 아니라,\nAI Agent 개발 관점에서 설계 → 테스트 → 검증까지의 흐름 속에서\n객체지향과 함수형이 어떤 이점을 주는지 직접 실험해보고 기록해보려 한다.",{"title":38,"searchDepth":132,"depth":132,"links":133},3,[],"2026-05-31T23:50:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-05-31-oop-fp",{"description":85},"feeds\u002F2026-05-31-oop-fp",[142,143,72],"OOP","FP","N9SjZzLRCfBFEcIvGVaOj6-Girq0VI3AybXYfO-Zn2M",1782923313340]