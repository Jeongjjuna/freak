[{"data":1,"prerenderedAt":165},["ShallowReactive",2],{"layout-data":3,"tag-posts-OOP":94,"tag-feeds-OOP":95},{"groups":4,"recentPosts":51},[5,11,41,46],{"name":6,"categories":7},"Engineering",[8],{"name":9,"count":10},"Architecture",1,{"name":12,"categories":13},"Learning",[14,16,18,20,22,24,26,29,31,33,35,37,39],{"name":15,"count":10},"API",{"name":17,"count":10},"Docker",{"name":19,"count":10},"Git",{"name":21,"count":10},"JPA",{"name":23,"count":10},"Kafka",{"name":25,"count":10},"Kubernetes",{"name":27,"count":28},"MySQL",2,{"name":30,"count":10},"RabbitMQ",{"name":32,"count":10},"Redis",{"name":34,"count":28},"Security",{"name":36,"count":28},"SpringBoot",{"name":38,"count":10},"SpringSecurity",{"name":40,"count":10},"Testing",{"name":42,"categories":43},"Archive",[44],{"name":45,"count":10},"Books",{"name":47,"categories":48},"Etc",[49],{"name":50,"count":10},"Kotlin",[52,61,68,76,84],{"slug":53,"title":54,"date":55,"category":34,"tags":56,"excerpt":59,"thumbnail":60},"2026-06-07-jvm-security-jwt","이론 & 실습 : 초간단 JWT 직접 구현해보기","2026-06-07",[34,57,58,50],"JWT","SHA256","","\u002Fimages\u002Fthumbnails\u002Fsecurity.png",{"slug":62,"title":63,"date":55,"category":50,"tags":64,"excerpt":59,"thumbnail":67},"2026-06-07-kotlin-stdlib-uuid-v7","UUID - v7 이 무엇일까?",[50,65,66],"UUID","UUIDv7","\u002Fimages\u002Fthumbnails\u002Fkotlin.png",{"slug":69,"title":70,"date":71,"category":27,"tags":72,"excerpt":59,"thumbnail":75},"revisiting-db-locks","초심 찾기! 동시성 처리를 위한 DB Lock 다시 한번 복습해보자","2026-04-30",[27,73,21,74],"동시성","데이터베이스","\u002Fimages\u002Fthumbnails\u002Fdatabase.png",{"slug":77,"title":78,"date":79,"category":45,"tags":80,"excerpt":59,"thumbnail":83},"minimum-practical-knowledge-for-developers","개발자를 위한 최소한의 실무 지식 독서 회고","2026-04-18",[81,82],"독서","개발자를 위한 최소한의 실무 지식","\u002Fimages\u002Fthumbnails\u002Fbooks.png",{"slug":85,"title":86,"date":87,"category":9,"tags":88,"excerpt":59,"thumbnail":93},"spring-architecture","아키텍처 규칙 강제하기(feat MultiModule, ArchUnit, AI Agent)","2026-04-08",[50,89,90,91,92],"Spring","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",[],[96],{"id":97,"title":98,"body":99,"date":154,"description":105,"extension":155,"meta":156,"navigation":157,"path":158,"seo":159,"stem":160,"tags":161,"__hash__":164},"feeds\u002Ffeeds\u002F2026-05-31-oop-fp.md","2026 05 31 Oop Fp",{"type":100,"value":101,"toc":151},"minimark",[102,106,109,119,122,145,148],[103,104,105],"p",{},"기존에 나는 읽기 쉽고, 확장성이 좋고, 협업하기 좋은 코드를 작성하기 위해 OOP와 FP를 활용했다.",[103,107,108],{},"하지만 이제는 AI가 코드를 작성하는 시대다.\nAI가 코드를 작성하게 되면서 부터는 문득 이런 생각이 들었다.",[110,111,112],"blockquote",{},[103,113,114,115,118],{},"\"객체지향(OOP), 함수형 프로그래밍(FP)을 계속 공부하는 것이 여전히 의미가 있을까?\"",[116,117],"br",{},"\n\"개발자의 역할이 구현보다 테스트와 검증에 가까워지고 있다면, OOP와 FP는 어떤 가치를 가질까?\"",[103,120,121],{},"내가 생각하는 핵심은 다음과 같다.",[123,124,125,134],"ul",{},[126,127,128,129],"li",{},"객체지향 프로그래밍(OOP)\n",[123,130,131],{},[126,132,133],{},"책임과 경계를 정의한다.",[126,135,136,137],{},"함수형 프로그래밍(FP)\n",[123,138,139,142],{},[126,140,141],{},"예측 가능성을 높인다.",[126,143,144],{},"부수효과(Side Effect)를 최소화한다.",[103,146,147],{},"누군가는 AI 개발을 지휘해야하고, 능숙하게 시스템을 파악하여 AI 에게 또다시 프롬프트를 전달해야한다.\n그렇기 때문에 어떤 책임을 어디에 둘지,\n어떤 상태 변경을 허용할지,\n무엇을 검증해야 하는지는 여전히 사람이 결정하는게 좋다고 생각한다.",[103,149,150],{},"앞으로는 협업과 확장성뿐 아니라,\nAI Agent 개발 관점에서 설계 → 테스트 → 검증까지의 흐름 속에서\n객체지향과 함수형이 어떤 이점을 주는지 직접 실험해보고 기록해보려 한다.",{"title":59,"searchDepth":152,"depth":152,"links":153},3,[],"2026-05-31T23:50:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-05-31-oop-fp",{"description":105},"feeds\u002F2026-05-31-oop-fp",[162,163,92],"OOP","FP","N9SjZzLRCfBFEcIvGVaOj6-Girq0VI3AybXYfO-Zn2M",1782920763519]