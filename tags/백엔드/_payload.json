,172],"code",{},"누가 보냈는지","와 ",[170,175,176],{},"내용이 안 바뀌었는지","를 증명한다",[141,179,180,181,184],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[170,182,183],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[141,186,187,188,191,192,194],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[170,189,190],{},"인증","), 중간에 변조되지 않았다(",[170,193,183],{},")\"를 증명한다.",[141,196,197],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[145,199,201],{"id":200},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[141,203,204],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[141,206,207],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[141,209,210],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[212,213],"br",{},[141,215,216],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[138,218,219],{},[141,220,221],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":59,"searchDepth":223,"depth":223,"links":224},3,[225],{"id":135,"depth":28,"text":136,"children":226},[227,228,230],{"id":147,"depth":223,"text":148},{"id":167,"depth":223,"text":229},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":200,"depth":223,"text":201},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":59},"feeds\u002F2026-06-03-signature",[239,240,100,241,242,57,190],"보안","암호기초","서명","HMAC","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":245,"title":246,"body":247,"date":332,"description":59,"extension":232,"meta":333,"navigation":234,"path":334,"seo":335,"stem":336,"tags":337,"__hash__":339},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":130,"value":248,"toc":324},[249,253,258,260,282,286,289,292,296,307,311,314,316,319],[133,250,252],{"id":251},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[138,254,255],{},[141,256,257],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[145,259,148],{"id":147},[150,261,262,273,276,279],{},[153,263,264,265,268,269,272],{},"JWT의 ",[170,266,267],{},"header",", ",[170,270,271],{},"payload"," (Base64URL)",[153,274,275],{},"URL의 한글·특수문자 (Percent-Encoding)",[153,277,278],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[153,280,281],{},"바이너리를 로그·DB에 저장할 때",[145,283,285],{"id":284},"왜-사용할까","왜 사용할까?",[141,287,288],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[141,290,291],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[145,293,295],{"id":294},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[141,297,264,298,173,300,302,303,306],{},[170,299,267],{},[170,301,271],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[170,304,305],{},"서명(Signature)"," 에서 나온다.",[145,308,310],{"id":309},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[141,312,313],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[212,315],{},[141,317,318],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[138,320,321],{},[141,322,323],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":59,"searchDepth":223,"depth":223,"links":325},[326],{"id":251,"depth":28,"text":252,"children":327},[328,329,330,331],{"id":147,"depth":223,"text":148},{"id":284,"depth":223,"text":285},{"id":294,"depth":223,"text":295},{"id":309,"depth":223,"text":310},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":59},"feeds\u002F2026-06-03-encoding",[239,240,100,338,57],"인코딩","8I5ExkCcCxIM2o5tuh_mX4i-P-F6f_Sv4n747ziuqKA",1782920763055]