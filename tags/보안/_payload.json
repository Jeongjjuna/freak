OP를 private 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[90,91,83,92],"Spring","AOP","Transactional","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[],[96,215,304,386,483,733],{"id":97,"title":98,"body":99,"date":201,"description":53,"extension":202,"meta":203,"navigation":204,"path":205,"seo":206,"stem":207,"tags":208,"__hash__":214},"feeds\u002Ffeeds\u002F2026-06-03-signature.md","2026 06 03 Signature",{"type":100,"value":101,"toc":192},"minimark",[102,107,114,119,135,148,155,165,168,172,175,178,181,184,187],[103,104,106],"h2",{"id":105},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[108,109,110],"blockquote",{},[111,112,113],"p",{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[115,116,118],"h3",{"id":117},"실무에서-만나는-곳","실무에서 만나는 곳",[120,121,122,126,129,132],"ul",{},[123,124,125],"li",{},"JWT 서명 (HS256, RS256)",[123,127,128],{},"웹훅 검증 (Stripe, GitHub 등)",[123,130,131],{},"서버 간 API 인증",[123,133,134],{},"AWS SigV4 요청 서명",[115,136,138,139,143,144,147],{"id":137},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[140,141,142],"code",{},"누가 보냈는지","와 ",[140,145,146],{},"내용이 안 바뀌었는지","를 증명한다",[111,149,150,151,154],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[140,152,153],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[111,156,157,158,161,162,164],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[140,159,160],{},"인증","), 중간에 변조되지 않았다(",[140,163,153],{},")\"를 증명한다.",[111,166,167],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[115,169,171],{"id":170},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[111,173,174],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[111,176,177],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[111,179,180],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[182,183],"br",{},[111,185,186],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[108,188,189],{},[111,190,191],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":53,"searchDepth":193,"depth":193,"links":194},3,[195],{"id":105,"depth":28,"text":106,"children":196},[197,198,200],{"id":117,"depth":193,"text":118},{"id":137,"depth":193,"text":199},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":170,"depth":193,"text":171},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":53},"feeds\u002F2026-06-03-signature",[209,210,211,212,213],"보안","백엔드","서명","HMAC","JWT","daCzdI8pZQRjnS280-A0_pWA--NQ7kXLUxftQzuK1jU",{"id":216,"title":217,"body":218,"date":295,"description":53,"extension":202,"meta":296,"navigation":204,"path":297,"seo":298,"stem":299,"tags":300,"__hash__":303},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":100,"value":219,"toc":288},[220,224,229,231,245,249,252,255,258,262,265,268,271,274,276,283],[103,221,223],{"id":222},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[108,225,226],{},[111,227,228],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[115,230,118],{"id":117},[120,232,233,236,239,242],{},[123,234,235],{},"비밀번호 저장",[123,237,238],{},"파일 무결성 검증",[123,240,241],{},"캐시 키 생성",[123,243,244],{},"Git 커밋 식별자",[115,246,248],{"id":247},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[111,250,251],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[111,253,254],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[111,256,257],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[115,259,261],{"id":260},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[111,263,264],{},"SHA-256은 매우 빠른 알고리즘이다.",[111,266,267],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[111,269,270],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[111,272,273],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[182,275],{},[111,277,278,279,282],{},"대표 알고리즘: SHA-256·SHA-512(",[140,280,281],{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[108,284,285],{},[111,286,287],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":53,"searchDepth":193,"depth":193,"links":289},[290],{"id":222,"depth":28,"text":223,"children":291},[292,293,294],{"id":117,"depth":193,"text":118},{"id":247,"depth":193,"text":248},{"id":260,"depth":193,"text":261},"2026-06-03T15:30:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-hash",{"description":53},"feeds\u002F2026-06-03-hash",[209,301,302],"암호기초","해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":305,"title":306,"body":307,"date":378,"description":53,"extension":202,"meta":379,"navigation":204,"path":380,"seo":381,"stem":382,"tags":383,"__hash__":385},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":100,"value":308,"toc":371},[309,313,318,320,331,335,338,348,354,358,361,363,366],[103,310,312],{"id":311},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[108,314,315],{},[111,316,317],{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[115,319,118],{"id":117},[120,321,322,325,328],{},[123,323,324],{},"전송 구간 암호화: HTTPS\u002FTLS",[123,326,327],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[123,329,330],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[115,332,334],{"id":333},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[111,336,337],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[120,339,340,343],{},[123,341,342],{},"필요하다 → 암호화",[123,344,345,346],{},"필요하지 않다 → ",[140,347,302],{},[111,349,350,351,353],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[140,352,302],{},"를 사용한다.(다음편)",[115,355,357],{"id":356},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[111,359,360],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[182,362],{},[111,364,365],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[108,367,368],{},[111,369,370],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":53,"searchDepth":193,"depth":193,"links":372},[373],{"id":311,"depth":28,"text":312,"children":374},[375,376,377],{"id":117,"depth":193,"text":118},{"id":333,"depth":193,"text":334},{"id":356,"depth":193,"text":357},"2026-06-03T15:20:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encryption",{"description":53},"feeds\u002F2026-06-03-encryption",[209,301,384],"암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":387,"title":388,"body":389,"date":474,"description":53,"extension":202,"meta":475,"navigation":204,"path":476,"seo":477,"stem":478,"tags":479,"__hash__":482},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":100,"value":390,"toc":466},[391,395,400,402,424,428,431,434,438,449,453,456,458,461],[103,392,394],{"id":393},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[108,396,397],{},[111,398,399],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[115,401,118],{"id":117},[120,403,404,415,418,421],{},[123,405,406,407,410,411,414],{},"JWT의 ",[140,408,409],{},"header",", ",[140,412,413],{},"payload"," (Base64URL)",[123,416,417],{},"URL의 한글·특수문자 (Percent-Encoding)",[123,419,420],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[123,422,423],{},"바이너리를 로그·DB에 저장할 때",[115,425,427],{"id":426},"왜-사용할까","왜 사용할까?",[111,429,430],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[111,432,433],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[115,435,437],{"id":436},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[111,439,406,440,143,442,444,445,448],{},[140,441,409],{},[140,443,413],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[140,446,447],{},"서명(Signature)"," 에서 나온다.",[115,450,452],{"id":451},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[111,454,455],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[182,457],{},[111,459,460],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[108,462,463],{},[111,464,465],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":53,"searchDepth":193,"depth":193,"links":467},[468],{"id":393,"depth":28,"text":394,"children":469},[470,471,472,473],{"id":117,"depth":193,"text":118},{"id":426,"depth":193,"text":427},{"id":436,"depth":193,"text":437},{"id":451,"depth":193,"text":452},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":53},"feeds\u002F2026-06-03-encoding",[209,210,480,481,213],"인코딩","Base64","Sq2598RzaFZXqN7EZqu85x2WRdigojLrlU9euESHMOQ",{"id":484,"title":485,"body":486,"date":726,"description":53,"extension":202,"meta":727,"navigation":204,"path":728,"seo":729,"stem":730,"tags":731,"__hash__":732},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":100,"value":487,"toc":716},[488,492,495,602,606,611,622,626,637,640,651,654,659,662,666,681,684,692,695,699],[115,489,491],{"id":490},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[111,493,494],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[496,497,498,520],"table",{},[499,500,501],"thead",{},[502,503,504,508,511,514,517],"tr",{},[505,506,507],"th",{},"구분",[505,509,510],{},"목적",[505,512,513],{},"방향성",[505,515,516],{},"키",[505,518,519],{},"대표 알고리즘",[521,522,523,547,566,584],"tbody",{},[502,524,525,531,538,541,544],{},[526,527,528],"td",{},[140,529,530],{},"인코딩 (Encoding)",[526,532,533,534],{},"형식 변환 ",[535,536,537],"em",{},"(보안 아님)",[526,539,540],{},"양방향 (키 불필요)",[526,542,543],{},"x",[526,545,546],{},"Base64, Base64URL, Hex",[502,548,549,554,557,560,563],{},[526,550,551],{},[140,552,553],{},"양방향 암호화 (Encryption)",[526,555,556],{},"기밀성 — 내용 숨기기",[526,558,559],{},"양방향 (복호화 가능)",[526,561,562],{},"o",[526,564,565],{},"AES(대칭키), RSA(비대칭키)",[502,567,568,573,576,579,581],{},[526,569,570],{},[140,571,572],{},"해시 (Hash)",[526,574,575],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[526,577,578],{},"단방향 (복원 불가)",[526,580,543],{},[526,582,583],{},"SHA-256, SHA-512, SHA-3",[502,585,586,591,594,597,599],{},[526,587,588],{},[140,589,590],{},"서명 (Signature)",[526,592,593],{},"무결성 + 인증 — 위변조 + 출처",[526,595,596],{},"단방향 (해시 기반)",[526,598,562],{},[526,600,601],{},"HMAC-SHA256(HS256), RS256, ES256",[115,603,605],{"id":604},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[607,608,610],"h4",{"id":609},"인코딩-암호화","인코딩 ≠ 암호화",[120,612,613,616,619],{},[123,614,615],{},"Base64는 키가 없다.",[123,617,618],{},"누구나 디코딩할 수 있다.",[123,620,621],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[607,623,625],{"id":624},"해시-서명","해시 ≠ 서명",[120,627,628,631,634],{},[123,629,630],{},"해시는 데이터의 지문을 생성한다.",[123,632,633],{},"같은 입력은 항상 같은 해시값을 만든다.",[123,635,636],{},"데이터가 변경되면 해시값도 달라진다.",[111,638,639],{},"반면 서명은",[120,641,642,645,648],{},[123,643,644],{},"해시에 키를 결합하여 생성한다.",[123,646,647],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[123,649,650],{},"누가 생성했는지까지 검증할 수 있다.",[111,652,653],{},"즉,",[108,655,656],{},[111,657,658],{},"서명(Signature) = 해시(Hash) + 키(Key)",[111,660,661],{},"라고 생각하면 이해하기 쉽다.",[607,663,665],{"id":664},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[111,667,406,668,671,672,675,676,680],{},[140,669,670],{},"HS256","은 ",[140,673,674],{},"HMAC-SHA256","을 사용하는 ",[677,678,679],"strong",{},"서명 알고리즘","이다.",[111,682,683],{},"토큰 내용을 숨기는 것이 아니라,",[120,685,686,689],{},[123,687,688],{},"토큰이 위조되지 않았는지",[123,690,691],{},"신뢰할 수 있는 발급자가 만들었는지",[111,693,694],{},"를 검증하기 위해 사용된다.",[115,696,698],{"id":697},"한-줄-요약","한 줄 요약",[108,700,701],{},[111,702,703,704,706,707,709,710,712,713,715],{},"형식만 바꾸면 ",[677,705,480],{},", 숨기면 ",[677,708,384],{},", 지문(위\u002F변조검사) 찍으면 ",[677,711,302],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[677,714,211],{},".",{"title":53,"searchDepth":193,"depth":193,"links":717},[718,719,725],{"id":490,"depth":193,"text":491},{"id":604,"depth":193,"text":605,"children":720},[721,723,724],{"id":609,"depth":722,"text":610},4,{"id":624,"depth":722,"text":625},{"id":664,"depth":722,"text":665},{"id":697,"depth":193,"text":698},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":53},"feeds\u002F2026-06-03-crypto-basics",[209,480,384,302,211],"DiJZVjRCgtWgXEW1t3eXSnpdeyUQmyB_r7uG-8JAGfk",{"id":734,"title":735,"body":736,"date":786,"description":740,"extension":202,"meta":787,"navigation":204,"path":788,"seo":789,"stem":790,"tags":791,"__hash__":793},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":100,"value":737,"toc":783},[738,741,744,750,753,760,765,768,774,777,780],[111,739,740],{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[111,742,743],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[745,746,747],"ol",{},[123,748,749],{},"JWT 방식",[111,751,752],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[111,754,755],{},[756,757],"img",{"alt":758,"src":759},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[745,761,762],{"start":28},[123,763,764],{},"HMAC (Hash-based Message Authentication Code)",[111,766,767],{},"서버 간에 시크릿 키를 공유한다.\n요청 하는 서버는 요청 정보(Request Body 등)를 시크릿 키를 이용해 해시 기반 서명값(MAC)으로 변환하고, 그 값을 \"헤더에 담아 전송\"한다.\n요청을 받은 서버는 요청 정보(Request Body 등) 을 동일한 시크릿 키로 해시 기반 서명값(MAC)으로 변환하고, \"그 결과가 헤더의 값과 같은지 확인하여 검증\"한다.",[111,769,770],{},[756,771],{"alt":772,"src":773},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[111,775,776],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[103,778,779],{"id":779},"정리",[111,781,782],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":53,"searchDepth":193,"depth":193,"links":784},[785],{"id":779,"depth":28,"text":779},"2026-06-01T20:36:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-hmac",{"description":740},"feeds\u002F2026-06-01-hmac",[209,792,212,213],"네트워크","f229CVTvv20IYHmale0GxOtq9gGfj6GwVHokCgATK-g",1780808014017]