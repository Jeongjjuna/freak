428],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[312,430,431],{},[120,432,433],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":54,"searchDepth":201,"depth":201,"links":435},[436],{"id":354,"depth":28,"text":355,"children":437},[438,439,441],{"id":363,"depth":201,"text":364},{"id":381,"depth":201,"text":440},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":412,"depth":201,"text":413},"2026-06-03T15:40:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-signature",{"description":54},"feeds\u002F2026-06-03-signature",[82,448,449,450,451,101,81],"암호기초","백엔드","서명","HMAC","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":454,"title":455,"body":456,"date":533,"description":54,"extension":338,"meta":534,"navigation":210,"path":535,"seo":536,"stem":537,"tags":538,"__hash__":540},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":107,"value":457,"toc":526},[458,462,467,469,483,487,490,493,496,500,503,506,509,512,514,521],[110,459,461],{"id":460},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[312,463,464],{},[120,465,466],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[115,468,364],{"id":363},[132,470,471,474,477,480],{},[135,472,473],{},"비밀번호 저장",[135,475,476],{},"파일 무결성 검증",[135,478,479],{},"캐시 키 생성",[135,481,482],{},"Git 커밋 식별자",[115,484,486],{"id":485},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[120,488,489],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[120,491,492],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[120,494,495],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[115,497,499],{"id":498},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[120,501,502],{},"SHA-256은 매우 빠른 알고리즘이다.",[120,504,505],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[120,507,508],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[120,510,511],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[424,513],{},[120,515,516,517,520],{},"대표 알고리즘: SHA-256·