te 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[70,90,83,91],"AOP","Transaction","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[94,96],{"slug":76,"title":77,"date":78,"category":38,"tags":95,"excerpt":54,"thumbnail":84},[80,81,70,82,83],{"slug":97,"title":98,"date":99,"category":34,"tags":100,"excerpt":54,"thumbnail":84},"jwt-authentication","[Example] JWT 인증 구현과 refresh token 전략","2025-07-28",[101,82,70,81],"JWT",[103,220,308,390,486,736],{"id":104,"title":105,"body":106,"date":207,"description":54,"extension":208,"meta":209,"navigation":210,"path":211,"seo":212,"stem":213,"tags":214,"__hash__":219},"feeds\u002Ffeeds\u002F2026-06-03-signature.md","2026 06 03 Signature",{"type":107,"value":108,"toc":198},"minimark",[109,114,121,126,142,155,162,171,174,178,181,184,187,190,193],[110,111,113],"h2",{"id":112},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[115,116,117],"blockquote",{},[118,119,120],"p",{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[122,123,125],"h3",{"id":124},"실무에서-만나는-곳","실무에서 만나는 곳",[127,128,129,133,136,139],"ul",{},[130,131,132],"li",{},"JWT 서명 (HS256, RS256)",[130,134,135],{},"웹훅 검증 (Stripe, GitHub 등)",[130,137,138],{},"서버 간 API 인증",[130,140,141],{},"AWS SigV4 요청 서명",[122,143,145,146,150,151,154],{"id":144},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[147,148,149],"code",{},"누가 보냈는지","와 ",[147,152,153],{},"내용이 안 바뀌었는지","를 증명한다",[118,156,157,158,161],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[147,159,160],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[118,163,164,165,167,168,170],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[147,166,81],{},"), 중간에 변조되지 않았다(",[147,169,160],{},")\"를 증명한다.",[118,172,173],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[122,175,177],{"id":176},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[118,179,180],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[118,182,183],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[118,185,186],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[188,189],"br",{},[118,191,192],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[115,194,195],{},[118,196,197],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":54,"searchDepth":199,"depth":199,"links":200},3,[201],{"id":112,"depth":28,"text":113,"children":202},[203,204,206],{"id":124,"depth":199,"text":125},{"id":144,"depth":199,"text":205},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":176,"depth":199,"text":177},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":54},"feeds\u002F2026-06-03-signature",[82,215,216,217,218,101,81],"암호기초","백엔드","서명","HMAC","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":221,"title":222,"body":223,"date":300,"description":54,"extension":208,"meta":301,"navigation":210,"path":302,"seo":303,"stem":304,"tags":305,"__hash__":307},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":107,"value":224,"toc":293},[225,229,234,236,250,254,257,260,263,267,270,273,276,279,281,288],[110,226,228],{"id":227},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[115,230,231],{},[118,232,233],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[122,235,125],{"id":124},[127,237,238,241,244,247],{},[130,239,240],{},"비밀번호 저장",[130,242,243],{},"파일 무결성 검증",[130,245,246],{},"캐시 키 생성",[130,248,249],{},"Git 커밋 식별자",[122,251,253],{"id":252},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[118,255,256],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[118,258,259],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[118,261,262],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[122,264,266],{"id":265},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[118,268,269],{},"SHA-256은 매우 빠른 알고리즘이다.",[118,271,272],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[118,274,275],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[118,277,278],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[188,280],{},[118,282,283,284,287],{},"대표 알고리즘: SHA-256·SHA-512(",[147,285,286],{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[115,289,290],{},[118,291,292],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":54,"searchDepth":199,"depth":199,"links":294},[295],{"id":227,"depth":28,"text":228,"children":296},[297,298,299],{"id":124,"depth":199,"text":125},{"id":252,"depth":199,"text":253},{"id":265,"depth":199,"text":266},"2026-06-03T15:30:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-hash",{"description":54},"feeds\u002F2026-06-03-hash",[82,215,306],"해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":309,"title":310,"body":311,"date":382,"description":54,"extension":208,"meta":383,"navigation":210,"path":384,"seo":385,"stem":386,"tags":387,"__hash__":389},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":107,"value":312,"toc":375},[313,317,322,324,335,339,342,352,358,362,365,367,370],[110,314,316],{"id":315},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[115,318,319],{},[118,320,321],{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[122,323,125],{"id":124},[127,325,326,329,332],{},[130,327,328],{},"전송 구간 암호화: HTTPS\u002FTLS",[130,330,331],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[130,333,334],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[122,336,338],{"id":337},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[118,340,341],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[127,343,344,347],{},[130,345,346],{},"필요하다 → 암호화",[130,348,349,350],{},"필요하지 않다 → ",[147,351,306],{},[118,353,354,355,357],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[147,356,306],{},"를 사용한다.(다음편)",[122,359,361],{"id":360},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[118,363,364],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[188,366],{},[118,368,369],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[115,371,372],{},[118,373,374],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":54,"searchDepth":199,"depth":199,"links":376},[377],{"id":315,"depth":28,"text":316,"children":378},[379,380,381],{"id":124,"depth":199,"text":125},{"id":337,"depth":199,"text":338},{"id":360,"depth":199,"text":361},"2026-06-03T15:20:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encryption",{"description":54},"feeds\u002F2026-06-03-encryption",[82,215,388],"암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":391,"title":392,"body":393,"date":478,"description":54,"extension":208,"meta":479,"navigation":210,"path":480,"seo":481,"stem":482,"tags":483,"__hash__":485},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":107,"value":394,"toc":470},[395,399,404,406,428,432,435,438,442,453,457,460,462,465],[110,396,398],{"id":397},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[115,400,401],{},[118,402,403],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[122,405,125],{"id":124},[127,407,408,419,422,425],{},[130,409,410,411,414,415,418],{},"JWT의 ",[147,412,413],{},"header",", ",[147,416,417],{},"payload"," (Base64URL)",[130,420,421],{},"URL의 한글·특수문자 (Percent-Encoding)",[130,423,424],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[130,426,427],{},"바이너리를 로그·DB에 저장할 때",[122,429,431],{"id":430},"왜-사용할까","왜 사용할까?",[118,433,434],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[118,436,437],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[122,439,441],{"id":440},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[118,443,410,444,150,446,448,449,452],{},[147,445,413],{},[147,447,417],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[147,450,451],{},"서명(Signature)"," 에서 나온다.",[122,454,456],{"id":455},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[118,458,459],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[188,461],{},[118,463,464],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[115,466,467],{},[118,468,469],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":54,"searchDepth":199,"depth":199,"links":471},[472],{"id":397,"depth":28,"text":398,"children":473},[474,475,476,477],{"id":124,"depth":199,"text":125},{"id":430,"depth":199,"text":431},{"id":440,"depth":199,"text":441},{"id":455,"depth":199,"text":456},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":54},"feeds\u002F2026-06-03-encoding",[82,215,216,484,101],"인코딩","8I5ExkCcCxIM2o5tuh_mX4i-P-F6f_Sv4n747ziuqKA",{"id":487,"title":488,"body":489,"date":729,"description":54,"extension":208,"meta":730,"navigation":210,"path":731,"seo":732,"stem":733,"tags":734,"__hash__":735},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":107,"value":490,"toc":719},[491,495,498,605,609,614,625,629,640,643,654,657,662,665,669,684,687,695,698,702],[122,492,494],{"id":493},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[118,496,497],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[499,500,501,523],"table",{},[502,503,504],"thead",{},[505,506,507,511,514,517,520],"tr",{},[508,509,510],"th",{},"구분",[508,512,513],{},"목적",[508,515,516],{},"방향성",[508,518,519],{},"키",[508,521,522],{},"대표 알고리즘",[524,525,526,550,569,587],"tbody",{},[505,527,528,534,541,544,547],{},[529,530,531],"td",{},[147,532,533],{},"인코딩 (Encoding)",[529,535,536,537],{},"형식 변환 ",[538,539,540],"em",{},"(보안 아님)",[529,542,543],{},"양방향 (키 불필요)",[529,545,546],{},"x",[529,548,549],{},"Base64, Base64URL, Hex",[505,551,552,557,560,563,566],{},[529,553,554],{},[147,555,556],{},"양방향 암호화 (Encryption)",[529,558,559],{},"기밀성 — 내용 숨기기",[529,561,562],{},"양방향 (복호화 가능)",[529,564,565],{},"o",[529,567,568],{},"AES(대칭키), RSA(비대칭키)",[505,570,571,576,579,582,584],{},[529,572,573],{},[147,574,575],{},"해시 (Hash)",[529,577,578],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[529,580,581],{},"단방향 (복원 불가)",[529,583,546],{},[529,585,586],{},"SHA-256, SHA-512, SHA-3",[505,588,589,594,597,600,602],{},[529,590,591],{},[147,592,593],{},"서명 (Signature)",[529,595,596],{},"무결성 + 인증 — 위변조 + 출처",[529,598,599],{},"단방향 (해시 기반)",[529,601,565],{},[529,603,604],{},"HMAC-SHA256(HS256), RS256, ES256",[122,606,608],{"id":607},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[610,611,613],"h4",{"id":612},"인코딩-암호화","인코딩 ≠ 암호화",[127,615,616,619,622],{},[130,617,618],{},"Base64는 키가 없다.",[130,620,621],{},"누구나 디코딩할 수 있다.",[130,623,624],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[610,626,628],{"id":627},"해시-서명","해시 ≠ 서명",[127,630,631,634,637],{},[130,632,633],{},"해시는 데이터의 지문을 생성한다.",[130,635,636],{},"같은 입력은 항상 같은 해시값을 만든다.",[130,638,639],{},"데이터가 변경되면 해시값도 달라진다.",[118,641,642],{},"반면 서명은",[127,644,645,648,651],{},[130,646,647],{},"해시에 키를 결합하여 생성한다.",[130,649,650],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[130,652,653],{},"누가 생성했는지까지 검증할 수 있다.",[118,655,656],{},"즉,",[115,658,659],{},[118,660,661],{},"서명(Signature) = 해시(Hash) + 키(Key)",[118,663,664],{},"라고 생각하면 이해하기 쉽다.",[610,666,668],{"id":667},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[118,670,410,671,674,675,678,679,683],{},[147,672,673],{},"HS256","은 ",[147,676,677],{},"HMAC-SHA256","을 사용하는 ",[680,681,682],"strong",{},"서명 알고리즘","이다.",[118,685,686],{},"토큰 내용을 숨기는 것이 아니라,",[127,688,689,692],{},[130,690,691],{},"토큰이 위조되지 않았는지",[130,693,694],{},"신뢰할 수 있는 발급자가 만들었는지",[118,696,697],{},"를 검증하기 위해 사용된다.",[122,699,701],{"id":700},"한-줄-요약","한 줄 요약",[115,703,704],{},[118,705,706,707,709,710,712,713,715,716,718],{},"형식만 바꾸면 ",[680,708,484],{},", 숨기면 ",[680,711,388],{},", 지문(위\u002F변조검사) 찍으면 ",[680,714,306],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[680,717,217],{},".",{"title":54,"searchDepth":199,"depth":199,"links":720},[721,722,728],{"id":493,"depth":199,"text":494},{"id":607,"depth":199,"text":608,"children":723},[724,726,727],{"id":612,"depth":725,"text":613},4,{"id":627,"depth":725,"text":628},{"id":667,"depth":725,"text":668},{"id":700,"depth":199,"text":701},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":54},"feeds\u002F2026-06-03-crypto-basics",[82,215,484,388,306,217],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",{"id":737,"title":738,"body":739,"date":789,"description":743,"extension":208,"meta":790,"navigation":210,"path":791,"seo":792,"stem":793,"tags":794,"__hash__":796},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":107,"value":740,"toc":786},[741,744,747,753,756,763,768,771,777,780,783],[118,742,743],{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[118,745,746],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[748,749,750],"ol",{},[130,751,752],{},"JWT 방식",[118,754,755],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[118,757,758],{},[759,760],"img",{"alt":761,"src":762},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[748,764,765],{"start":28},[130,766,767],{},"HMAC (Hash-based Message Authentication Code)",[118,769,770],{},"서버 간에 시크릿 키를 공유한다.\n요청 하는 서버는 요청 정보(Request Body 등)를 시크릿 키를 이용해 해시 기반 서명값(MAC)으로 변환하고, 그 값을 \"헤더에 담아 전송\"한다.\n요청을 받은 서버는 요청 정보(Request Body 등) 을 동일한 시크릿 키로 해시 기반 서명값(MAC)으로 변환하고, \"그 결과가 헤더의 값과 같은지 확인하여 검증\"한다.",[118,772,773],{},[759,774],{"alt":775,"src":776},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[118,778,779],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[110,781,782],{"id":782},"정리",[118,784,785],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":54,"searchDepth":199,"depth":199,"links":787},[788],{"id":782,"depth":28,"text":782},"2026-06-01T20:36:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-hmac",{"description":743},"feeds\u002F2026-06-01-hmac",[82,795,218,101,81],"네트워크","mJQJW2YkEiLfOXtm6jWO4bEV6DvCkJ55q9yOyoAMhZY",1780814128872]