026-06-06-jwt-timing-attack",[102,57,530],"타이밍공격","zlU7I9OjDuMcw6bA44-64aQRv5KtORCOJZR7FZEju0Y",{"id":533,"title":534,"body":535,"date":627,"description":59,"extension":345,"meta":628,"navigation":217,"path":629,"seo":630,"stem":631,"tags":632,"__hash__":637},"feeds\u002Ffeeds\u002F2026-06-03-signature.md","2026 06 03 Signature",{"type":114,"value":536,"toc":619},[537,541,546,550,564,576,583,592,595,599,602,605,608,611,614],[117,538,540],{"id":539},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[319,542,543],{},[127,544,545],{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[122,547,549],{"id":548},"실무에서-만나는-곳","실무에서 만나는 곳",[139,551,552,555,558,561],{},[142,553,554],{},"JWT 서명 (HS256, RS256)",[142,556,557],{},"웹훅 검증 (Stripe, GitHub 등)",[142,559,560],{},"서버 간 API 인증",[142,562,563],{},"AWS SigV4 요청 서명",[122,565,567,568,571,572,575],{"id":566},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[130,569,570],{},"누가 보냈는지","와 ",[130,573,574],{},"내용이 안 바뀌었는지","를 증명한다",[127,577,578,579,582],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[130,580,581],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[127,584,585,586,588,589,591],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[130,587,101],{},"), 중간에 변조되지 않았다(",[130,590,581],{},")\"를 증명한다.",[127,593,594],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[122,596,598],{"id":597},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[127,600,601],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[127,603,604],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[127,606,607],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[609,610],"br",{},[127,612,613],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[319,615,616],{},[127,617,618],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":59,"searchDepth":208,"depth":208,"links":620},[621],{"id":539,"depth":28,"text":540,"children":622},[623,624,626],{"id":548,"depth":208,"text":549},{"id":566,"depth":208,"text":625},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":597,"depth":208,"text":598},"2026-06-03T15:40:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-signature",{"description":59},"feeds\u002F2026-06-03-signature",[102,633,634,635,636,57,101],"암호기초","백엔드","서명","HMAC","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":639,"title":640,"body":641,"date":718,"description":59,"extension":345,"meta":719,"navigation":217,"path":720,"seo":721,"stem":722,"tags":723,"__hash__":725},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":114,"value":642,"toc":711},[643,647,652,654,668,672,675,678,681,685,688,691,694,697,699,706],[117,644,646],{"id":645},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[319,648,649],{},[127,650,651],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[122,653,549],{"id":548},[139,655,656,659,662,665],{},[142,657,658],{},"비밀번호 저장",[142,660,661],{},"파일 무결성 검증",[142,663,664],{},"캐시 키 생성",[142,666,667],{},"Git 커밋 식별자",[122,669,671],{"id":670},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[127,673,674],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[127,676,677],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[127,679,680],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[122,682,684],{"id":683},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[127,686,687],{},"SHA-256은 매우 빠른 알고리즘이다.",[127,689,690],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[127,692,693],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[127,695,696],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[609,698],{},[127,700,701,702,705],{},"대표 알고리즘: SHA-256·SHA-512(",[130,703,704],{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[319,707,708],{},[127,709,710],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":59,"searchDepth":208,"depth":208,"links":712},[713],{"id":645,"depth":28,"text":646,"children":714},[715,716,717],{"id":548,"depth":208,"text":549},{"id":670,"depth":208,"text":671},{"id":683,"depth":208,"text":684},"2026-06-03T15:30:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-hash",{"description":59},"feeds\u002F2026-06-03-hash",[102,633,724],"해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":727,"title":728,"body":729,"date":800,"description":59,"extension":345,"meta":801,"navigation":217,"path":802,"seo":803,"stem":804,"tags":805,"__hash__":807},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":114,"value":730,"toc":793},[731,735,740,742,753,757,760,770,776,780,783,785,788],[117,732,734],{"id":733},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[319,736,737],{},[127,738,739],{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[122,741,549],{"id":548},[139,743,744,747,750],{},[142,745,746],{},"전송 구간 암호화: HTTPS\u002FTLS",[142,748,749],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[142,751,752],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[122,754,756],{"id":755},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[127,758,759],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[139,761,762,765],{},[142,763,764],{},"필요하다 → 암호화",[142,766,767,768],{},"필요하지 않다 → ",[130,769,724],{},[127,771,772,773,775],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[130,774,724],{},"를 사용한다.(다음편)",[122,777,779],{"id":778},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[127,781,782],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[609,784],{},[127,786,787],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[319,789,790],{},[127,791,792],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":59,"searchDepth":208,"depth":208,"links":794},[795],{"id":733,"depth":28,"text":734,"children":796},[797,798,799],{"id":548,"depth":208,"text":549},{"id":755,"depth":208,"text":756},{"id":778,"depth":208,"text":779},"2026-06-03T15:20:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encryption",{"description":59},"feeds\u002F2026-06-03-encryption",[102,633,806],"암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":809,"title":810,"body":811,"date":896,"description":59,"extension":345,"meta":897,"navigation":217,"path":898,"seo":899,"stem":900,"tags":901,"__hash__":903},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":114,"value":812,"toc":888},[813,817,822,824,846,850,853,856,860,871,875,878,880,883],[117,814,816],{"id":815},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[319,818,819],{},[127,820,821],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[122,823,549],{"id":548},[139,825,826,837,840,843],{},[142,827,828,829,832,833,836],{},"JWT의 ",[130,830,831],{},"header",", ",[130,834,835],{},"payload"," (Base64URL)",[142,838,839],{},"URL의 한글·특수문자 (Percent-Encoding)",[142,841,842],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[142,844,845],{},"바이너리를 로그·DB에 저장할 때",[122,847,849],{"id":848},"왜-사용할까","왜 사용할까?",[127,851,852],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[127,854,855],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[122,857,859],{"id":858},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[127,861,828,862,571,864,866,867,870],{},[130,863,831],{},[130,865,835],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[130,868,869],{},"서명(Signature)"," 에서 나온다.",[122,872,874],{"id":873},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[127,876,877],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[609,879],{},[127,881,882],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[319,884,885],{},[127,886,887],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":59,"searchDepth":208,"depth":208,"links":889},[890],{"id":815,"depth":28,"text":816,"children":891},[892,893,894,895],{"id":548,"depth":208,"text":549},{"id":848,"depth":208,"text":849},{"id":858,"depth":208,"text":859},{"id":873,"depth":208,"text":874},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":59},"feeds\u002F2026-06-03-encoding",[102,633,634,902,57],"인코딩","8I5ExkCcCxIM2o5tuh_mX4i-P-F6f_Sv4n747ziuqKA",{"id":905,"title":906,"body":907,"date":1146,"description":59,"extension":345,"meta":1147,"navigation":217,"path":1148,"seo":1149,"stem":1150,"tags":1151,"__hash__":1152},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":114,"value":908,"toc":1137},[909,913,916,1023,1027,1032,1043,1047,1058,1061,1072,1075,1080,1083,1087,1102,1105,1113,1116,1120],[122,910,912],{"id":911},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[127,914,915],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[917,918,919,941],"table",{},[920,921,922],"thead",{},[923,924,925,929,932,935,938],"tr",{},[926,927,928],"th",{},"구분",[926,930,931],{},"목적",[926,933,934],{},"방향성",[926,936,937],{},"키",[926,939,940],{},"대표 알고리즘",[942,943,944,968,987,1005],"tbody",{},[923,945,946,952,959,962,965],{},[947,948,949],"td",{},[130,950,951],{},"인코딩 (Encoding)",[947,953,954,955],{},"형식 변환 ",[956,957,958],"em",{},"(보안 아님)",[947,960,961],{},"양방향 (키 불필요)",[947,963,964],{},"x",[947,966,967],{},"Base64, Base64URL, Hex",[923,969,970,975,978,981,984],{},[947,971,972],{},[130,973,974],{},"양방향 암호화 (Encryption)",[947,976,977],{},"기밀성 — 내용 숨기기",[947,979,980],{},"양방향 (복호화 가능)",[947,982,983],{},"o",[947,985,986],{},"AES(대칭키), RSA(비대칭키)",[923,988,989,994,997,1000,1002],{},[947,990,991],{},[130,992,993],{},"해시 (Hash)",[947,995,996],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[947,998,999],{},"단방향 (복원 불가)",[947,1001,964],{},[947,1003,1004],{},"SHA-256, SHA-512, SHA-3",[923,1006,1007,1012,1015,1018,1020],{},[947,1008,1009],{},[130,1010,1011],{},"서명 (Signature)",[947,1013,1014],{},"무결성 + 인증 — 위변조 + 출처",[947,1016,1017],{},"단방향 (해시 기반)",[947,1019,983],{},[947,1021,1022],{},"HMAC-SHA256(HS256), RS256, ES256",[122,1024,1026],{"id":1025},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[1028,1029,1031],"h4",{"id":1030},"인코딩-암호화","인코딩 ≠ 암호화",[139,1033,1034,1037,1040],{},[142,1035,1036],{},"Base64는 키가 없다.",[142,1038,1039],{},"누구나 디코딩할 수 있다.",[142,1041,1042],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[1028,1044,1046],{"id":1045},"해시-서명","해시 ≠ 서명",[139,1048,1049,1052,1055],{},[142,1050,1051],{},"해시는 데이터의 지문을 생성한다.",[142,1053,1054],{},"같은 입력은 항상 같은 해시값을 만든다.",[142,1056,1057],{},"데이터가 변경되면 해시값도 달라진다.",[127,1059,1060],{},"반면 서명은",[139,1062,1063,1066,1069],{},[142,1064,1065],{},"해시에 키를 결합하여 생성한다.",[142,1067,1068],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[142,1070,1071],{},"누가 생성했는지까지 검증할 수 있다.",[127,1073,1074],{},"즉,",[319,1076,1077],{},[127,1078,1079],{},"서명(Signature) = 해시(Hash) + 키(Key)",[127,1081,1082],{},"라고 생각하면 이해하기 쉽다.",[1028,1084,1086],{"id":1085},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[127,1088,828,1089,1092,1093,1096,1097,1101],{},[130,1090,1091],{},"HS256","은 ",[130,1094,1095],{},"HMAC-SHA256","을 사용하는 ",[1098,1099,1100],"strong",{},"서명 알고리즘","이다.",[127,1103,1104],{},"토큰 내용을 숨기는 것이 아니라,",[139,1106,1107,1110],{},[142,1108,1109],{},"토큰이 위조되지 않았는지",[142,1111,1112],{},"신뢰할 수 있는 발급자가 만들었는지",[127,1114,1115],{},"를 검증하기 위해 사용된다.",[122,1117,1119],{"id":1118},"한-줄-요약","한 줄 요약",[319,1121,1122],{},[127,1123,1124,1125,1127,1128,1130,1131,1133,1134,1136],{},"형식만 바꾸면 ",[1098,1126,902],{},", 숨기면 ",[1098,1129,806],{},", 지문(위\u002F변조검사) 찍으면 ",[1098,1132,724],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[1098,1135,635],{},".",{"title":59,"searchDepth":208,"depth":208,"links":1138},[1139,1140,1145],{"id":911,"depth":208,"text":912},{"id":1025,"depth":208,"text":1026,"children":1141},[1142,1143,1144],{"id":1030,"depth":214,"text":1031},{"id":1045,"depth":214,"text":1046},{"id":1085,"depth":214,"text":1086},{"id":1118,"depth":208,"text":1119},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":59},"feeds\u002F2026-06-03-crypto-basics",[102,633,902,806,724,635],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",{"id":1154,"title":1155,"body":1156,"date":1206,"description":1160,"extension":345,"meta":1207,"navigation":217,"path":1208,"seo":1209,"stem":1210,"tags":1211,"__hash__":1213},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":114,"value":1157,"toc":1203},[1158,1161,1164,1170,1173,1180,1185,1188,1194,1197,1200],[127,1159,1160],{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[127,1162,1163],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[1165,1166,1167],"ol",{},[142,1168,1169],{},"JWT 방식",[127,1171,1172],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[127,1174,1175],{},[1176,1177],"img",{"alt":1178,"src":1179},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[1165,1181,1182],{"start":28},[142,1183,1184],{},"HMAC (Hash-based Message Authentication Code)",[127,1186,1187],{},"서버 간에 시크릿 키를 공유한다.\n요청 하는 서버는 요청 정보(Request Body 등)를 시크릿 키를 이용해 해시 기반 서명값(MAC)으로 변환하고, 그 값을 \"헤더에 담아 전송\"한다.\n요청을 받은 서버는 요청 정보(Request Body 등) 을 동일한 시크릿 키로 해시 기반 서명값(MAC)으로 변환하고, \"그 결과가 헤더의 값과 같은지 확인하여 검증\"한다.",[127,1189,1190],{},[1176,1191],{"alt":1192,"src":1193},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[127,1195,1196],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[117,1198,1199],{"id":1199},"정리",[127,1201,1202],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":59,"searchDepth":208,"depth":208,"links":1204},[1205],{"id":1199,"depth":28,"text":1199},"2026-06-01T20:36:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-hmac",{"description":1160},"feeds\u002F2026-06-01-hmac",[102,1212,636,57,101],"네트워크","mJQJW2YkEiLfOXtm6jWO4bEV6DvCkJ55q9yOyoAMhZY",1780828888232]