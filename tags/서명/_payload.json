경되면 해시값도 달라진다.",[91,351,352],{},"반면 서명은",[100,354,355,358,361],{},[103,356,357],{},"해시에 키를 결합하여 생성한다.",[103,359,360],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[103,362,363],{},"누가 생성했는지까지 검증할 수 있다.",[91,365,366],{},"즉,",[88,368,369],{},[91,370,371],{},"서명(Signature) = 해시(Hash) + 키(Key)",[91,373,374],{},"라고 생각하면 이해하기 쉽다.",[320,376,378],{"id":377},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[91,380,381,382,385,386,389,390,394],{},"JWT의 ",[120,383,384],{},"HS256","은 ",[120,387,388],{},"HMAC-SHA256","을 사용하는 ",[391,392,393],"strong",{},"서명 알고리즘","이다.",[91,396,397],{},"토큰 내용을 숨기는 것이 아니라,",[100,399,400,403],{},[103,401,402],{},"토큰이 위조되지 않았는지",[103,404,405],{},"신뢰할 수 있는 발급자가 만들었는지",[91,407,408],{},"를 검증하기 위해 사용된다.",[95,410,412],{"id":411},"한-줄-요약","한 줄 요약",[88,414,415],{},[91,416,417,418,421,422,425,426,429,430,432],{},"형식만 바꾸면 ",[391,419,420],{},"인코딩",", 숨기면 ",[391,423,424],{},"암호화",", 지문(위\u002F변조검사) 찍으면 ",[391,427,428],{},"해시",", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[391,431,193],{},".",{"title":38,"searchDepth":173,"depth":173,"links":434},[435,436,442],{"id":203,"depth":173,"text":204},{"id":317,"depth":173,"text":318,"children":437},[438,440,441],{"id":322,"depth":439,"text":323},4,{"id":337,"depth":439,"text":338},{"id":377,"depth":439,"text":378},{"id":411,"depth":173,"text":412},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":38},"feeds\u002F2026-06-03-crypto-basics",[190,191,420,424,428,193],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1782923313179]