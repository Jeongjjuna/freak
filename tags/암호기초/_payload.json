ent)","2026-04-08",[50,89,90,91,92],"Spring","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",[],[96,215,303,385,481],{"id":97,"title":98,"body":99,"date":201,"description":59,"extension":202,"meta":203,"navigation":204,"path":205,"seo":206,"stem":207,"tags":208,"__hash__":214},"feeds\u002Ffeeds\u002F2026-06-03-signature.md","2026 06 03 Signature",{"type":100,"value":101,"toc":192},"minimark",[102,107,114,119,135,148,155,165,168,172,175,178,181,184,187],[103,104,106],"h2",{"id":105},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[108,109,110],"blockquote",{},[111,112,113],"p",{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[115,116,118],"h3",{"id":117},"실무에서-만나는-곳","실무에서 만나는 곳",[120,121,122,126,129,132],"ul",{},[123,124,125],"li",{},"JWT 서명 (HS256, RS256)",[123,127,128],{},"웹훅 검증 (Stripe, GitHub 등)",[123,130,131],{},"서버 간 API 인증",[123,133,134],{},"AWS SigV4 요청 서명",[115,136,138,139,143,144,147],{"id":137},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[140,141,142],"code",{},"누가 보냈는지","와 ",[140,145,146],{},"내용이 안 바뀌었는지","를 증명한다",[111,149,150,151,154],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[140,152,153],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[111,156,157,158,161,162,164],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[140,159,160],{},"인증","), 중간에 변조되지 않았다(",[140,163,153],{},")\"를 증명한다.",[111,166,167],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[115,169,171],{"id":170},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[111,173,174],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[111,176,177],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[111,179,180],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[182,183],"br",{},[111,185,186],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[108,188,189],{},[111,190,191],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":59,"searchDepth":193,"depth":193,"links":194},3,[195],{"id":105,"depth":28,"text":106,"children":196},[197,198,200],{"id":117,"depth":193,"text":118},{"id":137,"depth":193,"text":199},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":170,"depth":193,"text":171},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":59},"feeds\u002F2026-06-03-signature",[209,210,211,212,213,57,160],"보안","암호기초","백엔드","서명","HMAC","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":216,"title":217,"body":218,"date":295,"description":59,"extension":202,"meta":296,"navigation":204,"path":297,"seo":298,"stem":299,"tags":300,"__hash__":302},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":100,"value":219,"toc":288},[220,224,229,231,245,249,252,255,258,262,265,268,271,274,276,283],[103,221,223],{"id":222},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[108,225,226],{},[111,227,228],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[115,230,118],{"id":117},[120,232,233,236,239,242],{},[123,234,235],{},"비밀번호 저장",[123,237,238],{},"파일 무결성 검증",[123,240,241],{},"캐시 키 생성",[123,243,244],{},"Git 커밋 식별자",[115,246,248],{"id":247},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[111,250,251],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[111,253,254],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[111,256,257],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[115,259,261],{"id":260},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[111,263,264],{},"SHA-256은 매우 빠른 알고리즘이다.",[111,266,267],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[111,269,270],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[111,272,273],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[182,275],{},[111,277,278,279,282],{},"대표 알고리즘: SHA-256·SHA-512(",[140,280,281],{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[108,284,285],{},[111,286,287],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":59,"searchDepth":193,"depth":193,"links":289},[290],{"id":222,"depth":28,"text":223,"children":291},[292,293,294],{"id":117,"depth":193,"text":118},{"id":247,"depth":193,"text":248},{"id":260,"depth":193,"text":261},"2026-06-03T15:30:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-hash",{"description":59},"feeds\u002F2026-06-03-hash",[209,210,301],"해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":304,"title":305,"body":306,"date":377,"description":59,"extension":202,"meta":378,"navigation":204,"path":379,"seo":380,"stem":381,"tags":382,"__hash__":384},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":100,"value":307,"toc":370},[308,312,317,319,330,334,337,347,353,357,360,362,365],[103,309,311],{"id":310},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[108,313,314],{},[111,315,316],{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[115,318,118],{"id":117},[120,320,321,324,327],{},[123,322,323],{},"전송 구간 암호화: HTTPS\u002FTLS",[123,325,326],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[123,328,329],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[115,331,333],{"id":332},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[111,335,336],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[120,338,339,342],{},[123,340,341],{},"필요하다 → 암호화",[123,343,344,345],{},"필요하지 않다 → ",[140,346,301],{},[111,348,349,350,352],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[140,351,301],{},"를 사용한다.(다음편)",[115,354,356],{"id":355},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[111,358,359],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[182,361],{},[111,363,364],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[108,366,367],{},[111,368,369],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":59,"searchDepth":193,"depth":193,"links":371},[372],{"id":310,"depth":28,"text":311,"children":373},[374,375,376],{"id":117,"depth":193,"text":118},{"id":332,"depth":193,"text":333},{"id":355,"depth":193,"text":356},"2026-06-03T15:20:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encryption",{"description":59},"feeds\u002F2026-06-03-encryption",[209,210,383],"암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":386,"title":387,"body":388,"date":473,"description":59,"extension":202,"meta":474,"navigation":204,"path":475,"seo":476,"stem":477,"tags":478,"__hash__":480},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":100,"value":389,"toc":465},[390,394,399,401,423,427,430,433,437,448,452,455,457,460],[103,391,393],{"id":392},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[108,395,396],{},[111,397,398],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[115,400,118],{"id":117},[120,402,403,414,417,420],{},[123,404,405,406,409,410,413],{},"JWT의 ",[140,407,408],{},"header",", ",[140,411,412],{},"payload"," (Base64URL)",[123,415,416],{},"URL의 한글·특수문자 (Percent-Encoding)",[123,418,419],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[123,421,422],{},"바이너리를 로그·DB에 저장할 때",[115,424,426],{"id":425},"왜-사용할까","왜 사용할까?",[111,428,429],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[111,431,432],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[115,434,436],{"id":435},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[111,438,405,439,143,441,443,444,447],{},[140,440,408],{},[140,442,412],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[140,445,446],{},"서명(Signature)"," 에서 나온다.",[115,449,451],{"id":450},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[111,453,454],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[182,456],{},[111,458,459],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[108,461,462],{},[111,463,464],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":59,"searchDepth":193,"depth":193,"links":466},[467],{"id":392,"depth":28,"text":393,"children":468},[469,470,471,472],{"id":117,"depth":193,"text":118},{"id":425,"depth":193,"text":426},{"id":435,"depth":193,"text":436},{"id":450,"depth":193,"text":451},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":59},"feeds\u002F2026-06-03-encoding",[209,210,211,479,57],"인코딩","8I5ExkCcCxIM2o5tuh_mX4i-P-F6f_Sv4n747ziuqKA",{"id":482,"title":483,"body":484,"date":724,"description":59,"extension":202,"meta":725,"navigation":204,"path":726,"seo":727,"stem":728,"tags":729,"__hash__":730},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":100,"value":485,"toc":714},[486,490,493,600,604,609,620,624,635,638,649,652,657,660,664,679,682,690,693,697],[115,487,489],{"id":488},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[111,491,492],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[494,495,496,518],"table",{},[497,498,499],"thead",{},[500,501,502,506,509,512,515],"tr",{},[503,504,505],"th",{},"구분",[503,507,508],{},"목적",[503,510,511],{},"방향성",[503,513,514],{},"키",[503,516,517],{},"대표 알고리즘",[519,520,521,545,564,582],"tbody",{},[500,522,523,529,536,539,542],{},[524,525,526],"td",{},[140,527,528],{},"인코딩 (Encoding)",[524,530,531,532],{},"형식 변환 ",[533,534,535],"em",{},"(보안 아님)",[524,537,538],{},"양방향 (키 불필요)",[524,540,541],{},"x",[524,543,544],{},"Base64, Base64URL, Hex",[500,546,547,552,555,558,561],{},[524,548,549],{},[140,550,551],{},"양방향 암호화 (Encryption)",[524,553,554],{},"기밀성 — 내용 숨기기",[524,556,557],{},"양방향 (복호화 가능)",[524,559,560],{},"o",[524,562,563],{},"AES(대칭키), RSA(비대칭키)",[500,565,566,571,574,577,579],{},[524,567,568],{},[140,569,570],{},"해시 (Hash)",[524,572,573],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[524,575,576],{},"단방향 (복원 불가)",[524,578,541],{},[524,580,581],{},"SHA-256, SHA-512, SHA-3",[500,583,584,589,592,595,597],{},[524,585,586],{},[140,587,588],{},"서명 (Signature)",[524,590,591],{},"무결성 + 인증 — 위변조 + 출처",[524,593,594],{},"단방향 (해시 기반)",[524,596,560],{},[524,598,599],{},"HMAC-SHA256(HS256), RS256, ES256",[115,601,603],{"id":602},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[605,606,608],"h4",{"id":607},"인코딩-암호화","인코딩 ≠ 암호화",[120,610,611,614,617],{},[123,612,613],{},"Base64는 키가 없다.",[123,615,616],{},"누구나 디코딩할 수 있다.",[123,618,619],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[605,621,623],{"id":622},"해시-서명","해시 ≠ 서명",[120,625,626,629,632],{},[123,627,628],{},"해시는 데이터의 지문을 생성한다.",[123,630,631],{},"같은 입력은 항상 같은 해시값을 만든다.",[123,633,634],{},"데이터가 변경되면 해시값도 달라진다.",[111,636,637],{},"반면 서명은",[120,639,640,643,646],{},[123,641,642],{},"해시에 키를 결합하여 생성한다.",[123,644,645],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[123,647,648],{},"누가 생성했는지까지 검증할 수 있다.",[111,650,651],{},"즉,",[108,653,654],{},[111,655,656],{},"서명(Signature) = 해시(Hash) + 키(Key)",[111,658,659],{},"라고 생각하면 이해하기 쉽다.",[605,661,663],{"id":662},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[111,665,405,666,669,670,673,674,678],{},[140,667,668],{},"HS256","은 ",[140,671,672],{},"HMAC-SHA256","을 사용하는 ",[675,676,677],"strong",{},"서명 알고리즘","이다.",[111,680,681],{},"토큰 내용을 숨기는 것이 아니라,",[120,683,684,687],{},[123,685,686],{},"토큰이 위조되지 않았는지",[123,688,689],{},"신뢰할 수 있는 발급자가 만들었는지",[111,691,692],{},"를 검증하기 위해 사용된다.",[115,694,696],{"id":695},"한-줄-요약","한 줄 요약",[108,698,699],{},[111,700,701,702,704,705,707,708,710,711,713],{},"형식만 바꾸면 ",[675,703,479],{},", 숨기면 ",[675,706,383],{},", 지문(위\u002F변조검사) 찍으면 ",[675,709,301],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[675,712,212],{},".",{"title":59,"searchDepth":193,"depth":193,"links":715},[716,717,723],{"id":488,"depth":193,"text":489},{"id":602,"depth":193,"text":603,"children":718},[719,721,722],{"id":607,"depth":720,"text":608},4,{"id":622,"depth":720,"text":623},{"id":662,"depth":720,"text":663},{"id":695,"depth":193,"text":696},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":59},"feeds\u002F2026-06-03-crypto-basics",[209,210,479,383,301,212],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1782920763063]