ivate 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[70,90,83,91],"AOP","Transaction","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[],[95,213,301,383,479],{"id":96,"title":97,"body":98,"date":199,"description":54,"extension":200,"meta":201,"navigation":202,"path":203,"seo":204,"stem":205,"tags":206,"__hash__":212},"feeds\u002Ffeeds\u002F2026-06-03-signature.md","2026 06 03 Signature",{"type":99,"value":100,"toc":190},"minimark",[101,106,113,118,134,147,154,163,166,170,173,176,179,182,185],[102,103,105],"h2",{"id":104},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[107,108,109],"blockquote",{},[110,111,112],"p",{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[114,115,117],"h3",{"id":116},"실무에서-만나는-곳","실무에서 만나는 곳",[119,120,121,125,128,131],"ul",{},[122,123,124],"li",{},"JWT 서명 (HS256, RS256)",[122,126,127],{},"웹훅 검증 (Stripe, GitHub 등)",[122,129,130],{},"서버 간 API 인증",[122,132,133],{},"AWS SigV4 요청 서명",[114,135,137,138,142,143,146],{"id":136},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[139,140,141],"code",{},"누가 보냈는지","와 ",[139,144,145],{},"내용이 안 바뀌었는지","를 증명한다",[110,148,149,150,153],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[139,151,152],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[110,155,156,157,159,160,162],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[139,158,81],{},"), 중간에 변조되지 않았다(",[139,161,152],{},")\"를 증명한다.",[110,164,165],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[114,167,169],{"id":168},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[110,171,172],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[110,174,175],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[110,177,178],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[180,181],"br",{},[110,183,184],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[107,186,187],{},[110,188,189],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":54,"searchDepth":191,"depth":191,"links":192},3,[193],{"id":104,"depth":28,"text":105,"children":194},[195,196,198],{"id":116,"depth":191,"text":117},{"id":136,"depth":191,"text":197},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":168,"depth":191,"text":169},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":54},"feeds\u002F2026-06-03-signature",[82,207,208,209,210,211,81],"암호기초","백엔드","서명","HMAC","JWT","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":214,"title":215,"body":216,"date":293,"description":54,"extension":200,"meta":294,"navigation":202,"path":295,"seo":296,"stem":297,"tags":298,"__hash__":300},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":99,"value":217,"toc":286},[218,222,227,229,243,247,250,253,256,260,263,266,269,272,274,281],[102,219,221],{"id":220},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[107,223,224],{},[110,225,226],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[114,228,117],{"id":116},[119,230,231,234,237,240],{},[122,232,233],{},"비밀번호 저장",[122,235,236],{},"파일 무결성 검증",[122,238,239],{},"캐시 키 생성",[122,241,242],{},"Git 커밋 식별자",[114,244,246],{"id":245},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[110,248,249],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[110,251,252],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[110,254,255],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[114,257,259],{"id":258},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[110,261,262],{},"SHA-256은 매우 빠른 알고리즘이다.",[110,264,265],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[110,267,268],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[110,270,271],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[180,273],{},[110,275,276,277,280],{},"대표 알고리즘: SHA-256·SHA-512(",[139,278,279],{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[107,282,283],{},[110,284,285],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":54,"searchDepth":191,"depth":191,"links":287},[288],{"id":220,"depth":28,"text":221,"children":289},[290,291,292],{"id":116,"depth":191,"text":117},{"id":245,"depth":191,"text":246},{"id":258,"depth":191,"text":259},"2026-06-03T15:30:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-hash",{"description":54},"feeds\u002F2026-06-03-hash",[82,207,299],"해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":302,"title":303,"body":304,"date":375,"description":54,"extension":200,"meta":376,"navigation":202,"path":377,"seo":378,"stem":379,"tags":380,"__hash__":382},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":99,"value":305,"toc":368},[306,310,315,317,328,332,335,345,351,355,358,360,363],[102,307,309],{"id":308},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[107,311,312],{},[110,313,314],{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[114,316,117],{"id":116},[119,318,319,322,325],{},[122,320,321],{},"전송 구간 암호화: HTTPS\u002FTLS",[122,323,324],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[122,326,327],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[114,329,331],{"id":330},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[110,333,334],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[119,336,337,340],{},[122,338,339],{},"필요하다 → 암호화",[122,341,342,343],{},"필요하지 않다 → ",[139,344,299],{},[110,346,347,348,350],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[139,349,299],{},"를 사용한다.(다음편)",[114,352,354],{"id":353},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[110,356,357],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[180,359],{},[110,361,362],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[107,364,365],{},[110,366,367],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":54,"searchDepth":191,"depth":191,"links":369},[370],{"id":308,"depth":28,"text":309,"children":371},[372,373,374],{"id":116,"depth":191,"text":117},{"id":330,"depth":191,"text":331},{"id":353,"depth":191,"text":354},"2026-06-03T15:20:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encryption",{"description":54},"feeds\u002F2026-06-03-encryption",[82,207,381],"암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":384,"title":385,"body":386,"date":471,"description":54,"extension":200,"meta":472,"navigation":202,"path":473,"seo":474,"stem":475,"tags":476,"__hash__":478},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":99,"value":387,"toc":463},[388,392,397,399,421,425,428,431,435,446,450,453,455,458],[102,389,391],{"id":390},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[107,393,394],{},[110,395,396],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[114,398,117],{"id":116},[119,400,401,412,415,418],{},[122,402,403,404,407,408,411],{},"JWT의 ",[139,405,406],{},"header",", ",[139,409,410],{},"payload"," (Base64URL)",[122,413,414],{},"URL의 한글·특수문자 (Percent-Encoding)",[122,416,417],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[122,419,420],{},"바이너리를 로그·DB에 저장할 때",[114,422,424],{"id":423},"왜-사용할까","왜 사용할까?",[110,426,427],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[110,429,430],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[114,432,434],{"id":433},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[110,436,403,437,142,439,441,442,445],{},[139,438,406],{},[139,440,410],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[139,443,444],{},"서명(Signature)"," 에서 나온다.",[114,447,449],{"id":448},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[110,451,452],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[180,454],{},[110,456,457],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[107,459,460],{},[110,461,462],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":54,"searchDepth":191,"depth":191,"links":464},[465],{"id":390,"depth":28,"text":391,"children":466},[467,468,469,470],{"id":116,"depth":191,"text":117},{"id":423,"depth":191,"text":424},{"id":433,"depth":191,"text":434},{"id":448,"depth":191,"text":449},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":54},"feeds\u002F2026-06-03-encoding",[82,207,208,477,211],"인코딩","8I5ExkCcCxIM2o5tuh_mX4i-P-F6f_Sv4n747ziuqKA",{"id":480,"title":481,"body":482,"date":722,"description":54,"extension":200,"meta":723,"navigation":202,"path":724,"seo":725,"stem":726,"tags":727,"__hash__":728},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":99,"value":483,"toc":712},[484,488,491,598,602,607,618,622,633,636,647,650,655,658,662,677,680,688,691,695],[114,485,487],{"id":486},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[110,489,490],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[492,493,494,516],"table",{},[495,496,497],"thead",{},[498,499,500,504,507,510,513],"tr",{},[501,502,503],"th",{},"구분",[501,505,506],{},"목적",[501,508,509],{},"방향성",[501,511,512],{},"키",[501,514,515],{},"대표 알고리즘",[517,518,519,543,562,580],"tbody",{},[498,520,521,527,534,537,540],{},[522,523,524],"td",{},[139,525,526],{},"인코딩 (Encoding)",[522,528,529,530],{},"형식 변환 ",[531,532,533],"em",{},"(보안 아님)",[522,535,536],{},"양방향 (키 불필요)",[522,538,539],{},"x",[522,541,542],{},"Base64, Base64URL, Hex",[498,544,545,550,553,556,559],{},[522,546,547],{},[139,548,549],{},"양방향 암호화 (Encryption)",[522,551,552],{},"기밀성 — 내용 숨기기",[522,554,555],{},"양방향 (복호화 가능)",[522,557,558],{},"o",[522,560,561],{},"AES(대칭키), RSA(비대칭키)",[498,563,564,569,572,575,577],{},[522,565,566],{},[139,567,568],{},"해시 (Hash)",[522,570,571],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[522,573,574],{},"단방향 (복원 불가)",[522,576,539],{},[522,578,579],{},"SHA-256, SHA-512, SHA-3",[498,581,582,587,590,593,595],{},[522,583,584],{},[139,585,586],{},"서명 (Signature)",[522,588,589],{},"무결성 + 인증 — 위변조 + 출처",[522,591,592],{},"단방향 (해시 기반)",[522,594,558],{},[522,596,597],{},"HMAC-SHA256(HS256), RS256, ES256",[114,599,601],{"id":600},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[603,604,606],"h4",{"id":605},"인코딩-암호화","인코딩 ≠ 암호화",[119,608,609,612,615],{},[122,610,611],{},"Base64는 키가 없다.",[122,613,614],{},"누구나 디코딩할 수 있다.",[122,616,617],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[603,619,621],{"id":620},"해시-서명","해시 ≠ 서명",[119,623,624,627,630],{},[122,625,626],{},"해시는 데이터의 지문을 생성한다.",[122,628,629],{},"같은 입력은 항상 같은 해시값을 만든다.",[122,631,632],{},"데이터가 변경되면 해시값도 달라진다.",[110,634,635],{},"반면 서명은",[119,637,638,641,644],{},[122,639,640],{},"해시에 키를 결합하여 생성한다.",[122,642,643],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[122,645,646],{},"누가 생성했는지까지 검증할 수 있다.",[110,648,649],{},"즉,",[107,651,652],{},[110,653,654],{},"서명(Signature) = 해시(Hash) + 키(Key)",[110,656,657],{},"라고 생각하면 이해하기 쉽다.",[603,659,661],{"id":660},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[110,663,403,664,667,668,671,672,676],{},[139,665,666],{},"HS256","은 ",[139,669,670],{},"HMAC-SHA256","을 사용하는 ",[673,674,675],"strong",{},"서명 알고리즘","이다.",[110,678,679],{},"토큰 내용을 숨기는 것이 아니라,",[119,681,682,685],{},[122,683,684],{},"토큰이 위조되지 않았는지",[122,686,687],{},"신뢰할 수 있는 발급자가 만들었는지",[110,689,690],{},"를 검증하기 위해 사용된다.",[114,692,694],{"id":693},"한-줄-요약","한 줄 요약",[107,696,697],{},[110,698,699,700,702,703,705,706,708,709,711],{},"형식만 바꾸면 ",[673,701,477],{},", 숨기면 ",[673,704,381],{},", 지문(위\u002F변조검사) 찍으면 ",[673,707,299],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[673,710,209],{},".",{"title":54,"searchDepth":191,"depth":191,"links":713},[714,715,721],{"id":486,"depth":191,"text":487},{"id":600,"depth":191,"text":601,"children":716},[717,719,720],{"id":605,"depth":718,"text":606},4,{"id":620,"depth":718,"text":621},{"id":660,"depth":718,"text":661},{"id":693,"depth":191,"text":694},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":54},"feeds\u002F2026-06-03-crypto-basics",[82,207,477,381,299,209],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1780814128872]