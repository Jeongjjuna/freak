06 03 Signature",{"type":80,"value":81,"toc":172},"minimark",[82,87,94,99,115,128,135,145,148,152,155,158,161,164,167],[83,84,86],"h2",{"id":85},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[88,89,90],"blockquote",{},[91,92,93],"p",{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[95,96,98],"h3",{"id":97},"실무에서-만나는-곳","실무에서 만나는 곳",[100,101,102,106,109,112],"ul",{},[103,104,105],"li",{},"JWT 서명 (HS256, RS256)",[103,107,108],{},"웹훅 검증 (Stripe, GitHub 등)",[103,110,111],{},"서버 간 API 인증",[103,113,114],{},"AWS SigV4 요청 서명",[95,116,118,119,123,124,127],{"id":117},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[120,121,122],"code",{},"누가 보냈는지","와 ",[120,125,126],{},"내용이 안 바뀌었는지","를 증명한다",[91,129,130,131,134],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[120,132,133],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[91,136,137,138,141,142,144],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[120,139,140],{},"인증","), 중간에 변조되지 않았다(",[120,143,133],{},")\"를 증명한다.",[91,146,147],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[95,149,151],{"id":150},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[91,153,154],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[91,156,157],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[91,159,160],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[162,163],"br",{},[91,165,166],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[88,168,169],{},[91,170,171],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":38,"searchDepth":173,"depth":173,"links":174},3,[175],{"id":85,"depth":176,"text":86,"children":177},2,[178,179,181],{"id":97,"depth":173,"text":98},{"id":117,"depth":173,"text":180},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":150,"depth":173,"text":151},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":38},"feeds\u002F2026-06-03-signature",[190,191,192,193,194,36,140],"보안","암호기초","백엔드","서명","HMAC","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":197,"title":198,"body":199,"date":276,"description":38,"extension":183,"meta":277,"navigation":185,"path":278,"seo":279,"stem":280,"tags":281,"__hash__":283},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":80,"value":200,"toc":269},[201,205,210,212,226,230,233,236,239,243,246,249,252,255,257,264],[83,202,204],{"id":203},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[88,206,207],{},[91,208,209],{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[95,211,98],{"id":97},[100,213,214,217,220,223],{},[103,215,216],{},"비밀번호 저장",[103,218,219],{},"파일 무결성 검증",[103,221,222],{},"캐시 키 생성",[103,224,225],{},"Git 커밋 식별자",[95,227,229],{"id":228},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[91,231,232],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[91,234,235],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[91,237,238],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[95,240,242],{"id":241},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[91,244,245],{},"SHA-256은 매우 빠른 알고리즘이다.",[91,247,248],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[91,250,251],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[91,253,254],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[162,256],{},[91,258,259,260,263],{},"대표 알고리즘: SHA-256·SHA-512(",[120,261,262],{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[88,265,266],{},[91,267,268],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":38,"searchDepth":173,"depth":173,"links":270},[271],{"id":203,"depth":176,"text":204,"children":272},[273,274,275],{"id":97,"depth":173,"text":98},{"id":228,"depth":173,"text":229},{"id":241,"depth":173,"text":242},"2026-06-03T15:30:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-hash",{"description":38},"feeds\u002F2026-06-03-hash",[190,191,282],"해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":285,"title":286,"body":287,"date":358,"description":38,"extension":183,"meta":359,"navigation":185,"path":360,"seo":361,"stem":362,"tags":363,"__hash__":365},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":80,"value":288,"toc":351},[289,293,298,300,311,315,318,328,334,338,341,343,346],[83,290,292],{"id":291},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[88,294,295],{},[91,296,297],{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[95,299,98],{"id":97},[100,301,302,305,308],{},[103,303,304],{},"전송 구간 암호화: HTTPS\u002FTLS",[103,306,307],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[103,309,310],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[95,312,314],{"id":313},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[91,316,317],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[100,319,320,323],{},[103,321,322],{},"필요하다 → 암호화",[103,324,325,326],{},"필요하지 않다 → ",[120,327,282],{},[91,329,330,331,333],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[120,332,282],{},"를 사용한다.(다음편)",[95,335,337],{"id":336},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[91,339,340],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[162,342],{},[91,344,345],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[88,347,348],{},[91,349,350],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":38,"searchDepth":173,"depth":173,"links":352},[353],{"id":291,"depth":176,"text":292,"children":354},[355,356,357],{"id":97,"depth":173,"text":98},{"id":313,"depth":173,"text":314},{"id":336,"depth":173,"text":337},"2026-06-03T15:20:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encryption",{"description":38},"feeds\u002F2026-06-03-encryption",[190,191,364],"암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":367,"title":368,"body":369,"date":454,"description":38,"extension":183,"meta":455,"navigation":185,"path":456,"seo":457,"stem":458,"tags":459,"__hash__":461},"feeds\u002Ffeeds\u002F2026-06-03-encoding.md","2026 06 03 Encoding",{"type":80,"value":370,"toc":446},[371,375,380,382,404,408,411,414,418,429,433,436,438,441],[83,372,374],{"id":373},"백엔드가-만나는-암호-기초-14-인코딩","백엔드가 만나는 암호 기초 (1\u002F4) — 인코딩",[88,376,377],{},[91,378,379],{},"한국어를 영어로 번역하는 것 🌍— 내용은 그대로, 표현만 바뀐다.",[95,381,98],{"id":97},[100,383,384,395,398,401],{},[103,385,386,387,390,391,394],{},"JWT의 ",[120,388,389],{},"header",", ",[120,392,393],{},"payload"," (Base64URL)",[103,396,397],{},"URL의 한글·특수문자 (Percent-Encoding)",[103,399,400],{},"바이너리 데이터를 JSON에 담을 때 (Base64)",[103,402,403],{},"바이너리를 로그·DB에 저장할 때",[95,405,407],{"id":406},"왜-사용할까","왜 사용할까?",[91,409,410],{},"시스템마다 다룰 수 있는 데이터 형식이 다르기 때문이다.",[91,412,413],{},"예를 들어 Base64는 바이너리를 텍스트로 바꿔 JSON, HTTP, DB 등에 담을 수 있게 해주고,\nPercent-Encoding은 한글·특수문자를 URL에 안전하게 담을 수 있게 해준다.",[95,415,417],{"id":416},"포인트1-jwt는-암호화된-토큰이-아니다","포인트1 — JWT는 암호화된 토큰이 아니다",[91,419,386,420,123,422,424,425,428],{},[120,421,389],{},[120,423,393],{},"는 Base64URL로 인코딩된 데이터일 뿐이다.\n누구나 디코딩해서 내용을 볼 수 있으며, JWT의 안전성은 인코딩이 아니라 ",[120,426,427],{},"서명(Signature)"," 에서 나온다.",[95,430,432],{"id":431},"포인트2-인코딩은-보안이-아니다","포인트2 — 인코딩은 보안이 아니다",[91,434,435],{},"인코딩의 목적은 데이터를 숨기는 것이 아니라 전달과 저장이다.\n참고로 Base64는 데이터 크기를 약 33% 증가시킨다.",[162,437],{},[91,439,440],{},"대표 인코딩: Base64, Base64URL, Hex, Percent-Encoding",[88,442,443],{},[91,444,445],{},"한 줄 요약: 인코딩은 보안 기술이 아니라 데이터를 표현하는 방법이다.",{"title":38,"searchDepth":173,"depth":173,"links":447},[448],{"id":373,"depth":176,"text":374,"children":449},[450,451,452,453],{"id":97,"depth":173,"text":98},{"id":406,"depth":173,"text":407},{"id":416,"depth":173,"text":417},{"id":431,"depth":173,"text":432},"2026-06-03T15:10:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-encoding",{"description":38},"feeds\u002F2026-06-03-encoding",[190,191,192,460,36],"인코딩","8I5ExkCcCxIM2o5tuh_mX4i-P-F6f_Sv4n747ziuqKA",{"id":463,"title":464,"body":465,"date":705,"description":38,"extension":183,"meta":706,"navigation":185,"path":707,"seo":708,"stem":709,"tags":710,"__hash__":711},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":80,"value":466,"toc":695},[467,471,474,581,585,590,601,605,616,619,630,633,638,641,645,660,663,671,674,678],[95,468,470],{"id":469},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[91,472,473],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[475,476,477,499],"table",{},[478,479,480],"thead",{},[481,482,483,487,490,493,496],"tr",{},[484,485,486],"th",{},"구분",[484,488,489],{},"목적",[484,491,492],{},"방향성",[484,494,495],{},"키",[484,497,498],{},"대표 알고리즘",[500,501,502,526,545,563],"tbody",{},[481,503,504,510,517,520,523],{},[505,506,507],"td",{},[120,508,509],{},"인코딩 (Encoding)",[505,511,512,513],{},"형식 변환 ",[514,515,516],"em",{},"(보안 아님)",[505,518,519],{},"양방향 (키 불필요)",[505,521,522],{},"x",[505,524,525],{},"Base64, Base64URL, Hex",[481,527,528,533,536,539,542],{},[505,529,530],{},[120,531,532],{},"양방향 암호화 (Encryption)",[505,534,535],{},"기밀성 — 내용 숨기기",[505,537,538],{},"양방향 (복호화 가능)",[505,540,541],{},"o",[505,543,544],{},"AES(대칭키), RSA(비대칭키)",[481,546,547,552,555,558,560],{},[505,548,549],{},[120,550,551],{},"해시 (Hash)",[505,553,554],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[505,556,557],{},"단방향 (복원 불가)",[505,559,522],{},[505,561,562],{},"SHA-256, SHA-512, SHA-3",[481,564,565,570,573,576,578],{},[505,566,567],{},[120,568,569],{},"서명 (Signature)",[505,571,572],{},"무결성 + 인증 — 위변조 + 출처",[505,574,575],{},"단방향 (해시 기반)",[505,577,541],{},[505,579,580],{},"HMAC-SHA256(HS256), RS256, ES256",[95,582,584],{"id":583},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[586,587,589],"h4",{"id":588},"인코딩-암호화","인코딩 ≠ 암호화",[100,591,592,595,598],{},[103,593,594],{},"Base64는 키가 없다.",[103,596,597],{},"누구나 디코딩할 수 있다.",[103,599,600],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[586,602,604],{"id":603},"해시-서명","해시 ≠ 서명",[100,606,607,610,613],{},[103,608,609],{},"해시는 데이터의 지문을 생성한다.",[103,611,612],{},"같은 입력은 항상 같은 해시값을 만든다.",[103,614,615],{},"데이터가 변경되면 해시값도 달라진다.",[91,617,618],{},"반면 서명은",[100,620,621,624,627],{},[103,622,623],{},"해시에 키를 결합하여 생성한다.",[103,625,626],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[103,628,629],{},"누가 생성했는지까지 검증할 수 있다.",[91,631,632],{},"즉,",[88,634,635],{},[91,636,637],{},"서명(Signature) = 해시(Hash) + 키(Key)",[91,639,640],{},"라고 생각하면 이해하기 쉽다.",[586,642,644],{"id":643},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[91,646,386,647,650,651,654,655,659],{},[120,648,649],{},"HS256","은 ",[120,652,653],{},"HMAC-SHA256","을 사용하는 ",[656,657,658],"strong",{},"서명 알고리즘","이다.",[91,661,662],{},"토큰 내용을 숨기는 것이 아니라,",[100,664,665,668],{},[103,666,667],{},"토큰이 위조되지 않았는지",[103,669,670],{},"신뢰할 수 있는 발급자가 만들었는지",[91,672,673],{},"를 검증하기 위해 사용된다.",[95,675,677],{"id":676},"한-줄-요약","한 줄 요약",[88,679,680],{},[91,681,682,683,685,686,688,689,691,692,694],{},"형식만 바꾸면 ",[656,684,460],{},", 숨기면 ",[656,687,364],{},", 지문(위\u002F변조검사) 찍으면 ",[656,690,282],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[656,693,193],{},".",{"title":38,"searchDepth":173,"depth":173,"links":696},[697,698,704],{"id":469,"depth":173,"text":470},{"id":583,"depth":173,"text":584,"children":699},[700,702,703],{"id":588,"depth":701,"text":589},4,{"id":603,"depth":701,"text":604},{"id":643,"depth":701,"text":644},{"id":676,"depth":173,"text":677},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":38},"feeds\u002F2026-06-03-crypto-basics",[190,191,460,364,282,193],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1782923313178]