ate 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[70,90,83,91],"AOP","Transaction","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[],[95,193],{"id":96,"title":97,"body":98,"date":182,"description":54,"extension":183,"meta":184,"navigation":185,"path":186,"seo":187,"stem":188,"tags":189,"__hash__":192},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":99,"value":100,"toc":174},"minimark",[101,106,113,118,131,135,138,150,156,160,163,166,169],[102,103,105],"h2",{"id":104},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[107,108,109],"blockquote",{},[110,111,112],"p",{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[114,115,117],"h3",{"id":116},"실무에서-만나는-곳","실무에서 만나는 곳",[119,120,121,125,128],"ul",{},[122,123,124],"li",{},"전송 구간 암호화: HTTPS\u002FTLS",[122,126,127],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[122,129,130],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[114,132,134],{"id":133},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[110,136,137],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[119,139,140,143],{},[122,141,142],{},"필요하다 → 암호화",[122,144,145,146],{},"필요하지 않다 → ",[147,148,149],"code",{},"해시",[110,151,152,153,155],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[147,154,149],{},"를 사용한다.(다음편)",[114,157,159],{"id":158},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[110,161,162],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[164,165],"br",{},[110,167,168],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[107,170,171],{},[110,172,173],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":54,"searchDepth":175,"depth":175,"links":176},3,[177],{"id":104,"depth":28,"text":105,"children":178},[179,180,181],{"id":116,"depth":175,"text":117},{"id":133,"depth":175,"text":134},{"id":158,"depth":175,"text":159},"2026-06-03T15:20:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-encryption",{"description":54},"feeds\u002F2026-06-03-encryption",[82,190,191],"암호기초","암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":194,"title":195,"body":196,"date":439,"description":54,"extension":183,"meta":440,"navigation":185,"path":441,"seo":442,"stem":443,"tags":444,"__hash__":445},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":99,"value":197,"toc":429},[198,202,205,312,316,321,332,336,347,350,361,364,369,372,376,392,395,403,406,410],[114,199,201],{"id":200},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[110,203,204],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[206,207,208,230],"table",{},[209,210,211],"thead",{},[212,213,214,218,221,224,227],"tr",{},[215,216,217],"th",{},"구분",[215,219,220],{},"목적",[215,222,223],{},"방향성",[215,225,226],{},"키",[215,228,229],{},"대표 알고리즘",[231,232,233,257,276,294],"tbody",{},[212,234,235,241,248,251,254],{},[236,237,238],"td",{},[147,239,240],{},"인코딩 (Encoding)",[236,242,243,244],{},"형식 변환 ",[245,246,247],"em",{},"(보안 아님)",[236,249,250],{},"양방향 (키 불필요)",[236,252,253],{},"x",[236,255,256],{},"Base64, Base64URL, Hex",[212,258,259,264,267,270,273],{},[236,260,261],{},[147,262,263],{},"양방향 암호화 (Encryption)",[236,265,266],{},"기밀성 — 내용 숨기기",[236,268,269],{},"양방향 (복호화 가능)",[236,271,272],{},"o",[236,274,275],{},"AES(대칭키), RSA(비대칭키)",[212,277,278,283,286,289,291],{},[236,279,280],{},[147,281,282],{},"해시 (Hash)",[236,284,285],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[236,287,288],{},"단방향 (복원 불가)",[236,290,253],{},[236,292,293],{},"SHA-256, SHA-512, SHA-3",[212,295,296,301,304,307,309],{},[236,297,298],{},[147,299,300],{},"서명 (Signature)",[236,302,303],{},"무결성 + 인증 — 위변조 + 출처",[236,305,306],{},"단방향 (해시 기반)",[236,308,272],{},[236,310,311],{},"HMAC-SHA256(HS256), RS256, ES256",[114,313,315],{"id":314},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[317,318,320],"h4",{"id":319},"인코딩-암호화","인코딩 ≠ 암호화",[119,322,323,326,329],{},[122,324,325],{},"Base64는 키가 없다.",[122,327,328],{},"누구나 디코딩할 수 있다.",[122,330,331],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[317,333,335],{"id":334},"해시-서명","해시 ≠ 서명",[119,337,338,341,344],{},[122,339,340],{},"해시는 데이터의 지문을 생성한다.",[122,342,343],{},"같은 입력은 항상 같은 해시값을 만든다.",[122,345,346],{},"데이터가 변경되면 해시값도 달라진다.",[110,348,349],{},"반면 서명은",[119,351,352,355,358],{},[122,353,354],{},"해시에 키를 결합하여 생성한다.",[122,356,357],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[122,359,360],{},"누가 생성했는지까지 검증할 수 있다.",[110,362,363],{},"즉,",[107,365,366],{},[110,367,368],{},"서명(Signature) = 해시(Hash) + 키(Key)",[110,370,371],{},"라고 생각하면 이해하기 쉽다.",[317,373,375],{"id":374},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[110,377,378,379,382,383,386,387,391],{},"JWT의 ",[147,380,381],{},"HS256","은 ",[147,384,385],{},"HMAC-SHA256","을 사용하는 ",[388,389,390],"strong",{},"서명 알고리즘","이다.",[110,393,394],{},"토큰 내용을 숨기는 것이 아니라,",[119,396,397,400],{},[122,398,399],{},"토큰이 위조되지 않았는지",[122,401,402],{},"신뢰할 수 있는 발급자가 만들었는지",[110,404,405],{},"를 검증하기 위해 사용된다.",[114,407,409],{"id":408},"한-줄-요약","한 줄 요약",[107,411,412],{},[110,413,414,415,418,419,421,422,424,425,428],{},"형식만 바꾸면 ",[388,416,417],{},"인코딩",", 숨기면 ",[388,420,191],{},", 지문(위\u002F변조검사) 찍으면 ",[388,423,149],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[388,426,427],{},"서명",".",{"title":54,"searchDepth":175,"depth":175,"links":430},[431,432,438],{"id":200,"depth":175,"text":201},{"id":314,"depth":175,"text":315,"children":433},[434,436,437],{"id":319,"depth":435,"text":320},4,{"id":334,"depth":435,"text":335},{"id":374,"depth":435,"text":375},{"id":408,"depth":175,"text":409},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":54},"feeds\u002F2026-06-03-crypto-basics",[82,190,417,191,149,427],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1780814129437]