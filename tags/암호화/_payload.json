[{"data":1,"prerenderedAt":429},["ShallowReactive",2],{"layout-data":3,"tag-posts-암호화":74,"tag-feeds-암호화":75},{"groups":4,"recentPosts":30},[5,11,20,25],{"name":6,"categories":7},"Engineering",[8],{"name":9,"count":10},"Architecture",1,{"name":12,"categories":13},"Learning",[14,16,18],{"name":15,"count":10},"MySQL",{"name":17,"count":10},"Redis",{"name":19,"count":10},"Security",{"name":21,"categories":22},"Archive",[23],{"name":24,"count":10},"Books",{"name":26,"categories":27},"Etc",[28],{"name":29,"count":10},"Kotlin",[31,40,47,56,64],{"slug":32,"title":33,"date":34,"category":19,"tags":35,"excerpt":38,"thumbnail":39},"2026-06-07-jvm-security-jwt","이론 & 실습 : 초간단 JWT 직접 구현해보기","2026-06-07",[19,36,37,29],"JWT","SHA256","","\u002Fimages\u002Fthumbnails\u002Fsecurity.png",{"slug":41,"title":42,"date":34,"category":29,"tags":43,"excerpt":38,"thumbnail":46},"2026-06-07-kotlin-stdlib-uuid-v7","UUID - v7 이 무엇일까?",[29,44,45],"UUID","UUIDv7","\u002Fimages\u002Fthumbnails\u002Fkotlin.png",{"slug":48,"title":49,"date":50,"category":15,"tags":51,"excerpt":38,"thumbnail":55},"revisiting-db-locks","초심 찾기! 동시성 처리를 위한 DB Lock 다시 한번 복습해보자","2026-04-30",[15,52,53,54],"동시성","JPA","데이터베이스","\u002Fimages\u002Fthumbnails\u002Fdatabase.png",{"slug":57,"title":58,"date":59,"category":24,"tags":60,"excerpt":38,"thumbnail":63},"minimum-practical-knowledge-for-developers","개발자를 위한 최소한의 실무 지식 독서 회고","2026-04-18",[61,62],"독서","개발자를 위한 최소한의 실무 지식","\u002Fimages\u002Fthumbnails\u002Fbooks.png",{"slug":65,"title":66,"date":67,"category":9,"tags":68,"excerpt":38,"thumbnail":73},"spring-architecture","아키텍처 규칙 강제하기(feat MultiModule, ArchUnit, AI Agent)","2026-04-08",[29,69,70,71,72],"Spring","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",[],[76,176],{"id":77,"title":78,"body":79,"date":164,"description":38,"extension":165,"meta":166,"navigation":167,"path":168,"seo":169,"stem":170,"tags":171,"__hash__":175},"feeds\u002Ffeeds\u002F2026-06-03-encryption.md","2026 06 03 Encryption",{"type":80,"value":81,"toc":155},"minimark",[82,87,94,99,112,116,119,131,137,141,144,147,150],[83,84,86],"h2",{"id":85},"백엔드가-만나는-암호-기초-24-암호화-양방향","백엔드가 만나는 암호 기초 (2\u002F4) — 암호화 (양방향)",[88,89,90],"blockquote",{},[91,92,93],"p",{},"자물쇠 금고 🔐 — 키로 잠그고, 키로 다시 연다.",[95,96,98],"h3",{"id":97},"실무에서-만나는-곳","실무에서 만나는 곳",[100,101,102,106,109],"ul",{},[103,104,105],"li",{},"전송 구간 암호화: HTTPS\u002FTLS",[103,107,108],{},"DB 컬럼 암호화: 주민번호·카드번호처럼 나중에 복호화해서 보여줘야 하는 값",[103,110,111],{},"설정 시크릿을 KMS\u002FVault로 암호화해 저장하고, 런타임에 복호화",[95,113,115],{"id":114},"포인트1-언제-양방향-암호화를-사용할까","포인트1  — 언제 양방향 암호화를 사용할까?",[91,117,118],{},"기준은 \"원래 값이 나중에 필요할까?\"이다.",[100,120,121,124],{},[103,122,123],{},"필요하다 → 암호화",[103,125,126,127],{},"필요하지 않다 → ",[128,129,130],"code",{},"해시",[91,132,133,134,136],{},"주민번호, 카드번호, API Key처럼 나중에 다시 조회해야 하는 값은 암호화한다.\n반면 비밀번호는 원래 값을 알 필요가 없으므로 암호화가 아니라 ",[128,135,130],{},"를 사용한다.(다음편)",[95,138,140],{"id":139},"포인트2-암호화보다-더-중요한-것은-키-관리다","포인트2  — 암호화보다 더 중요한 것은 키 관리다",[91,142,143],{},"아무리 강력한 알고리즘을 사용해도 암호화 키가 유출되면 데이터는 그대로 읽힌다.\n그래서 실무에서는 알고리즘 선택보다 키를 안전하게 보관하고 접근을 통제하는 것이 더 중요하다.\n직접 구현하기보다는 KMS, Vault, 검증된 암호화 라이브러리를 사용하는 것이 일반적이다.",[145,146],"br",{},[91,148,149],{},"대표 양방향 알고리즘 : AES(대칭키), RSA(비대칭키)",[88,151,152],{},[91,153,154],{},"한 줄 요약:  다시 읽어야 하면 양방향 암호화. 암호화를 지키는 건 키 관리.",{"title":38,"searchDepth":156,"depth":156,"links":157},3,[158],{"id":85,"depth":159,"text":86,"children":160},2,[161,162,163],{"id":97,"depth":156,"text":98},{"id":114,"depth":156,"text":115},{"id":139,"depth":156,"text":140},"2026-06-03T15:20:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-encryption",{"description":38},"feeds\u002F2026-06-03-encryption",[172,173,174],"보안","암호기초","암호화","hHkU_iX05zFOveH9ix4V3K2Gk73ORfjVqo_7EQD5CJs",{"id":177,"title":178,"body":179,"date":422,"description":38,"extension":165,"meta":423,"navigation":167,"path":424,"seo":425,"stem":426,"tags":427,"__hash__":428},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":80,"value":180,"toc":412},[181,185,188,295,299,304,315,319,330,333,344,347,352,355,359,375,378,386,389,393],[95,182,184],{"id":183},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[91,186,187],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[189,190,191,213],"table",{},[192,193,194],"thead",{},[195,196,197,201,204,207,210],"tr",{},[198,199,200],"th",{},"구분",[198,202,203],{},"목적",[198,205,206],{},"방향성",[198,208,209],{},"키",[198,211,212],{},"대표 알고리즘",[214,215,216,240,259,277],"tbody",{},[195,217,218,224,231,234,237],{},[219,220,221],"td",{},[128,222,223],{},"인코딩 (Encoding)",[219,225,226,227],{},"형식 변환 ",[228,229,230],"em",{},"(보안 아님)",[219,232,233],{},"양방향 (키 불필요)",[219,235,236],{},"x",[219,238,239],{},"Base64, Base64URL, Hex",[195,241,242,247,250,253,256],{},[219,243,244],{},[128,245,246],{},"양방향 암호화 (Encryption)",[219,248,249],{},"기밀성 — 내용 숨기기",[219,251,252],{},"양방향 (복호화 가능)",[219,254,255],{},"o",[219,257,258],{},"AES(대칭키), RSA(비대칭키)",[195,260,261,266,269,272,274],{},[219,262,263],{},[128,264,265],{},"해시 (Hash)",[219,267,268],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[219,270,271],{},"단방향 (복원 불가)",[219,273,236],{},[219,275,276],{},"SHA-256, SHA-512, SHA-3",[195,278,279,284,287,290,292],{},[219,280,281],{},[128,282,283],{},"서명 (Signature)",[219,285,286],{},"무결성 + 인증 — 위변조 + 출처",[219,288,289],{},"단방향 (해시 기반)",[219,291,255],{},[219,293,294],{},"HMAC-SHA256(HS256), RS256, ES256",[95,296,298],{"id":297},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[300,301,303],"h4",{"id":302},"인코딩-암호화","인코딩 ≠ 암호화",[100,305,306,309,312],{},[103,307,308],{},"Base64는 키가 없다.",[103,310,311],{},"누구나 디코딩할 수 있다.",[103,313,314],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[300,316,318],{"id":317},"해시-서명","해시 ≠ 서명",[100,320,321,324,327],{},[103,322,323],{},"해시는 데이터의 지문을 생성한다.",[103,325,326],{},"같은 입력은 항상 같은 해시값을 만든다.",[103,328,329],{},"데이터가 변경되면 해시값도 달라진다.",[91,331,332],{},"반면 서명은",[100,334,335,338,341],{},[103,336,337],{},"해시에 키를 결합하여 생성한다.",[103,339,340],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[103,342,343],{},"누가 생성했는지까지 검증할 수 있다.",[91,345,346],{},"즉,",[88,348,349],{},[91,350,351],{},"서명(Signature) = 해시(Hash) + 키(Key)",[91,353,354],{},"라고 생각하면 이해하기 쉽다.",[300,356,358],{"id":357},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[91,360,361,362,365,366,369,370,374],{},"JWT의 ",[128,363,364],{},"HS256","은 ",[128,367,368],{},"HMAC-SHA256","을 사용하는 ",[371,372,373],"strong",{},"서명 알고리즘","이다.",[91,376,377],{},"토큰 내용을 숨기는 것이 아니라,",[100,379,380,383],{},[103,381,382],{},"토큰이 위조되지 않았는지",[103,384,385],{},"신뢰할 수 있는 발급자가 만들었는지",[91,387,388],{},"를 검증하기 위해 사용된다.",[95,390,392],{"id":391},"한-줄-요약","한 줄 요약",[88,394,395],{},[91,396,397,398,401,402,404,405,407,408,411],{},"형식만 바꾸면 ",[371,399,400],{},"인코딩",", 숨기면 ",[371,403,174],{},", 지문(위\u002F변조검사) 찍으면 ",[371,406,130],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[371,409,410],{},"서명",".",{"title":38,"searchDepth":156,"depth":156,"links":413},[414,415,421],{"id":183,"depth":156,"text":184},{"id":297,"depth":156,"text":298,"children":416},[417,419,420],{"id":302,"depth":418,"text":303},4,{"id":317,"depth":418,"text":318},{"id":357,"depth":418,"text":358},{"id":391,"depth":156,"text":392},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":38},"feeds\u002F2026-06-03-crypto-basics",[172,173,400,174,130,410],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1782923313196]