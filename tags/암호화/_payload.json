로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[319,335,337],{"id":336},"해시-서명","해시 ≠ 서명",[120,339,340,343,346],{},[123,341,342],{},"해시는 데이터의 지문을 생성한다.",[123,344,345],{},"같은 입력은 항상 같은 해시값을 만든다.",[123,347,348],{},"데이터가 변경되면 해시값도 달라진다.",[111,350,351],{},"반면 서명은",[120,353,354,357,360],{},[123,355,356],{},"해시에 키를 결합하여 생성한다.",[123,358,359],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[123,361,362],{},"누가 생성했는지까지 검증할 수 있다.",[111,364,365],{},"즉,",[108,367,368],{},[111,369,370],{},"서명(Signature) = 해시(Hash) + 키(Key)",[111,372,373],{},"라고 생각하면 이해하기 쉽다.",[319,375,377],{"id":376},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[111,379,380,381,384,385,388,389,393],{},"JWT의 ",[148,382,383],{},"HS256","은 ",[148,386,387],{},"HMAC-SHA256","을 사용하는 ",[390,391,392],"strong",{},"서명 알고리즘","이다.",[111,395,396],{},"토큰 내용을 숨기는 것이 아니라,",[120,398,399,402],{},[123,400,401],{},"토큰이 위조되지 않았는지",[123,403,404],{},"신뢰할 수 있는 발급자가 만들었는지",[111,406,407],{},"를 검증하기 위해 사용된다.",[115,409,411],{"id":410},"한-줄-요약","한 줄 요약",[108,413,414],{},[111,415,416,417,420,421,423,424,426,427,430],{},"형식만 바꾸면 ",[390,418,419],{},"인코딩",", 숨기면 ",[390,422,193],{},", 지문(위\u002F변조검사) 찍으면 ",[390,425,150],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[390,428,429],{},"서명",".",{"title":59,"searchDepth":176,"depth":176,"links":432},[433,434,440],{"id":202,"depth":176,"text":203},{"id":316,"depth":176,"text":317,"children":435},[436,438,439],{"id":321,"depth":437,"text":322},4,{"id":336,"depth":437,"text":337},{"id":376,"depth":437,"text":377},{"id":410,"depth":176,"text":411},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":59},"feeds\u002F2026-06-03-crypto-basics",[191,192,419,193,150,429],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1781631563456]