[{"data":1,"prerenderedAt":257},["ShallowReactive",2],{"layout-data":3,"tag-posts-인증":74,"tag-feeds-인증":75},{"groups":4,"recentPosts":30},[5,11,20,25],{"name":6,"categories":7},"Engineering",[8],{"name":9,"count":10},"Architecture",1,{"name":12,"categories":13},"Learning",[14,16,18],{"name":15,"count":10},"MySQL",{"name":17,"count":10},"Redis",{"name":19,"count":10},"Security",{"name":21,"categories":22},"Archive",[23],{"name":24,"count":10},"Books",{"name":26,"categories":27},"Etc",[28],{"name":29,"count":10},"Kotlin",[31,40,47,56,64],{"slug":32,"title":33,"date":34,"category":19,"tags":35,"excerpt":38,"thumbnail":39},"2026-06-07-jvm-security-jwt","이론 & 실습 : 초간단 JWT 직접 구현해보기","2026-06-07",[19,36,37,29],"JWT","SHA256","","\u002Fimages\u002Fthumbnails\u002Fsecurity.png",{"slug":41,"title":42,"date":34,"category":29,"tags":43,"excerpt":38,"thumbnail":46},"2026-06-07-kotlin-stdlib-uuid-v7","UUID - v7 이 무엇일까?",[29,44,45],"UUID","UUIDv7","\u002Fimages\u002Fthumbnails\u002Fkotlin.png",{"slug":48,"title":49,"date":50,"category":15,"tags":51,"excerpt":38,"thumbnail":55},"revisiting-db-locks","초심 찾기! 동시성 처리를 위한 DB Lock 다시 한번 복습해보자","2026-04-30",[15,52,53,54],"동시성","JPA","데이터베이스","\u002Fimages\u002Fthumbnails\u002Fdatabase.png",{"slug":57,"title":58,"date":59,"category":24,"tags":60,"excerpt":38,"thumbnail":63},"minimum-practical-knowledge-for-developers","개발자를 위한 최소한의 실무 지식 독서 회고","2026-04-18",[61,62],"독서","개발자를 위한 최소한의 실무 지식","\u002Fimages\u002Fthumbnails\u002Fbooks.png",{"slug":65,"title":66,"date":67,"category":9,"tags":68,"excerpt":38,"thumbnail":73},"spring-architecture","아키텍처 규칙 강제하기(feat MultiModule, ArchUnit, AI Agent)","2026-04-08",[29,69,70,71,72],"Spring","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",[],[76,196],{"id":77,"title":78,"body":79,"date":182,"description":38,"extension":183,"meta":184,"navigation":185,"path":186,"seo":187,"stem":188,"tags":189,"__hash__":195},"feeds\u002Ffeeds\u002F2026-06-03-signature.md","2026 06 03 Signature",{"type":80,"value":81,"toc":172},"minimark",[82,87,94,99,115,128,135,145,148,152,155,158,161,164,167],[83,84,86],"h2",{"id":85},"백엔드가-만나는-암호-기초-44-서명","백엔드가 만나는 암호 기초 (4\u002F4) — 서명",[88,89,90],"blockquote",{},[91,92,93],"p",{},"인감도장 🔏 — 문서에 도장을 찍어 \"내가 작성했고, 중간에 바뀌지 않았다\"를 증명한다.",[95,96,98],"h3",{"id":97},"실무에서-만나는-곳","실무에서 만나는 곳",[100,101,102,106,109,112],"ul",{},[103,104,105],"li",{},"JWT 서명 (HS256, RS256)",[103,107,108],{},"웹훅 검증 (Stripe, GitHub 등)",[103,110,111],{},"서버 간 API 인증",[103,113,114],{},"AWS SigV4 요청 서명",[95,116,118,119,123,124,127],{"id":117},"포인트1-서명은-누가-보냈는지와-내용이-안-바뀌었는지를-증명한다","포인트1 — 서명은 ",[120,121,122],"code",{},"누가 보냈는지","와 ",[120,125,126],{},"내용이 안 바뀌었는지","를 증명한다",[91,129,130,131,134],{},"해시는 내용이 바뀌었는지 확인할 수 있지만(",[120,132,133],{},"무결성","),\n누가 만들었는지는 알 수 없다.",[91,136,137,138,141,142,144],{},"서명은 해시에 비밀키를 더해\n\"이 사람이 만들었고(",[120,139,140],{},"인증","), 중간에 변조되지 않았다(",[120,143,133],{},")\"를 증명한다.",[91,146,147],{},"그래서 JWT, 웹훅, 서버 간 통신에서 상대방을 신뢰할 수 있다.",[95,149,151],{"id":150},"포인트2-서명의-핵심도-결국-키-관리다","포인트2 — 서명의 핵심도 결국 키 관리다",[91,153,154],{},"공격자가 서명 키를 얻으면 정상 서버처럼 서명을 만들 수 있다.",[91,156,157],{},"따라서 알고리즘보다 중요한 것은\n키를 안전하게 보관하고 주기적으로 교체하는 것이다.",[91,159,160],{},"실무에서는 검증된 라이브러리를 사용하고,\n키는 KMS나 Vault 같은 전용 시스템으로 관리한다.",[162,163],"br",{},[91,165,166],{},"대표 알고리즘: HMAC-SHA256(HS256), RSA(RS256), ECDSA(ES256)",[88,168,169],{},[91,170,171],{},"한 줄 — 서명은 \"누가 보냈는지\"와 \"내용이 안 바뀌었는지\"를 증명한다.",{"title":38,"searchDepth":173,"depth":173,"links":174},3,[175],{"id":85,"depth":176,"text":86,"children":177},2,[178,179,181],{"id":97,"depth":173,"text":98},{"id":117,"depth":173,"text":180},"포인트1 — 서명은 누가 보냈는지와 내용이 안 바뀌었는지를 증명한다",{"id":150,"depth":173,"text":151},"2026-06-03T15:40:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-signature",{"description":38},"feeds\u002F2026-06-03-signature",[190,191,192,193,194,36,140],"보안","암호기초","백엔드","서명","HMAC","zVf80lRF5E4ZkBH3gZ8nYEoID0zftcLEwHaCgosKy_o",{"id":197,"title":198,"body":199,"date":249,"description":203,"extension":183,"meta":250,"navigation":185,"path":251,"seo":252,"stem":253,"tags":254,"__hash__":256},"feeds\u002Ffeeds\u002F2026-06-01-hmac.md","2026 06 01 Hmac",{"type":80,"value":200,"toc":246},[201,204,207,213,216,223,228,231,237,240,243],[91,202,203],{},"시스템을 구축하다 보면 마주치게 되는 server to server 구간의 HTTP 통신.\n이때 서버 B는 들어온 요청이 정말 서버 A로부터 온 것인지 신뢰할 수 있어야 한다.",[91,205,206],{},"주로 JWT나 HMAC 같은 서명(인증) 방식으로 요청의 신뢰성을 증명한다.\n\"내용이 위변조됐는지\" \u002F \"누가 보냈는지\"를 검증하는 것이다. 내용 자체의 기밀성은 HTTPS(암호화)가 담당한다.",[208,209,210],"ol",{},[103,211,212],{},"JWT 방식",[91,214,215],{},"보내는 서버 A가 JWT에 서명하고, 받는 서버 B가 그 서명을 검증하여 약속된 클라이언트가 맞는지 확인한다.\n대칭키(HS256)를 쓰면 서버 간에 시크릿 키를 공유하고, 비대칭키(RS256 등)를 쓰면 A가 개인키로 서명하고 B는 공개키로 검증하므로 키를 공유하지 않는다.",[91,217,218],{},[219,220],"img",{"alt":221,"src":222},"JWT 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F01.png",[208,224,225],{"start":176},[103,226,227],{},"HMAC (Hash-based Message Authentication Code)",[91,229,230],{},"서버 간에 시크릿 키를 공유한다.\n요청 하는 서버는 요청 정보(Request Body 등)를 시크릿 키를 이용해 해시 기반 서명값(MAC)으로 변환하고, 그 값을 \"헤더에 담아 전송\"한다.\n요청을 받은 서버는 요청 정보(Request Body 등) 을 동일한 시크릿 키로 해시 기반 서명값(MAC)으로 변환하고, \"그 결과가 헤더의 값과 같은지 확인하여 검증\"한다.",[91,232,233],{},[219,234],{"alt":235,"src":236},"HMAC 방식의 서명","\u002Ffreak\u002Fimages\u002Ffeeds\u002F2026-06-01\u002F02.png",[91,238,239],{},"HMAC을 사용하면 시크릿 키가 유출되지 않는 한, 중간에서 공격자가 요청 정보를 위변조하더라도 유효한 서명값을 만들 수 없어 탐지·거부된다. 그래서 보안이 중요한 금융권이나 웹훅 검증에서 주로 사용된다.\n다만 HMAC 서명만으로는 정상 요청을 그대로 가로채 다시 보내는 재전송(replay) 공격은 막지 못한다. timestamp와 nonce를 함께 서명에 포함하면 이를 보완할 수 있다.",[83,241,242],{"id":242},"정리",[91,244,245],{},"신뢰할 수 있는 내부망 네트워크 안에서의 server to server 통신이라면 JWT 방식으로도 충분하다.\n\"요청 정보가 변조되지 않았는지\", \"정말 시크릿 키를 가진 소유자가 보낸 요청이 맞는지\"까지 검증해야 한다면 HMAC을 사용한다.",{"title":38,"searchDepth":173,"depth":173,"links":247},[248],{"id":242,"depth":176,"text":242},"2026-06-01T20:36:00+09:00",{},"\u002Ffeeds\u002F2026-06-01-hmac",{"description":203},"feeds\u002F2026-06-01-hmac",[190,255,194,36,140],"네트워크","mJQJW2YkEiLfOXtm6jWO4bEV6DvCkJ55q9yOyoAMhZY",1782923313179]