헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[333,334,336],"h4",{"id":335},"인코딩-암호화","인코딩 ≠ 암호화",[119,338,339,342,345],{},[122,340,341],{},"Base64는 키가 없다.",[122,343,344],{},"누구나 디코딩할 수 있다.",[122,346,347],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[333,349,351],{"id":350},"해시-서명","해시 ≠ 서명",[119,353,354,357,360],{},[122,355,356],{},"해시는 데이터의 지문을 생성한다.",[122,358,359],{},"같은 입력은 항상 같은 해시값을 만든다.",[122,361,362],{},"데이터가 변경되면 해시값도 달라진다.",[110,364,365],{},"반면 서명은",[119,367,368,371,374],{},[122,369,370],{},"해시에 키를 결합하여 생성한다.",[122,372,373],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[122,375,376],{},"누가 생성했는지까지 검증할 수 있다.",[110,378,379],{},"즉,",[107,381,382],{},[110,383,384],{},"서명(Signature) = 해시(Hash) + 키(Key)",[110,386,387],{},"라고 생각하면 이해하기 쉽다.",[333,389,391],{"id":390},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[110,393,124,394,397,398,401,402,406],{},[126,395,396],{},"HS256","은 ",[126,399,400],{},"HMAC-SHA256","을 사용하는 ",[403,404,405],"strong",{},"서명 알고리즘","이다.",[110,408,409],{},"토큰 내용을 숨기는 것이 아니라,",[119,411,412,415],{},[122,413,414],{},"토큰이 위조되지 않았는지",[122,416,417],{},"신뢰할 수 있는 발급자가 만들었는지",[110,419,420],{},"를 검증하기 위해 사용된다.",[114,422,424],{"id":423},"한-줄-요약","한 줄 요약",[107,426,427],{},[110,428,429,430,432,433,436,437,440,441,444],{},"형식만 바꾸면 ",[403,431,206],{},", 숨기면 ",[403,434,435],{},"암호화",", 지문(위\u002F변조검사) 찍으면 ",[403,438,439],{},"해시",", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[403,442,443],{},"서명",".",{"title":54,"searchDepth":188,"depth":188,"links":446},[447,448,454],{"id":216,"depth":188,"text":217},{"id":330,"depth":188,"text":331,"children":449},[450,452,453],{"id":335,"depth":451,"text":336},4,{"id":350,"depth":451,"text":351},{"id":390,"depth":451,"text":391},{"id":423,"depth":188,"text":424},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":54},"feeds\u002F2026-06-03-crypto-basics",[82,204,206,435,439,443],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1780811789196]