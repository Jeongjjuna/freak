",[115,331,333],{"id":332},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[335,336,338],"h4",{"id":337},"인코딩-암호화","인코딩 ≠ 암호화",[120,340,341,344,347],{},[123,342,343],{},"Base64는 키가 없다.",[123,345,346],{},"누구나 디코딩할 수 있다.",[123,348,349],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[335,351,353],{"id":352},"해시-서명","해시 ≠ 서명",[120,355,356,359,362],{},[123,357,358],{},"해시는 데이터의 지문을 생성한다.",[123,360,361],{},"같은 입력은 항상 같은 해시값을 만든다.",[123,363,364],{},"데이터가 변경되면 해시값도 달라진다.",[111,366,367],{},"반면 서명은",[120,369,370,373,376],{},[123,371,372],{},"해시에 키를 결합하여 생성한다.",[123,374,375],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[123,377,378],{},"누가 생성했는지까지 검증할 수 있다.",[111,380,381],{},"즉,",[108,383,384],{},[111,385,386],{},"서명(Signature) = 해시(Hash) + 키(Key)",[111,388,389],{},"라고 생각하면 이해하기 쉽다.",[335,391,393],{"id":392},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[111,395,125,396,399,400,403,404,408],{},[127,397,398],{},"HS256","은 ",[127,401,402],{},"HMAC-SHA256","을 사용하는 ",[405,406,407],"strong",{},"서명 알고리즘","이다.",[111,410,411],{},"토큰 내용을 숨기는 것이 아니라,",[120,413,414,417],{},[123,415,416],{},"토큰이 위조되지 않았는지",[123,418,419],{},"신뢰할 수 있는 발급자가 만들었는지",[111,421,422],{},"를 검증하기 위해 사용된다.",[115,424,426],{"id":425},"한-줄-요약","한 줄 요약",[108,428,429],{},[111,430,431,432,434,435,438,439,442,443,446],{},"형식만 바꾸면 ",[405,433,207],{},", 숨기면 ",[405,436,437],{},"암호화",", 지문(위\u002F변조검사) 찍으면 ",[405,440,441],{},"해시",", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[405,444,445],{},"서명",".",{"title":53,"searchDepth":189,"depth":189,"links":448},[449,450,456],{"id":218,"depth":189,"text":219},{"id":332,"depth":189,"text":333,"children":451},[452,454,455],{"id":337,"depth":453,"text":338},4,{"id":352,"depth":453,"text":353},{"id":392,"depth":453,"text":393},{"id":425,"depth":189,"text":426},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":53},"feeds\u002F2026-06-03-crypto-basics",[205,207,437,441,445],"DiJZVjRCgtWgXEW1t3eXSnpdeyUQmyB_r7uG-8JAGfk",1780808014825]