,337],"h4",{"id":336},"인코딩-암호화","인코딩 ≠ 암호화",[120,339,340,343,346],{},[123,341,342],{},"Base64는 키가 없다.",[123,344,345],{},"누구나 디코딩할 수 있다.",[123,347,348],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[334,350,352],{"id":351},"해시-서명","해시 ≠ 서명",[120,354,355,358,361],{},[123,356,357],{},"해시는 데이터의 지문을 생성한다.",[123,359,360],{},"같은 입력은 항상 같은 해시값을 만든다.",[123,362,363],{},"데이터가 변경되면 해시값도 달라진다.",[111,365,366],{},"반면 서명은",[120,368,369,372,375],{},[123,370,371],{},"해시에 키를 결합하여 생성한다.",[123,373,374],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[123,376,377],{},"누가 생성했는지까지 검증할 수 있다.",[111,379,380],{},"즉,",[108,382,383],{},[111,384,385],{},"서명(Signature) = 해시(Hash) + 키(Key)",[111,387,388],{},"라고 생각하면 이해하기 쉽다.",[334,390,392],{"id":391},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[111,394,125,395,398,399,402,403,407],{},[127,396,397],{},"HS256","은 ",[127,400,401],{},"HMAC-SHA256","을 사용하는 ",[404,405,406],"strong",{},"서명 알고리즘","이다.",[111,409,410],{},"토큰 내용을 숨기는 것이 아니라,",[120,412,413,416],{},[123,414,415],{},"토큰이 위조되지 않았는지",[123,417,418],{},"신뢰할 수 있는 발급자가 만들었는지",[111,420,421],{},"를 검증하기 위해 사용된다.",[115,423,425],{"id":424},"한-줄-요약","한 줄 요약",[108,427,428],{},[111,429,430,431,433,434,437,438,441,442,445],{},"형식만 바꾸면 ",[404,432,208],{},", 숨기면 ",[404,435,436],{},"암호화",", 지문(위\u002F변조검사) 찍으면 ",[404,439,440],{},"해시",", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[404,443,444],{},"서명",".",{"title":59,"searchDepth":189,"depth":189,"links":447},[448,449,455],{"id":217,"depth":189,"text":218},{"id":331,"depth":189,"text":332,"children":450},[451,453,454],{"id":336,"depth":452,"text":337},4,{"id":351,"depth":452,"text":352},{"id":391,"depth":452,"text":392},{"id":424,"depth":189,"text":425},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":59},"feeds\u002F2026-06-03-crypto-basics",[205,206,208,436,440,444],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1780828888933]