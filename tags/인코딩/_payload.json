346,347],{},"반면 서명은",[100,349,350,353,356],{},[103,351,352],{},"해시에 키를 결합하여 생성한다.",[103,354,355],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[103,357,358],{},"누가 생성했는지까지 검증할 수 있다.",[91,360,361],{},"즉,",[88,363,364],{},[91,365,366],{},"서명(Signature) = 해시(Hash) + 키(Key)",[91,368,369],{},"라고 생각하면 이해하기 쉽다.",[315,371,373],{"id":372},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[91,375,105,376,379,380,383,384,388],{},[107,377,378],{},"HS256","은 ",[107,381,382],{},"HMAC-SHA256","을 사용하는 ",[385,386,387],"strong",{},"서명 알고리즘","이다.",[91,390,391],{},"토큰 내용을 숨기는 것이 아니라,",[100,393,394,397],{},[103,395,396],{},"토큰이 위조되지 않았는지",[103,398,399],{},"신뢰할 수 있는 발급자가 만들었는지",[91,401,402],{},"를 검증하기 위해 사용된다.",[95,404,406],{"id":405},"한-줄-요약","한 줄 요약",[88,408,409],{},[91,410,411,412,414,415,418,419,422,423,426],{},"형식만 바꾸면 ",[385,413,189],{},", 숨기면 ",[385,416,417],{},"암호화",", 지문(위\u002F변조검사) 찍으면 ",[385,420,421],{},"해시",", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[385,424,425],{},"서명",".",{"title":38,"searchDepth":169,"depth":169,"links":428},[429,430,436],{"id":198,"depth":169,"text":199},{"id":312,"depth":169,"text":313,"children":431},[432,434,435],{"id":317,"depth":433,"text":318},4,{"id":332,"depth":433,"text":333},{"id":372,"depth":433,"text":373},{"id":405,"depth":169,"text":406},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":38},"feeds\u002F2026-06-03-crypto-basics",[186,187,189,417,421,425],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1782923313199]