,{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[324,340,342],{"id":341},"해시-서명","해시 ≠ 서명",[120,344,345,348,351],{},[123,346,347],{},"해시는 데이터의 지문을 생성한다.",[123,349,350],{},"같은 입력은 항상 같은 해시값을 만든다.",[123,352,353],{},"데이터가 변경되면 해시값도 달라진다.",[111,355,356],{},"반면 서명은",[120,358,359,362,365],{},[123,360,361],{},"해시에 키를 결합하여 생성한다.",[123,363,364],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[123,366,367],{},"누가 생성했는지까지 검증할 수 있다.",[111,369,370],{},"즉,",[108,372,373],{},[111,374,375],{},"서명(Signature) = 해시(Hash) + 키(Key)",[111,377,378],{},"라고 생각하면 이해하기 쉽다.",[324,380,382],{"id":381},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[111,384,385,386,389,390,393,394,398],{},"JWT의 ",[171,387,388],{},"HS256","은 ",[171,391,392],{},"HMAC-SHA256","을 사용하는 ",[395,396,397],"strong",{},"서명 알고리즘","이다.",[111,400,401],{},"토큰 내용을 숨기는 것이 아니라,",[120,403,404,407],{},[123,405,406],{},"토큰이 위조되지 않았는지",[123,408,409],{},"신뢰할 수 있는 발급자가 만들었는지",[111,411,412],{},"를 검증하기 위해 사용된다.",[115,414,416],{"id":415},"한-줄-요약","한 줄 요약",[108,418,419],{},[111,420,421,422,425,426,429,430,432,433,436],{},"형식만 바꾸면 ",[395,423,424],{},"인코딩",", 숨기면 ",[395,427,428],{},"암호화",", 지문(위\u002F변조검사) 찍으면 ",[395,431,198],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[395,434,435],{},"서명",".",{"title":59,"searchDepth":181,"depth":181,"links":438},[439,440,446],{"id":207,"depth":181,"text":208},{"id":321,"depth":181,"text":322,"children":441},[442,444,445],{"id":326,"depth":443,"text":327},4,{"id":341,"depth":443,"text":342},{"id":381,"depth":443,"text":382},{"id":415,"depth":181,"text":416},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":59},"feeds\u002F2026-06-03-crypto-basics",[196,197,424,428,198,435],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1781631563450]