0,"value":81,"toc":160},"minimark",[82,87,94,99,115,119,122,125,128,132,135,138,141,144,147,155],[83,84,86],"h2",{"id":85},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[88,89,90],"blockquote",{},[91,92,93],"p",{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[95,96,98],"h3",{"id":97},"실무에서-만나는-곳","실무에서 만나는 곳",[100,101,102,106,109,112],"ul",{},[103,104,105],"li",{},"비밀번호 저장",[103,107,108],{},"파일 무결성 검증",[103,110,111],{},"캐시 키 생성",[103,113,114],{},"Git 커밋 식별자",[95,116,118],{"id":117},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[91,120,121],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[91,123,124],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[91,126,127],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[95,129,131],{"id":130},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[91,133,134],{},"SHA-256은 매우 빠른 알고리즘이다.",[91,136,137],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[91,139,140],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[91,142,143],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[145,146],"br",{},[91,148,149,150,154],{},"대표 알고리즘: SHA-256·SHA-512(",[151,152,153],"code",{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[88,156,157],{},[91,158,159],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":38,"searchDepth":161,"depth":161,"links":162},3,[163],{"id":85,"depth":164,"text":86,"children":165},2,[166,167,168],{"id":97,"depth":161,"text":98},{"id":117,"depth":161,"text":118},{"id":130,"depth":161,"text":131},"2026-06-03T15:30:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-hash",{"description":38},"feeds\u002F2026-06-03-hash",[177,178,179],"보안","암호기초","해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":182,"title":183,"body":184,"date":428,"description":38,"extension":170,"meta":429,"navigation":172,"path":430,"seo":431,"stem":432,"tags":433,"__hash__":434},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics"