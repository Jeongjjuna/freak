e 메서드에 적용할 수 없는 이유 (feat. @Transactional)","2026-02-07",[70,90,83,91],"AOP","Transaction","\u002Fimages\u002Fthumbnails\u002Fspring-boot-java.png",[],[95,198],{"id":96,"title":97,"body":98,"date":187,"description":54,"extension":188,"meta":189,"navigation":190,"path":191,"seo":192,"stem":193,"tags":194,"__hash__":197},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":99,"value":100,"toc":179},"minimark",[101,106,113,118,134,138,141,144,147,151,154,157,160,163,166,174],[102,103,105],"h2",{"id":104},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[107,108,109],"blockquote",{},[110,111,112],"p",{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[114,115,117],"h3",{"id":116},"실무에서-만나는-곳","실무에서 만나는 곳",[119,120,121,125,128,131],"ul",{},[122,123,124],"li",{},"비밀번호 저장",[122,126,127],{},"파일 무결성 검증",[122,129,130],{},"캐시 키 생성",[122,132,133],{},"Git 커밋 식별자",[114,135,137],{"id":136},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[110,139,140],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[110,142,143],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[110,145,146],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[114,148,150],{"id":149},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[110,152,153],{},"SHA-256은 매우 빠른 알고리즘이다.",[110,155,156],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[110,158,159],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[110,161,162],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[164,165],"br",{},[110,167,168,169,173],{},"대표 알고리즘: SHA-256·SHA-512(",[170,171,172],"code",{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[107,175,176],{},[110,177,178],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":54,"searchDepth":180,"depth":180,"links":181},3,[182],{"id":104,"depth":28,"text":105,"children":183},[184,185,186],{"id":116,"depth":180,"text":117},{"id":136,"depth":180,"text":137},{"id":149,"depth":180,"text":150},"2026-06-03T15:30:00+09:00","md",{},true,"\u002Ffeeds\u002F2026-06-03-hash",{"description":54},"feeds\u002F2026-06-03-hash",[82,195,196],"암호기초","해시","i5ZY6AYI4dIZUR14-fNvk6P7tkXBYny-GdNSwcUcizw",{"id":199,"title":200,"body":201,"date":445,"description":54,"extension":188,"meta":446,"navigation":190,"path":447,"seo":448,"stem":449,"tags":450,"__hash__":451},"feeds\u002Ffeeds\u002F2026-06-03-crypto-basics.md","2026 06 03 Crypto Basics",{"type":99,"value":202,"toc":435},[203,207,210,317,321,326,337,341,352,355,366,369,374,377,381,397,400,408,411,415],[114,204,206],{"id":205},"인코딩-암호화-해시-서명-한-번에-구분하기","인코딩 · 암호화 · 해시 · 서명 — 한 번에 구분하기",[110,208,209],{},"비슷해 보이지만 목적과 방향성으로 나누면 명확해진다.",[211,212,213,235],"table",{},[214,215,216],"thead",{},[217,218,219,223,226,229,232],"tr",{},[220,221,222],"th",{},"구분",[220,224,225],{},"목적",[220,227,228],{},"방향성",[220,230,231],{},"키",[220,233,234],{},"대표 알고리즘",[236,237,238,262,281,299],"tbody",{},[217,239,240,246,253,256,259],{},[241,242,243],"td",{},[170,244,245],{},"인코딩 (Encoding)",[241,247,248,249],{},"형식 변환 ",[250,251,252],"em",{},"(보안 아님)",[241,254,255],{},"양방향 (키 불필요)",[241,257,258],{},"x",[241,260,261],{},"Base64, Base64URL, Hex",[217,263,264,269,272,275,278],{},[241,265,266],{},[170,267,268],{},"양방향 암호화 (Encryption)",[241,270,271],{},"기밀성 — 내용 숨기기",[241,273,274],{},"양방향 (복호화 가능)",[241,276,277],{},"o",[241,279,280],{},"AES(대칭키), RSA(비대칭키)",[217,282,283,288,291,294,296],{},[241,284,285],{},[170,286,287],{},"해시 (Hash)",[241,289,290],{},"무결성 — 데이터 지문(위\u002F변조 검사)",[241,292,293],{},"단방향 (복원 불가)",[241,295,258],{},[241,297,298],{},"SHA-256, SHA-512, SHA-3",[217,300,301,306,309,312,314],{},[241,302,303],{},[170,304,305],{},"서명 (Signature)",[241,307,308],{},"무결성 + 인증 — 위변조 + 출처",[241,310,311],{},"단방향 (해시 기반)",[241,313,277],{},[241,315,316],{},"HMAC-SHA256(HS256), RS256, ES256",[114,318,320],{"id":319},"자주-헷갈리는-포인트","🤔 자주 헷갈리는 포인트",[322,323,325],"h4",{"id":324},"인코딩-암호화","인코딩 ≠ 암호화",[119,327,328,331,334],{},[122,329,330],{},"Base64는 키가 없다.",[122,332,333],{},"누구나 디코딩할 수 있다.",[122,335,336],{},"시크릿을 Base64로 저장하는 것은 보안이 아니라 단순한 형식 변환이다.",[322,338,340],{"id":339},"해시-서명","해시 ≠ 서명",[119,342,343,346,349],{},[122,344,345],{},"해시는 데이터의 지문을 생성한다.",[122,347,348],{},"같은 입력은 항상 같은 해시값을 만든다.",[122,350,351],{},"데이터가 변경되면 해시값도 달라진다.",[110,353,354],{},"반면 서명은",[119,356,357,360,363],{},[122,358,359],{},"해시에 키를 결합하여 생성한다.",[122,361,362],{},"데이터가 변경되지 않았음을 검증할 수 있다.",[122,364,365],{},"누가 생성했는지까지 검증할 수 있다.",[110,367,368],{},"즉,",[107,370,371],{},[110,372,373],{},"서명(Signature) = 해시(Hash) + 키(Key)",[110,375,376],{},"라고 생각하면 이해하기 쉽다.",[322,378,380],{"id":379},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[110,382,383,384,387,388,391,392,396],{},"JWT의 ",[170,385,386],{},"HS256","은 ",[170,389,390],{},"HMAC-SHA256","을 사용하는 ",[393,394,395],"strong",{},"서명 알고리즘","이다.",[110,398,399],{},"토큰 내용을 숨기는 것이 아니라,",[119,401,402,405],{},[122,403,404],{},"토큰이 위조되지 않았는지",[122,406,407],{},"신뢰할 수 있는 발급자가 만들었는지",[110,409,410],{},"를 검증하기 위해 사용된다.",[114,412,414],{"id":413},"한-줄-요약","한 줄 요약",[107,416,417],{},[110,418,419,420,423,424,427,428,430,431,434],{},"형식만 바꾸면 ",[393,421,422],{},"인코딩",", 숨기면 ",[393,425,426],{},"암호화",", 지문(위\u002F변조검사) 찍으면 ",[393,429,196],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[393,432,433],{},"서명",".",{"title":54,"searchDepth":180,"depth":180,"links":436},[437,438,444],{"id":205,"depth":180,"text":206},{"id":319,"depth":180,"text":320,"children":439},[440,442,443],{"id":324,"depth":441,"text":325},4,{"id":339,"depth":441,"text":340},{"id":379,"depth":441,"text":380},{"id":413,"depth":180,"text":414},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":54},"feeds\u002F2026-06-03-crypto-basics",[82,195,422,426,196,433],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1780814129407]