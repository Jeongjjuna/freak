","2026-04-08",[50,89,90,91,92],"Spring","아키텍처","테스트","AI Agent","\u002Fimages\u002Fthumbnails\u002Fspring.png",[],[96,200],{"id":97,"title":98,"body":99,"date":188,"description":59,"extension":189,"meta":190,"navigation":191,"path":192,"seo":193,"stem":194,"tags":195,"__hash__":199},"feeds\u002Ffeeds\u002F2026-06-03-hash.md","2026 06 03 Hash",{"type":100,"value":101,"toc":180},"minimark",[102,107,114,119,135,139,142,145,148,152,155,158,161,164,167,175],[103,104,106],"h2",{"id":105},"백엔드가-만나는-암호-기초-34-해시-단방향","백엔드가 만나는 암호 기초 (3\u002F4) — 해시 (단방향)",[108,109,110],"blockquote",{},[111,112,113],"p",{},"믹서기 🥤 — 갈면 원래 재료로 되돌릴 수 없다.",[115,116,118],"h3",{"id":117},"실무에서-만나는-곳","실무에서 만나는 곳",[120,121,122,126,129,132],"ul",{},[123,124,125],"li",{},"비밀번호 저장",[123,127,128],{},"파일 무결성 검증",[123,130,131],{},"캐시 키 생성",[123,133,134],{},"Git 커밋 식별자",[115,136,138],{"id":137},"포인트1-해시는-원래-값으로-되돌릴-수-없다","포인트1 — 해시는 원래 값으로 되돌릴 수 없다",[111,140,141],{},"해시는 입력값을 고정 길이의 결과값으로 변환하는 기술이다.",[111,143,144],{},"같은 입력은 항상 같은 해시값을 만들지만,\n해시값만 보고 원래 값을 알아내는 것은 불가능하다.",[111,146,147],{},"그래서 비밀번호는 원문 대신 해시값만 저장하고,\n로그인 시 입력된 비밀번호를 다시 해시해서 비교한다.",[115,149,151],{"id":150},"포인트2-비밀번호는-일부러-느리게-계산한다","포인트2 — 비밀번호는 일부러 느리게 계산한다",[111,153,154],{},"SHA-256은 매우 빠른 알고리즘이다.",[111,156,157],{},"문제는 서버뿐 아니라 공격자도 빠르게 계산할 수 있다는 점이다.\n비밀번호가 유출되면 공격자는 초당 수십억 개의 후보를 대입해 볼 수 있다.",[111,159,160],{},"그래서 비밀번호 저장에는 bcrypt, scrypt, Argon2처럼\n일부러 계산을 느리게 만든 알고리즘을 사용한다.",[111,162,163],{},"사용자에게는 로그인 시 0.1초 정도의 차이지만,\n공격자에게는 수억 번의 시도 비용이 추가된다.",[165,166],"br",{},[111,168,169,170,174],{},"대표 알고리즘: SHA-256·SHA-512(",[171,172,173],"code",{},"무결성 검증","), bcrypt·scrypt·Argon2(비밀번호)",[108,176,177],{},[111,178,179],{},"한 줄 요약: 해시는 되돌릴 수 없다. 비밀번호는 느린 해시를 사용한다.",{"title":59,"searchDepth":181,"depth":181,"links":182},3,[183],{"id":105,"depth":28,"text":106,"children":184},[185,186,187],{"id":117,"depth":181,"text":118},{"id":137,"depth":181,"text":138},{"id":150,"depth":181,"text":151},"2026-06-03T15:30:00+09:00","md",{},true,"\u002Ffeeds\u