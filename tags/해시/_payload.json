지까지 검증할 수 있다.",[91,350,351],{},"즉,",[88,353,354],{},[91,355,356],{},"서명(Signature) = 해시(Hash) + 키(Key)",[91,358,359],{},"라고 생각하면 이해하기 쉽다.",[305,361,363],{"id":362},"jwt의-hs256은-암호화가-아니다","JWT의 HS256은 암호화가 아니다",[91,365,366,367,370,371,374,375,379],{},"JWT의 ",[151,368,369],{},"HS256","은 ",[151,372,373],{},"HMAC-SHA256","을 사용하는 ",[376,377,378],"strong",{},"서명 알고리즘","이다.",[91,381,382],{},"토큰 내용을 숨기는 것이 아니라,",[100,384,385,388],{},[103,386,387],{},"토큰이 위조되지 않았는지",[103,389,390],{},"신뢰할 수 있는 발급자가 만들었는지",[91,392,393],{},"를 검증하기 위해 사용된다.",[95,395,397],{"id":396},"한-줄-요약","한 줄 요약",[88,399,400],{},[91,401,402,403,406,407,410,411,413,414,417],{},"형식만 바꾸면 ",[376,404,405],{},"인코딩",", 숨기면 ",[376,408,409],{},"암호화",", 지문(위\u002F변조검사) 찍으면 ",[376,412,179],{},", 지문(위\u002F변조검사)에 도장까지 찍으면 ",[376,415,416],{},"서명",".",{"title":38,"searchDepth":161,"depth":161,"links":419},[420,421,427],{"id":188,"depth":161,"text":189},{"id":302,"depth":161,"text":303,"children":422},[423,425,426],{"id":307,"depth":424,"text":308},4,{"id":322,"depth":424,"text":323},{"id":362,"depth":424,"text":363},{"id":396,"depth":161,"text":397},"2026-06-03T15:00:00+09:00",{},"\u002Ffeeds\u002F2026-06-03-crypto-basics",{"description":38},"feeds\u002F2026-06-03-crypto-basics",[177,178,405,409,179,416],"gdwHaqNPAGKGhhqbVWgUgU6A01GR5Gj8BW9oeqUOLkU",1782923313179]